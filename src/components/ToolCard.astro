---
import AnimatedIcon from './AnimatedIcon.astro'
import type { Tool } from '../data/tools'

interface Props {
  tool: Tool
}

const { tool } = Astro.props
---

<a href={`/tools/${tool.id}/`} class="group block bg-gray-900 border border-gray-800 rounded-xl p-5 hover:border-blue-600 hover:-translate-y-1 transition-all duration-200">
  <div class="w-12 h-12 bg-gray-800 rounded-lg flex items-center justify-center mb-4 text-blue-400 group-hover:bg-blue-600 group-hover:text-white transition-all duration-200 overflow-visible">
    <AnimatedIcon type={tool.icon} />
  </div>
  <h3 class="font-semibold text-gray-100 group-hover:text-blue-400 transition-colors">{tool.name}</h3>
  <p class="text-gray-500 text-sm mt-1">{tool.description}</p>
</a>
