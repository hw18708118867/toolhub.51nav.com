      <rect x="27" y="16" width="10" height="10" rx="2" fill="#60a5fa" style="animation: float 3.5s ease-in-out infinite 0.3s"/>
      <rect x="40" y="16" width="10" height="10" rx="2" fill="#93c5fd" style="animation: float 3s ease-in-out infinite 0.6s"/>
      <rect x="14" y="31" width="10" height="10" rx="2" fill="#60a5fa" style="animation: float 3.5s ease-in-out infinite 0.9s"/>
