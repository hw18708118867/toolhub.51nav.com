---
interface Props {
  type: string
  size?: 'sm' | 'md' | 'lg'
}

const { type, size = 'md' } = Astro.props

const sizeClasses = {
  sm: 'w-8 h-8',
  md: 'w-10 h-10',
  lg: 'w-14 h-14',
}
---

<div class={sizeClasses[size]}>
  {type === 'json' && (
    <svg viewBox="0 0 64 64" fill="none" class="w-full h-full overflow-visible">
      <defs>
        <style>
          @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-3px); }
          }
        </style>
      </defs>
      <rect x="8" y="8" width="48" height="48" rx="10" fill="#1e293b" stroke="#3b82f6" stroke-width="2"/>
      <rect x="16" y="20" width="12" height="6" rx="2" fill="#3b82f6" style="animation: float 3s ease-in-out infinite"/>
      <rect x="16" y="30" width="20" height="6" rx="2" fill="#60a5fa" style="animation: float 3.5s ease-in-out infinite 0.5s"/>
      <rect x="16" y="40" width="16" height="6" rx="2" fill="#93c5fd" style="animation: float 3.5s ease-in-out infinite 1s"/>
      <rect x="38" y="34" width="10" height="6" rx="2" fill="#3b82f6" style="animation: float 3s ease-in-out infinite 0.5s"/>
      <circle cx="46" cy="23" r="3" fill="#f59e0b" style="animation: float 3s ease-in-out infinite"/>
    </svg>
  )}

  {type === 'base64' && (
    <svg viewBox="0 0 64 64" fill="none" class="w-full h-full overflow-visible">
