---
interface Props {
  id: string
}

const { id } = Astro.props
---

<div id={id} class="hidden mt-4 px-4 py-3 rounded-lg"></div>

<script is:inline>
function showStatus(elId, message, type) {
  const el = document.getElementById(elId);
  if (!el) return;
  el.textContent = message;
  el.className = 'mt-4 px-4 py-3 rounded-lg';
  el.classList.remove('hidden');
  if (type === 'success') {
    el.classList.add('bg-green-900/40', 'border', 'border-green-800', 'text-green-400');
  } else {
    el.classList.add('bg-red-900/40', 'border', 'border-red-800', 'text-red-400');
  }
  setTimeout(() => el.classList.add('hidden'), 3000);
}
</script>