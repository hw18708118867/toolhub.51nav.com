---
import AnimatedLogo from './AnimatedLogo.astro'
---

<footer class="bg-gray-50 border-t border-gray-200 mt-auto dark:bg-gray-900 dark:border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12">
      <!-- Brand Column -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center overflow-visible">
            <AnimatedLogo />
          </div>
          <span class="font-bold text-xl text-gray-900 dark:text-white">DevTools Hub</span>
        </a>
        <p class="text-gray-500 mb-6 max-w-sm dark:text-gray-400">
          Free, fast, and easy-to-use developer tools. All processing happens locally in your browser. Your data stays private.
        </p>
      </div>

      <!-- Tools Columns -->
      <div>
        <h4 class="font-semibold text-gray-900 mb-4 dark:text-white">Text & Encoding</h4>
        <ul class="space-y-2">
          <li><a href="/tools/json-formatter/" class="text-gray-500 hover:text-gray-900 transition-colors dark:text-gray-400 dark:hover:text-white">JSON Formatter</a></li>
          <li><a href="/tools/base64-converter/" class="text-gray-500 hover:text-gray-900 transition-colors dark:text-gray-400 dark:hover:text-white">Base64 Converter</a></li>
          <li><a href="/tools/url-encode/" class="text-gray-500 hover:text-gray-900 transition-colors dark:text-gray-400 dark:hover:text-white">URL Encode</a></li>
          <li><a href="/tools/html-entities/" class="text-gray-500 hover:text-gray-900 transition-colors dark:text-gray-400 dark:hover:text-white">HTML Entities</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-gray-900 mb-4 dark:text-white">Development</h4>
        <ul class="space-y-2">
          <li><a href="/tools/regex-tester/" class="text-gray-500 hover:text-gray-900 transition-colors dark:text-gray-400 dark:hover:text-white">Regex Tester</a></li>
          <li><a href="/tools/diff-checker/" class="text-gray-500 hover:text-gray-900 transition-colors dark:text-gray-400 dark:hover:text-white">Diff Checker</a></li>
          <li><a href="/tools/sql-formatter/" class="text-gray-500 hover:text-gray-900 transition-colors dark:text-gray-400 dark:hover:text-white">SQL Formatter</a></li>
          <li><a href="/tools/jwt-decoder/" class="text-gray-500 hover:text-gray-900 transition-colors dark:text-gray-400 dark:hover:text-white">JWT Decoder</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-gray-900 mb-4 dark:text-white">Company</h4>
        <ul class="space-y-2">
          <li><a href="/about/" class="text-gray-500 hover:text-gray-900 transition-colors dark:text-gray-400 dark:hover:text-white">About</a></li>
          <li><a href="/contact/" class="text-gray-500 hover:text-gray-900 transition-colors dark:text-gray-400 dark:hover:text-white">Contact</a></li>
          <li><a href="/privacy/" class="text-gray-500 hover:text-gray-900 transition-colors dark:text-gray-400 dark:hover:text-white">Privacy</a></li>
          <li><a href="/terms/" class="text-gray-500 hover:text-gray-900 transition-colors dark:text-gray-400 dark:hover:text-white">Terms</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-gray-200 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 dark:border-gray-800">
      <p class="text-gray-400 text-sm dark:text-gray-500">
        &copy; {new Date().getFullYear()} DevTools Hub. All rights reserved.
      </p>
      <p class="text-gray-400 text-sm dark:text-gray-500">
        Made with ❤️ for developers
      </p>
    </div>
  </div>
</footer>