---
import BaseLayout from './BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

interface RelatedLink {
  href: string
  title: string
  desc: string
  type?: 'tool' | 'guide'
}

interface Props {
  title: string
  description: string
  breadcrumb?: string
  relatedTools?: RelatedLink[]
}

const { title, description, breadcrumb = 'Guide', relatedTools = [] } = Astro.props

const siteUrl = 'https://toolhub.51nav.com'
const canonicalPath = Astro.url.pathname
const pageUrl = `${siteUrl}${canonicalPath}`

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  url: pageUrl,
  publisher: { '@type': 'Organization', name: 'DevTools Hub', url: siteUrl },
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
}

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: `${siteUrl}/guides/` },
    { '@type': 'ListItem', position: 3, name: breadcrumb },
  ],
}
---

<BaseLayout {title} {description}>
  <Header />
  <main class="flex-1">
    <article class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-gray-400 mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-blue-500 transition-colors">Home</a>
        <span class="text-gray-300 dark:text-gray-600">/</span>
        <a href="/guides/" class="hover:text-blue-500 transition-colors">Guides</a>
        <span class="text-gray-300 dark:text-gray-600">/</span>
        <span class="text-gray-500 dark:text-gray-400">{breadcrumb}</span>
      </nav>

      <!-- Article Header -->
      <header class="mb-12">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 mb-6 leading-tight dark:text-white">
          <slot name="title" />
        </h1>
        <p class="text-lg sm:text-xl text-gray-500 leading-relaxed max-w-3xl dark:text-gray-400">
          <slot name="intro" />
        </p>
      </header>

      <!-- ===== 3-Column Layout ===== -->
      <div class="lg:grid lg:grid-cols-[220px_1fr] xl:grid-cols-[220px_1fr_260px] gap-10">

        <!-- LEFT: Table of Contents -->
        <aside class="hidden lg:block">
          <div class="sticky top-24">
            <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">On This Page</h4>
            <nav id="toc-nav" class="space-y-1.5 text-sm border-l-2 border-gray-200 dark:border-gray-800">
              <!-- Populated by JS -->
            </nav>
          </div>
        </aside>

        <!-- CENTER: Article Content -->
        <div class="min-w-0">
          <div id="guide-content" class="guide-content">
            <slot />
          </div>
        </div>

        <!-- RIGHT: Related Tools -->
        {relatedTools.length > 0 && (
          <aside class="hidden xl:block">
            <div class="sticky top-24">
              <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Tools</h4>
              <div class="space-y-2">
                {relatedTools.map(rt => (
                  <a href={rt.href} class="block p-3 bg-white border border-gray-200 rounded-lg hover:border-blue-500 hover:shadow-sm transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600">
                    <div class="flex items-center gap-2 mb-1">
                      <span class={`text-[10px] font-medium uppercase tracking-wider ${rt.type === 'tool' ? 'text-green-500' : 'text-blue-500'}`}>{rt.type || 'guide'}</span>
                    </div>
                    <h5 class="text-sm font-semibold text-gray-900 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">{rt.title}</h5>
                    <p class="text-xs text-gray-400 mt-1 leading-relaxed">{rt.desc}</p>
                  </a>
                ))}
              </div>
            </div>
          </aside>
        )}
      </div>

      <!-- Mobile: Related Tools (below content on smaller screens) -->
      {relatedTools.length > 0 && (
        <div class="mt-12 xl:hidden">
          <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Related Tools</h4>
          <div class="grid sm:grid-cols-2 gap-3">
            {relatedTools.map(rt => (
              <a href={rt.href} class="block p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-sm transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600">
                <span class={`text-[10px] font-medium uppercase tracking-wider ${rt.type === 'tool' ? 'text-green-500' : 'text-blue-500'}`}>{rt.type || 'guide'}</span>
                <h5 class="text-sm font-semibold text-gray-900 mt-1 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">{rt.title}</h5>
                <p class="text-xs text-gray-400 mt-1">{rt.desc}</p>
              </a>
            ))}
          </div>
        </div>
      )}
    </article>
  </main>
  <Footer />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)}></script>

  <!-- TOC Generator -->
  <script>
    (function() {
      const content = document.getElementById('guide-content');
      const toc = document.getElementById('toc-nav');
      if (!content || !toc) return;

      const headings = content.querySelectorAll('h2, h3');
      if (headings.length === 0) { toc.innerHTML = '<span class="text-gray-400 text-xs">No sections</span>'; return; }

      let html = '';
      headings.forEach((h, i) => {
        // Add an ID to the heading if it doesn't have one
        if (!h.id) h.id = 'section-' + i;
        const isH3 = h.tagName === 'H3';
        const text = h.textContent || '';
        html += `<a href="#${h.id}" class="block py-1 pl-3 ${isH3 ? 'ml-3 text-xs' : 'text-sm font-medium'} text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 transition-colors border-l-2 -ml-[2px] ${isH3 ? 'border-transparent hover:border-blue-400' : 'border-transparent hover:border-blue-500'}">${text}</a>`;
      });
      toc.innerHTML = html;

      // Highlight current section on scroll
      const links = toc.querySelectorAll('a');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          const link = toc.querySelector(`a[href="#${entry.target.id}"]`);
          if (link) {
            if (entry.isIntersecting) {
              links.forEach(l => l.classList.remove('text-blue-600', 'dark:text-blue-400', 'border-blue-500', 'font-semibold'));
              link.classList.add('text-blue-600', 'dark:text-blue-400', 'border-blue-500', 'font-semibold');
            }
          }
        });
      }, { rootMargin: '-80px 0px -70% 0px' });

      headings.forEach(h => observer.observe(h));
    })();
  </script>
</BaseLayout>

<style is:global>
  .guide-content {
    @apply text-gray-700 dark:text-gray-300 leading-relaxed;
  }
  .guide-content h2 {
    @apply text-2xl sm:text-3xl font-bold text-gray-900 mt-14 mb-5 pb-3 border-b border-gray-200 dark:text-white dark:border-gray-800;
  }
  .guide-content h3 {
    @apply text-xl font-semibold text-gray-900 mt-10 mb-4 dark:text-white;
  }
  .guide-content p {
    @apply mb-5 text-base sm:text-lg leading-8;
  }
  .guide-content strong {
    @apply font-semibold text-gray-900 dark:text-white;
  }
  .guide-content a {
    @apply text-blue-600 hover:text-blue-500 underline decoration-blue-300 hover:decoration-blue-500 underline-offset-2 transition-colors dark:text-blue-400 dark:decoration-blue-700 dark:hover:decoration-blue-400;
  }
  .guide-content ul, .guide-content ol {
    @apply mb-6 pl-6 space-y-2;
  }
  .guide-content ul { @apply list-disc; }
  .guide-content ol { @apply list-decimal; }
  .guide-content li {
    @apply text-base sm:text-lg leading-8;
  }
  .guide-content li > strong {
    @apply text-gray-900 dark:text-white;
  }
  .guide-content code {
    @apply px-1.5 py-0.5 bg-gray-100 text-rose-600 rounded text-sm font-mono dark:bg-gray-800 dark:text-rose-400;
  }
  .guide-content pre {
    @apply my-8 rounded-xl overflow-hidden border border-gray-200 dark:border-gray-700;
  }
  .guide-content pre[class*="language-"] {
    @apply rounded-xl border-0;
    margin: 2rem 0;
  }
  .guide-content pre code {
    @apply block p-6 text-sm sm:text-base leading-7 overflow-x-auto bg-transparent text-gray-100 rounded-none;
    font-family: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace;
  }
  .guide-content pre[class*="language-"] {
    background: #1e293b !important;
  }
  .dark .guide-content pre[class*="language-"] {
    background: #0f172a !important;
  }
  .guide-content table {
    @apply w-full text-left my-8 border-collapse;
  }
  .guide-content thead th {
    @apply py-3 px-4 text-sm font-semibold text-gray-900 bg-gray-50 border-b-2 border-gray-200 dark:text-white dark:bg-gray-900 dark:border-gray-700;
  }
  .guide-content tbody td {
    @apply py-3 px-4 text-sm text-gray-600 border-b border-gray-100 dark:text-gray-400 dark:border-gray-800;
  }
  .guide-content tbody tr:last-child td {
    @apply border-b-0;
  }
  .guide-content blockquote {
    @apply my-8 pl-5 py-1 border-l-4 border-blue-500 bg-blue-50/50 rounded-r-xl dark:bg-blue-950/30 dark:border-blue-400;
  }
  .guide-content blockquote p {
    @apply text-gray-700 dark:text-gray-300;
  }

  /* Smooth scroll for TOC anchor clicks */
  html { scroll-behavior: smooth; }
</style>
