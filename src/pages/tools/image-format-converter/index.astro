---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'image-format-converter')!
const steps = [
  { name: 'Upload an Image', text: 'Upload an image in any supported format — JPEG, PNG, WebP, or SVG. The tool reads the file and displays a preview with the current format and dimensions.' },
  { name: 'Choose Target Format', text: 'Select the output format — JPEG (best for photos), PNG (lossless, supports transparency), WebP (modern, smaller files), or SVG (vector). For JPEG, adjust the quality slider.' },
  { name: 'Download the Converted Image', text: 'Click "Convert & Download" to save the image in the new format. The converted file downloads immediately. No server processing — conversion happens entirely in your browser using Canvas.' },
]
const faq = [
  { question: 'Which format should I choose?', answer: 'JPEG: best for photographs and complex images, no transparency support. PNG: best for images with text, logos, screenshots, or transparency. WebP: modern alternative to both JPEG and PNG with better compression, supported in all modern browsers. SVG: only for vector graphics — converting a photo to SVG won\'t make it scalable.' },
  { question: 'Does conversion lose quality?', answer: 'JPEG to PNG: no loss (PNG is lossless), but file size increases. PNG to JPEG: quality loss from JPEG compression, and transparency is replaced with white. WebP offers better quality-to-size than JPEG at the same quality setting. For production use: start from the highest quality original, convert to the needed format, then compress.' },
  { question: 'Can I convert SVG to PNG/JPEG?', answer: 'Yes. The tool renders the SVG at its natural size and converts it to raster format. Large SVGs may produce large raster images. For SVG files, you can adjust the output dimensions before converting. For the reverse — raster to SVG — the tool cannot trace paths; use a vectorization tool instead.' },
]
---
<ToolLayout tool={tool} description="Free online image format converter. Convert images between JPEG, PNG, WebP and SVG in the browser. No upload required — all processing is local and private." {steps} {faq}>
  <div class="mb-6"><div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Upload Image</span></div><div class="p-6 text-center"><input type="file" id="fileInput" accept="image/*" class="hidden"><button id="uploadBtn" class="btn btn-primary" onclick="document.getElementById('fileInput').click()">Choose Image</button><p class="text-xs text-gray-400 mt-2">or drag and drop • JPEG, PNG, WebP, SVG</p></div></div></div>
  <div class="hidden" id="controls"><div class="grid md:grid-cols-2 gap-6">
    <div class="space-y-4"><div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Convert To</span></div><div class="p-4 space-y-3">
      <select id="format" class="form-select w-full bg-white border border-gray-200 rounded-lg px-3 py-2 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100"><option value="image/jpeg">JPEG</option><option value="image/png" selected>PNG</option><option value="image/webp">WebP</option></select>
      <div id="qualityRow"><label class="text-sm text-gray-600 dark:text-gray-400">Quality: <span id="qualityVal">90</span>%</label><input type="range" id="quality" class="w-full" min="10" max="100" value="90"></div>
      <button id="convertBtn" class="btn btn-primary w-full">Convert & Download</button></div></div></div>
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Original</span><span id="origInfo" class="text-xs text-gray-400 ml-2"></span></div><div class="p-4 flex items-center justify-center"><img id="preview" class="max-h-64 max-w-full object-contain"></div></div>
  </div></div>
  <section slot="relatedArticles" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2><div class="space-y-3">
      <a href="/guides/image-tools-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Image Tools Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Compress, resize, convert and optimize images for the web.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/image-compressor/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Image Compressor</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Compress JPEG, PNG and WebP images.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/image-resize/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Image Resize</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Resize images to exact pixel dimensions.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
  </div></section>
  <script>
    const fileInput=document.getElementById('fileInput') as HTMLInputElement,controls=document.getElementById('controls')!,format=document.getElementById('format') as HTMLSelectElement,quality=document.getElementById('quality') as HTMLInputElement,qualityVal=document.getElementById('qualityVal')!,qualityRow=document.getElementById('qualityRow')!,preview=document.getElementById('preview') as HTMLImageElement,origInfo=document.getElementById('origInfo')!,convertBtn=document.getElementById('convertBtn')!;
    let img:HTMLImageElement|null=null,origFmt='';
    fileInput.addEventListener('change',(e:any)=>{const f=e.target.files?.[0];if(f)loadImage(f)});
    document.addEventListener('dragover',e=>e.preventDefault());document.addEventListener('drop',e=>{e.preventDefault();const f=e.dataTransfer?.files?.[0];if(f)loadImage(f)});
    function loadImage(f:File){origFmt=f.type;const r=new FileReader();r.onload=()=>{img=new Image();img.onload=()=>{preview.src=r.result as string;origInfo.textContent=`${f.type.split('/')[1].toUpperCase()} • ${img!.width}×${img!.height}`;controls.classList.remove('hidden')};img.src=r.result as string};r.readAsDataURL(f)}
    format.addEventListener('change',()=>{qualityRow.style.display=format.value==='image/png'?'none':'block'});
    quality.addEventListener('input',()=>{qualityVal.textContent=quality.value});
    convertBtn.addEventListener('click',()=>{if(!img)return;const c=document.createElement('canvas');c.width=img.width;c.height=img.height;c.getContext('2d')!.drawImage(img,0,0);const mime=format.value;const q=mime==='image/png'?undefined:parseInt(quality.value)/100;const ext=mime.split('/')[1];c.toBlob(b=>{if(!b)return;const a=document.createElement('a');a.href=URL.createObjectURL(b);a.download='converted.'+ext;a.click()},mime,q)});
  </script>
</ToolLayout>
