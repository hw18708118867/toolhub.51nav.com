---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import StatusMessage from '../../../components/StatusMessage.astro'
import { tools } from '../../../data/tools'

const tool = tools.find(t => t.id === 'json-compare')!

const steps = [
  { name: 'Paste Both JSONs', text: 'Paste the first JSON in the left panel and the second JSON in the right panel. Both must be valid JSON.' },
  { name: 'Choose Comparison Mode', text: 'Click "Deep Compare" to check if the two JSON objects are structurally equal (ignoring key order). Click "Show Diff" to see the key-by-key differences.' },
  { name: 'Review Results', text: 'For Compare mode: a green success message if they match, or the first difference found. For Diff mode: a structured breakdown of keys only in left, only in right, and values that differ.' },
]

const faq = [
  { question: 'What\'s the difference between Compare and Diff?', answer: 'Compare (deep equality) tells you whether two JSON objects are semantically identical — same keys, same values, same structure — regardless of key order. Diff goes further and lists every key that appears in only one object or has a different value between the two. Use Compare for a quick yes/no, use Diff to understand exactly what changed.' },
  { question: 'Does key order affect the comparison?', answer: 'No. The deep compare ignores key ordering — {"a":1,"b":2} and {"b":2,"a":1} are considered equal. This matches how JSON is defined in the spec, where objects are unordered collections.' },
  { question: 'How are arrays compared?', answer: 'Arrays are compared element-by-element in order. [1, 2, 3] is different from [3, 2, 1]. Nested arrays and objects are compared recursively. If you need to compare arrays regardless of element order, sort them first using the JSON Sort tool.' },
]
---

<ToolLayout
  tool={tool}
  description="Compare two JSON objects for deep equality or find differences. Checks structural equality ignoring key order. All processing happens locally in your browser." {steps} {faq}
>
  <div class="flex flex-wrap gap-3 mb-6">
    <button id="compareBtn" class="btn btn-primary">Deep Compare</button>
    <button id="diffBtn" class="btn btn-secondary">Show Diff</button>
    <button id="sampleBtn" class="btn btn-secondary">Load Sample</button>
    <button id="clearBtn" class="btn btn-secondary">Clear All</button>
  </div>

  <div class="grid lg:grid-cols-2 gap-6 mb-6">
    <div class="code-panel">
      <div class="code-panel-header">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400">JSON A (Original)</span>
        <button id="copyLeftBtn" class="btn btn-sm btn-secondary">Copy</button>
      </div>
      <textarea id="leftInput" class="code-input" placeholder="Paste first JSON here..."></textarea>
    </div>
    <div class="code-panel">
      <div class="code-panel-header">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400">JSON B (Modified)</span>
        <button id="copyRightBtn" class="btn btn-sm btn-secondary">Copy</button>
      </div>
      <textarea id="rightInput" class="code-input" placeholder="Paste second JSON here..."></textarea>
    </div>
  </div>

  <div class="code-panel">
    <div class="code-panel-header">
      <span class="text-sm font-medium text-gray-500 dark:text-gray-400">Result</span>
      <button id="copyResultBtn" class="btn btn-sm btn-secondary">Copy</button>
    </div>
    <pre id="resultEl" class="code-output"></pre>
  </div>
  <StatusMessage id="statusEl" />

  <section slot="examples" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Examples</h2>
    <div class="grid lg:grid-cols-3 gap-6 mb-6">
      <div>
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 dark:text-gray-400">JSON A</h3>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>&#123;"name":"DevTools","version":"1.0","settings":&#123;"theme":"dark"&#125;&#125;</code></pre>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 dark:text-gray-400">JSON B</h3>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>&#123;"version":"1.0","name":"DevTools","settings":&#123;"theme":"light"&#125;&#125;</code></pre>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-green-600 uppercase tracking-wider mb-3">Diff Result</h3>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>✗ settings.theme:
  A: "dark"
  B: "light"</code></pre>
      </div>
    </div>
  </section>

  <section slot="tutorial" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Useful for API Testing and Config Management</h2>
    <div class="prose prose-gray max-w-none dark:prose-invert">
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">
        Comparing JSON is a daily task if you work with APIs. You deploy a change and need to verify the API response hasn't changed unexpectedly; you migrate from one service to another and need to confirm the output is equivalent; you update a config file and want to see exactly what keys you touched.
      </p>
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">
        The deep compare is useful for automated testing scenarios — for example, checking that your staging API returns the same data structure as production, even if key ordering differs between environments.
      </p>
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">
        Diff mode helps with code review: when someone updates a JSON config file, paste the old and new versions here to see exactly which keys were added, removed, or changed — without scanning through lines manually.
      </p>
    </div>
  </section>

  <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-2xl">
      <a href="/guides/json-comparison-guide/" class="group"><div class="bg-white border border-gray-200 rounded-xl p-5 flex gap-4 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-1 dark:text-white">JSON Comparison Guide</h4><p class="text-xs text-gray-500 mt-1 dark:text-gray-400">Deep equality, semantic diff, and key sorting strategies.</p></div></div></a>
      <a href="/guides/json-structure-guide/" class="group"><div class="bg-white border border-gray-200 rounded-xl p-5 flex gap-4 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-1 dark:text-white">JSON Structure Guide</h4><p class="text-xs text-gray-500 mt-1 dark:text-gray-400">Flattening, tree views, and working with nested JSON.</p></div></div></a>
    </div>
  </section>

  <script>
    import { copyToClipboard } from '../../../utils/copyToClipboard'

    const leftInput = document.getElementById('leftInput') as HTMLTextAreaElement
    const rightInput = document.getElementById('rightInput') as HTMLTextAreaElement
    const resultEl = document.getElementById('resultEl')!

    function showStatus(msg: string, type: 'success' | 'error') {
      const el = document.getElementById('statusEl')!
      el.textContent = msg; el.classList.remove('hidden')
      el.className = type === 'success' ? 'mt-4 px-4 py-3 rounded-lg bg-green-900/40 border border-green-800 text-green-400' : 'mt-4 px-4 py-3 rounded-lg bg-red-900/40 border border-red-800 text-red-400'
      setTimeout(() => el.classList.add('hidden'), 3000)
    }

    function deepEqual(a: any, b: any): boolean {
      if (a === b) return true
      if (typeof a !== typeof b) return false
      if (a === null || b === null) return a === b
      if (Array.isArray(a) && Array.isArray(b)) {
        if (a.length !== b.length) return false
        return a.every((v, i) => deepEqual(v, b[i]))
      }
      if (typeof a === 'object' && typeof b === 'object') {
        const ka = Object.keys(a).sort(), kb = Object.keys(b).sort()
        if (ka.length !== kb.length) return false
        if (!deepEqual(ka, kb)) return false
        return ka.every(k => deepEqual(a[k], b[k]))
      }
      return false
    }

    function diffObjects(a: any, b: any, path = ''): string[] {
      const lines: string[] = []
      if (a === b) return lines
      if (typeof a !== typeof b) { lines.push(`Type mismatch at ${path || '(root)'}: ${typeof a} vs ${typeof b}`); return lines }
      if (a === null || b === null) { lines.push(`${path || '(root)'}: ${JSON.stringify(a)} vs ${JSON.stringify(b)}`); return lines }
      if (Array.isArray(a) && Array.isArray(b)) {
        const max = Math.max(a.length, b.length)
        for (let i = 0; i < max; i++) {
          if (i >= a.length) { lines.push(`+ ${path}[${i}]: ${JSON.stringify(b[i])}`); continue }
          if (i >= b.length) { lines.push(`- ${path}[${i}]: ${JSON.stringify(a[i])}`); continue }
          lines.push(...diffObjects(a[i], b[i], `${path}[${i}]`))
        }
        return lines
      }
      if (typeof a === 'object') {
        const allKeys = new Set([...Object.keys(a), ...Object.keys(b)])
        allKeys.forEach(k => {
          const np = path ? `${path}.${k}` : k
          if (!(k in a)) { lines.push(`+ ${np}: ${JSON.stringify(b[k])}`) }
          else if (!(k in b)) { lines.push(`- ${np}: ${JSON.stringify(a[k])}`) }
          else { lines.push(...diffObjects(a[k], b[k], np)) }
        })
        return lines
      }
      lines.push(`${path || '(root)'}: ${JSON.stringify(a)} → ${JSON.stringify(b)}`)
      return lines
    }

    document.getElementById('compareBtn')!.addEventListener('click', () => {
      const la = leftInput.value.trim(), ra = rightInput.value.trim()
      if (!la || !ra) { showStatus('Paste JSON in both panels', 'error'); return }
      try {
        const a = JSON.parse(la), b = JSON.parse(ra)
        if (deepEqual(a, b)) {
          resultEl.textContent = '✓ The two JSON objects are structurally equal.'
          resultEl.className = 'code-output text-green-600 dark:text-green-400'
          showStatus('They match!', 'success')
        } else {
          resultEl.textContent = '✗ The two JSON objects are different. Use "Show Diff" to see details.'
          resultEl.className = 'code-output text-red-500 dark:text-red-400'
          showStatus('They are different', 'error')
        }
      } catch (e) { showStatus('Invalid JSON: ' + (e as Error).message, 'error') }
    })

    document.getElementById('diffBtn')!.addEventListener('click', () => {
      const la = leftInput.value.trim(), ra = rightInput.value.trim()
      if (!la || !ra) { showStatus('Paste JSON in both panels', 'error'); return }
      try {
        const a = JSON.parse(la), b = JSON.parse(ra)
        const diffs = diffObjects(a, b)
        if (diffs.length === 0) {
          resultEl.textContent = '✓ No differences — the two JSON objects are identical.'
          resultEl.className = 'code-output text-green-600 dark:text-green-400'
          showStatus('No differences found', 'success')
        } else {
          resultEl.textContent = diffs.join('\n')
          resultEl.className = 'code-output'
          showStatus(`${diffs.length} difference(s) found`, 'error')
        }
      } catch (e) { showStatus('Invalid JSON: ' + (e as Error).message, 'error') }
    })

    document.getElementById('sampleBtn')!.addEventListener('click', () => {
      leftInput.value = '{"name":"DevTools","version":"1.0","settings":{"theme":"dark","lang":"en"},"features":["format","minify"]}'
      rightInput.value = '{"name":"DevTools","version":"2.0","settings":{"theme":"light","lang":"en"},"features":["format","minify","validate"]}'
      resultEl.textContent = ''; resultEl.className = 'code-output'
    })

    document.getElementById('clearBtn')!.addEventListener('click', () => {
      leftInput.value = ''; rightInput.value = ''; resultEl.textContent = ''; resultEl.className = 'code-output'
    })

    document.getElementById('copyLeftBtn')!.addEventListener('click', async () => {
      const ok = await copyToClipboard(leftInput.value)
      showStatus(ok ? 'Copied!' : 'Copy failed', ok ? 'success' : 'error')
    })
    document.getElementById('copyRightBtn')!.addEventListener('click', async () => {
      const ok = await copyToClipboard(rightInput.value)
      showStatus(ok ? 'Copied!' : 'Copy failed', ok ? 'success' : 'error')
    })
    document.getElementById('copyResultBtn')!.addEventListener('click', async () => {
      const ok = await copyToClipboard(resultEl.textContent || '')
      showStatus(ok ? 'Copied!' : 'Copy failed', ok ? 'success' : 'error')
    })
  </script>
</ToolLayout>
