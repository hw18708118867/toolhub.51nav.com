---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'tailwind-color-generator')!
const steps = [
  { name: 'Enter a Base Color', text: 'Type a HEX color code (like #3b82f6) as the base shade (typically 500). The tool generates a full 50-950 palette — 11 shades from lightest (50) to darkest (950).' },
  { name: 'Review the Generated Palette', text: 'The tool generates all 11 Tailwind shades automatically. Each shade is calculated by adjusting lightness from the base color. The palette follows Tailwind\'s consistent lightness curve.' },
  { name: 'Copy the Config', text: 'Copy the generated palette as a Tailwind config object. Paste it into tailwind.config.js under theme.extend.colors. The palette is ready to use as bg-custom-500, text-custom-700, etc.' },
]
const faq = [
  { question: 'How does the generator create shades?', answer: 'The generator starts from your base color (usually the 500 shade) and adjusts lightness to produce 10 additional shades. Lighter shades (50-400) increase lightness and slightly reduce saturation. Darker shades (600-950) decrease lightness. The specific lightness values match Tailwind\'s built-in color scales, which were designed for consistent visual rhythm — the jump from 500 to 600 feels the same as from 600 to 700.' },
  { question: 'Can I customize individual shades?', answer: 'The generator produces a mathematically consistent palette. If you need to tweak individual shades (e.g., making the 100 shade warmer), copy the generated config and manually adjust the specific HEX values. The generated palette is a starting point that follows Tailwind conventions, not a final design decision.' },
  { question: 'How do I use this in my Tailwind project?', answer: 'Copy the generated config and add it to tailwind.config.js: theme: { extend: { colors: { brand: { 50: \'#...\', 100: \'#...\', ... 950: \'#...\' } } } }. Then use in HTML: class="bg-brand-500 text-brand-100". The color name (brand, primary, accent) is up to you — change the key in the config object.' },
]
---
<ToolLayout tool={tool} description="Free Tailwind CSS color palette generator. Generate full 50-950 shade palettes from any base color. Copy-ready config for tailwind.config.js. All processing is local and private." {steps} {faq}>
  <div class="mb-6"><div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Base Color (500 shade)</span></div><div class="p-4 flex gap-4 items-center"><input type="color" id="colorPicker" value="#3b82f6" class="w-12 h-12 rounded cursor-pointer border-0"><input type="text" id="hexInput" class="flex-1 bg-white border border-gray-200 text-gray-900 rounded-lg px-4 py-3 text-sm font-mono dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100" value="#3b82f6" placeholder="#3b82f6"><button id="generateBtn" class="btn btn-primary">Generate Palette</button></div></div></div>
  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6" id="paletteGrid"></div>
  <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Tailwind Config</span><button id="copyConfigBtn" class="btn btn-sm btn-secondary ml-auto">Copy</button></div><pre id="configOutput" class="code-output text-sm">Click "Generate Palette" to create a color scale.</pre></div>
  <section slot="examples" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Generated Palette Example</h2><div class="bg-gray-50 border border-gray-200 rounded-xl p-4 font-mono text-sm text-gray-700 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>colors: {'{'}<br/>  primary: {'{'}<br/>    50: '#eff6ff',<br/>    100: '#dbeafe',<br/>    ...<br/>    500: '#3b82f6',<br/>    ...<br/>    950: '#172554'<br/>  {'}'}<br/>{'}'}</code></div></section>
  <section slot="relatedArticles" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2><div class="space-y-3">
      <a href="/guides/color-tools-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Color Tools Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Convert, generate and check colors for the web.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/color-converter/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Color Converter</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Convert between HEX, RGB, HSL and CMYK.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/color-palette/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Color Palette Generator</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Generate harmonious color palettes.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
  </div></section>
  <script>
    const colorPicker=document.getElementById('colorPicker') as HTMLInputElement,hexInput=document.getElementById('hexInput') as HTMLInputElement,generateBtn=document.getElementById('generateBtn')!,paletteGrid=document.getElementById('paletteGrid')!,configOutput=document.getElementById('configOutput')!,copyConfigBtn=document.getElementById('copyConfigBtn')!;
    const shadeNames=['50','100','200','300','400','500','600','700','800','900','950'];
    function hexToHsl(h:string):[number,number,number]{const r=parseInt(h.slice(1,3),16)/255,g=parseInt(h.slice(3,5),16)/255,b=parseInt(h.slice(5,7),16)/255;const max=Math.max(r,g,b),min=Math.min(r,g,b);let hue=0;const l=(max+min)/2;if(max!==min){const d=max-min,s=l>.5?d/(2-max-min):d/(max+min);if(max===r)hue=((g-b)/d+(g<b?6:0))*60;else if(max===g)hue=((b-r)/d+2)*60;else hue=((r-g)/d+4)*60;return[Math.round(hue),Math.round(s*100),Math.round(l*100)]}return[0,0,Math.round(l*100)]}
    function hslToHex(h:number,s:number,l:number):string{s/=100;l/=100;const c=(1-Math.abs(2*l-1))*s,x=c*(1-Math.abs((h/60)%2-1)),m=l-c/2;let r=0,g=0,b=0;if(h<60){r=c;g=x}else if(h<120){r=x;g=c}else if(h<180){g=c;b=x}else if(h<240){g=x;b=c}else if(h<300){r=x;b=c}else{r=c;b=x}return'#'+[r,g,b].map(v=>Math.round((v+m)*255).toString(16).padStart(2,'0')).join('')}
    const targetLightness=[95,90,82,70,58,45,37,28,20,12,6];
    function generate(){
      const baseHex=hexInput.value;if(!/^#[a-f\d]{6}$/i.test(baseHex))return;
      const [h,s]=hexToHsl(baseHex);
      let html='',config='colors: {\n  custom: {\n';
      shadeNames.forEach((name,i)=>{
        const tl=targetLightness[i],ss=Math.min(100,s*(i===0?0.3:(i<=4?0.6+(i*0.1):1))+(i>=6?(10-i)*2:0));
        const hex=hslToHex(h,Math.round(ss),tl),isBase=i===5;
        html+=`<div class="code-panel"><div class="flex items-center gap-3 p-3"><div class="w-10 h-10 rounded-lg flex-shrink-0 ${isBase?'ring-2 ring-blue-500 ring-offset-2':''}" style="background:${hex}"></div><div class="text-sm"><div class="font-semibold text-gray-900 dark:text-white">${name}${isBase?' (base)':''}</div><div class="text-xs text-gray-400 font-mono">${hex}</div></div></div></div>`;
        config+=`    ${name}: '${hex}',\n`;
      });
      config+='  }\n}';
      paletteGrid.innerHTML=html;configOutput.textContent=config;
    }
    colorPicker.addEventListener('input',()=>{hexInput.value=colorPicker.value;generate()});
    hexInput.addEventListener('input',()=>{if(/^#[a-f\d]{6}$/i.test(hexInput.value)){colorPicker.value=hexInput.value;generate()}});
    generateBtn.addEventListener('click',generate);
    copyConfigBtn.addEventListener('click',()=>navigator.clipboard.writeText(configOutput.textContent||''));
    generate();
  </script>
</ToolLayout>
