---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import StatusMessage from '../../../components/StatusMessage.astro'
import { tools } from '../../../data/tools'

const tool = tools.find(t => t.id === 'json-escape')!

const steps = [
  { name: 'Paste Your JSON String', text: 'Paste the JSON string you need to escape or unescape into the input area. This could be a string you want to embed inside another JSON document or code.' },
  { name: 'Choose Direction', text: 'Click "Escape" to convert special characters like quotes and newlines into their escape sequences. Click "Unescape" to convert escape sequences back to literal characters.' },
  { name: 'Copy the Result', text: 'The processed output appears on the right. Click the Copy button to copy it to your clipboard.' },
]

const faq = [
  { question: 'When do I need to escape a JSON string?', answer: 'You need to escape a string when embedding it as a value inside another JSON document. For example, if you have a JSON string that contains double quotes, you need to escape them so the outer JSON parser doesn\'t get confused about where the string ends.' },
  { question: 'What characters get escaped?', answer: 'The main characters escaped are double quotes (" → \\"), backslashes (\\ → \\\\), newlines (→ \\n), tabs (→ \\t), carriage returns (→ \\r), and other control characters. Forward slashes can optionally be escaped but it\'s rarely needed.' },
  { question: 'Is this the same as URL encoding?', answer: 'No. URL encoding (%20, %2F, etc.) is for URLs. JSON escaping uses backslash sequences (\\n, \\", etc.) and is specifically for embedding strings in JSON format. These are two completely different systems for different purposes.' },
]
---

<ToolLayout
  tool={tool}
  description="Free online JSON Escape/Unescape tool. Escape special characters in JSON strings or convert escape sequences back to literal characters. Works entirely in your browser." {steps} {faq}
>
  <div class="flex flex-wrap gap-3 mb-6">
    <button id="escapeBtn" class="btn btn-primary">Escape</button>
    <button id="unescapeBtn" class="btn btn-secondary">Unescape</button>
    <button id="sampleBtn" class="btn btn-secondary">Load Sample</button>
    <button id="clearBtn" class="btn btn-secondary">Clear</button>
  </div>

  <div class="grid lg:grid-cols-2 gap-6">
    <div class="code-panel">
      <div class="code-panel-header">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400">Input</span>
        <button id="copyInputBtn" class="btn btn-sm btn-secondary">Copy</button>
      </div>
      <textarea id="inputEl" class="code-input" placeholder="Paste a JSON string to escape or unescape..."></textarea>
    </div>
    <div class="code-panel">
      <div class="code-panel-header">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400">Output</span>
        <button id="copyOutputBtn" class="btn btn-sm btn-secondary">Copy</button>
      </div>
      <pre id="outputEl" class="code-output"></pre>
    </div>
  </div>
  <StatusMessage id="statusEl" />

  <section slot="examples" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Examples</h2>
    <div class="grid lg:grid-cols-2 gap-6 mb-6">
      <div>
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 dark:text-gray-400">Before (Unescaped)</h3>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>He said "Hello World"
Line one
Line two</code></pre>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-green-600 uppercase tracking-wider mb-3">After (Escaped)</h3>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>He said \"Hello World\"\nLine one\nLine two</code></pre>
      </div>
    </div>
    <div class="grid lg:grid-cols-2 gap-6">
      <div>
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 dark:text-gray-400">Before (Escaped)</h3>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>&#123;\"name\":\"John\",\"city\":\"New\nYork\"&#125;</code></pre>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-green-600 uppercase tracking-wider mb-3">After (Unescaped)</h3>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>&#123;"name":"John","city":"New
York"&#125;</code></pre>
      </div>
    </div>
  </section>

  <section slot="tutorial" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">When JSON Escaping Matters</h2>
    <div class="prose prose-gray max-w-none dark:prose-invert">
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">
        JSON escaping trips up developers most often when they're building JSON strings by hand — concatenating strings in code instead of using a proper serialization library. If you've ever gotten a <code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">SyntaxError: Unexpected token</code> from <code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">JSON.parse()</code>, unescaped characters are one of the first things to check.
      </p>
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">
        A common scenario: you're storing a JSON snippet as a string value inside another JSON object. The inner JSON's double quotes need to be escaped so the outer parser treats them as literal characters, not as string delimiters. Without escaping, the parser sees the first inner quote and thinks the outer string ended.
      </p>
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">
        Another case is embedding JSON in HTML <code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">&lt;script&gt;</code> tags. If your JSON contains <code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">&lt;/script&gt;</code> as a string, the browser's HTML parser will close the script tag prematurely. The fix is to escape the <code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">/</code> as <code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">\/</code>.
      </p>
    </div>
  </section>

  <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="space-y-3">
      <a href="/guides/json-escaping-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">JSON Escaping Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">When and how to escape JSON strings correctly.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
      <a href="/guides/json-debugging-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">JSON Debugging Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Fix and prevent common JSON syntax errors.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    </div>
  </section>

  <script>
    import { copyToClipboard } from '../../../utils/copyToClipboard'

    const inputEl = document.getElementById('inputEl') as HTMLTextAreaElement
    const outputEl = document.getElementById('outputEl')!

    function showStatus(msg: string, type: 'success' | 'error') {
      const el = document.getElementById('statusEl')!
      el.textContent = msg; el.classList.remove('hidden')
      el.className = type === 'success' ? 'mt-4 px-4 py-3 rounded-lg bg-green-900/40 border border-green-800 text-green-400' : 'mt-4 px-4 py-3 rounded-lg bg-red-900/40 border border-red-800 text-red-400'
      setTimeout(() => el.classList.add('hidden'), 3000)
    }

    function escapeJson(str: string): string {
      return str.replace(/\\/g, '\\\\').replace(/"/g, '\\"').replace(/\n/g, '\\n').replace(/\r/g, '\\r').replace(/\t/g, '\\t').replace(/[\b]/g, '\\b').replace(/\f/g, '\\f')
    }

    function unescapeJson(str: string): string {
      return str.replace(/\\n/g, '\n').replace(/\\r/g, '\r').replace(/\\t/g, '\t').replace(/\\b/g, '\b').replace(/\\f/g, '\f').replace(/\\"/g, '"').replace(/\\\\/g, '\\')
    }

    document.getElementById('escapeBtn')!.addEventListener('click', () => {
      const v = inputEl.value
      if (!v.trim()) { showStatus('Enter text to escape first', 'error'); return }
      outputEl.textContent = escapeJson(v)
      showStatus('Escaped!', 'success')
    })

    document.getElementById('unescapeBtn')!.addEventListener('click', () => {
      const v = inputEl.value
      if (!v.trim()) { showStatus('Enter text to unescape first', 'error'); return }
      outputEl.textContent = unescapeJson(v)
      showStatus('Unescaped!', 'success')
    })

    document.getElementById('sampleBtn')!.addEventListener('click', () => {
      inputEl.value = 'He said "hello" to me\nFile is at C:\\Users\\john\\documents'
      outputEl.textContent = ''
    })

    document.getElementById('clearBtn')!.addEventListener('click', () => { inputEl.value = ''; outputEl.textContent = '' })

    document.getElementById('copyInputBtn')!.addEventListener('click', async () => {
      const ok = await copyToClipboard(inputEl.value)
      showStatus(ok ? 'Copied!' : 'Copy failed', ok ? 'success' : 'error')
    })
    document.getElementById('copyOutputBtn')!.addEventListener('click', async () => {
      const ok = await copyToClipboard(outputEl.textContent || '')
      showStatus(ok ? 'Copied!' : 'Copy failed', ok ? 'success' : 'error')
    })
  </script>
</ToolLayout>
