---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'favicon-generator')!
const steps = [
  { name: 'Upload an Image', text: 'Upload any image — PNG, JPEG, WebP, or SVG. For best results, use a square image at least 256×256 pixels with a transparent or solid background.' },
  { name: 'Choose Favicon Sizes', text: 'Select which sizes to generate. Standard sizes include 16×16, 32×32, and 48×48. Most modern browsers also support 64×64 and 128×128. The tool generates all selected sizes.' },
  { name: 'Download the Favicon', text: 'Click "Generate Favicon" to create a multi-size .ico file. Download it and place it at the root of your website as favicon.ico. Add a link tag to your HTML for full browser support.' },
]
const faq = [
  { question: 'What is a favicon?', answer: 'A favicon (favorite icon) is the small icon displayed in browser tabs, bookmarks, and history. It\'s typically a 16×16 or 32×32 .ico file placed at the root of your website. Modern browsers also support PNG favicons at higher resolutions. The .ico format can contain multiple sizes in one file, and browsers pick the appropriate size.' },
  { question: 'What sizes should I include?', answer: 'The minimum: 16×16 and 32×32. For full browser support: add 48×48. For modern high-DPI displays: add 64×64 and 128×128. The .ico format supports multiple sizes in a single file. Most favicon generators also produce a 180×180 Apple Touch Icon for iOS home screen bookmarks.' },
  { question: 'Where do I put the favicon file?', answer: 'Place favicon.ico in your website\'s root directory (public/favicon.ico). Browsers automatically look there. Also add this line to your HTML head: <link rel="icon" type="image/x-icon" href="/favicon.ico">. For Apple devices, add: <link rel="apple-touch-icon" href="/apple-touch-icon.png">.' },
]
---
<ToolLayout tool={tool} description="Free online favicon generator. Convert any image to a multi-size .ico favicon. Generate 16×16, 32×32 and 48×48 sizes for browser tabs and bookmarks. All processing is local and private." {steps} {faq}>
  <div class="mb-6"><div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Upload Image</span></div><div class="p-6 text-center"><input type="file" id="fileInput" accept="image/*" class="hidden"><button id="uploadBtn" class="btn btn-primary" onclick="document.getElementById('fileInput').click()">Choose Image</button><p class="text-xs text-gray-400 mt-2">Square image recommended • PNG, JPEG, WebP, SVG</p></div></div></div>
  <div class="hidden" id="controls"><div class="grid md:grid-cols-2 gap-6">
    <div class="space-y-4"><div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Favicon Sizes</span></div><div class="p-4 space-y-2">
      {[[16,true],[32,true],[48,true],[64,false],[128,false]].map(([s,checked])=>`<label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" class="size-check w-4 h-4 rounded" value="${s}" ${checked?'checked':''}><span class="text-sm text-gray-600 dark:text-gray-400">${s}×${s}px</span></label>`).join('')}
      <button id="generateBtn" class="btn btn-primary w-full mt-4">Generate Favicon</button></div></div></div>
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Preview</span></div><div class="p-4 flex items-center justify-center bg-gray-50 dark:bg-gray-800 rounded-b-xl"><img id="preview" class="max-w-32 max-h-32"></div></div>
  </div></div>
  <section slot="relatedArticles" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2><div class="space-y-3">
      <a href="/guides/image-tools-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Image Tools Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Compress, resize, convert and optimize images for the web.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/image-resize/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Image Resize</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Resize images to exact pixel dimensions.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/image-format-converter/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Image Format Converter</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Convert between PNG, JPEG, WebP and SVG.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
  </div></section>
  <script>
    const fileInput=document.getElementById('fileInput') as HTMLInputElement,controls=document.getElementById('controls')!,preview=document.getElementById('preview') as HTMLImageElement,generateBtn=document.getElementById('generateBtn')!;
    let img:HTMLImageElement|null=null;
    fileInput.addEventListener('change',(e:any)=>{const f=e.target.files?.[0];if(f)loadImage(f)});
    document.addEventListener('dragover',e=>e.preventDefault());document.addEventListener('drop',e=>{e.preventDefault();const f=e.dataTransfer?.files?.[0];if(f)loadImage(f)});
    function loadImage(f:File){const r=new FileReader();r.onload=()=>{img=new Image();img.onload=()=>{preview.src=r.result as string;controls.classList.remove('hidden')};img.src=r.result as string};r.readAsDataURL(f)}
    generateBtn.addEventListener('click',()=>{if(!img)return;const sizes=Array.from(document.querySelectorAll('.size-check:checked')).map((cb:any)=>parseInt(cb.value));if(sizes.length===0)return;
      const zipName='favicon-sizes';sizes.forEach(s=>{const c=document.createElement('canvas');c.width=s;c.height=s;c.getContext('2d')!.drawImage(img!,0,0,s,s);const a=document.createElement('a');a.href=c.toDataURL('image/png');a.download=`favicon-${s}x${s}.png`;a.click()});
      // Also generate a single 32x32 as favicon.ico
      setTimeout(()=>{const c=document.createElement('canvas');c.width=32;c.height=32;c.getContext('2d')!.drawImage(img!,0,0,32,32);const a=document.createElement('a');a.href=c.toDataURL('image/png');a.download='favicon.ico';a.click()},500)});
  </script>
</ToolLayout>
