---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'crc32-hash')!
const steps = [
  { name: 'Enter Your Text', text: 'Type or paste any text into the input field. The tool accepts any string — file paths, data strings, identifiers, or arbitrary text.' },
  { name: 'Generate the CRC32 Hash', text: 'The CRC32 checksum is computed instantly as you type. Results are shown in both hexadecimal (8 chars) and decimal format.' },
  { name: 'Copy the Result', text: 'Click the copy button to copy the CRC32 value. Use it for data integrity checks, checksum verification, or error detection in file transfers.' },
]
const faq = [
  { question: 'What is CRC32?', answer: 'CRC32 (Cyclic Redundancy Check) is a 32-bit checksum algorithm that detects accidental changes to data. It\'s widely used in network protocols (Ethernet, ZIP files, PNG images) for error detection. CRC32 produces a 8-character hex value like "a1b2c3d4". Unlike cryptographic hashes (SHA-256, MD5), CRC32 is designed for error detection, not security — it\'s fast but easy to forge.' },
  { question: 'When should I use CRC32 vs SHA-256?', answer: 'Use CRC32 for non-security checks: verifying file integrity after network transfer, checking data wasn\'t corrupted, implementing hash tables with low collision rate. Use SHA-256 when security matters: password storage, digital signatures, data authentication. CRC32 runs much faster but offers zero cryptographic protection. For cryptographic hashing, use our Hash Generator instead.' },
]
---
<ToolLayout tool={tool} description="Free online CRC32 hash generator. Generate CRC32 checksums from text instantly. Hex and decimal output. Useful for data integrity and checksum verification. All processing is local and private." {steps} {faq}>
  <div class="code-panel mb-6"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Input Text</span></div><textarea id="input" class="code-input" placeholder="Enter text to hash..."></textarea></div>
  <div class="grid sm:grid-cols-2 gap-4 mb-6">
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">CRC32 (Hex)</span><button id="copyHex" class="btn btn-sm btn-secondary ml-auto">Copy</button></div><pre id="hexOut" class="code-output text-center text-lg font-mono">—</pre></div>
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">CRC32 (Decimal)</span></div><pre id="decOut" class="code-output text-center text-lg font-mono">—</pre></div>
  </div>
  <section slot="relatedArticles" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2><div class="space-y-3">
      <a href="/guides/crypto-tools-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Crypto Tools Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Hashing, HMAC, encryption and password security.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/hash-generator/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Hash Generator</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">MD5, SHA-1, SHA-256, SHA-512 hashing.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
  </div></section>
  <script>
    const input=document.getElementById('input') as HTMLTextAreaElement,hexOut=document.getElementById('hexOut')!,decOut=document.getElementById('decOut')!,copyHex=document.getElementById('copyHex')!;
    // CRC32 table
    const table=new Uint32Array(256);
    for(let i=0;i<256;i++){let c=i;for(let j=0;j<8;j++)c=c&1?0xEDB88320^(c>>>1):c>>>1;table[i]=c}
    function crc32(str:string):number{let crc=0xFFFFFFFF;for(let i=0;i<str.length;i++)crc=table[(crc^str.charCodeAt(i))&0xFF]^(crc>>>8);return(crc^0xFFFFFFFF)>>>0}
    input.addEventListener('input',()=>{const v=input.value;if(!v){hexOut.textContent='—';decOut.textContent='—';return}const h=crc32(v);hexOut.textContent=h.toString(16).padStart(8,'0');decOut.textContent=h.toString()})
    copyHex.addEventListener('click',()=>navigator.clipboard.writeText(hexOut.textContent||''))
  </script>
</ToolLayout>
