---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'aes-encrypt')!
const steps = [
  { name: 'Enter Text & Key', text: 'Type the text you want to encrypt and a secret key/password. The key should be at least 16 characters for AES-256 security. Keep the key safe — without it, decryption is impossible.' },
  { name: 'Encrypt or Decrypt', text: 'Click "Encrypt" to convert your text into a secure encrypted format. Click "Decrypt" with the correct key to recover the original text. Use the same key for both operations.' },
  { name: 'Copy the Result', text: 'The encrypted output is base64-encoded ciphertext. Copy it for storage or transmission. Only someone with the correct key can decrypt it back to the original text.' },
]
const faq = [
  { question: 'What is AES encryption?', answer: 'AES (Advanced Encryption Standard) is the most widely used symmetric encryption algorithm. It was established by NIST in 2001 and is used worldwide to protect classified information, secure web traffic (TLS), encrypt files, and protect databases. AES uses the same key for encryption and decryption — symmetric encryption. Our tool uses AES-GCM mode with 256-bit keys derived from your password via PBKDF2.' },
  { question: 'Is browser-based encryption secure?', answer: 'Our tool uses the Web Crypto API (crypto.subtle), which provides native, hardware-accelerated AES encryption in the browser. The encryption itself is cryptographically sound. However, browser-based encryption has inherent risks: your key is in memory, the page could be compromised by XSS, and browser extensions could intercept data. For truly sensitive data, use a dedicated encryption application, not a web tool.' },
  { question: 'What is the difference between AES-128, AES-192, and AES-256?', answer: 'The number refers to key length in bits. AES-256 uses a 256-bit key (32 bytes), providing the highest security. AES-128 is theoretically breakable by quantum computers in the distant future; AES-256 is considered quantum-resistant. Our tool uses AES-256-GCM. The "GCM" mode provides both encryption and authentication — it detects if ciphertext has been tampered with.' },
]
---
<ToolLayout tool={tool} description="Free online AES encrypt/decrypt tool. Secure text with AES-256-GCM encryption. Uses Web Crypto API for native browser encryption. All processing is local and private." {steps} {faq}>
  <div class="mb-6 space-y-4">
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Text</span></div><textarea id="text" class="code-input" placeholder="Enter text to encrypt or decrypt..."></textarea></div>
    <div><label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Secret Key</label><input type="password" id="key" class="w-full bg-white border border-gray-200 text-gray-900 rounded-lg px-4 py-3 text-sm dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100" placeholder="Enter encryption key..."></div>
  </div>
  <div class="flex gap-3 mb-6"><button id="encryptBtn" class="btn btn-primary">Encrypt</button><button id="decryptBtn" class="btn btn-secondary">Decrypt</button></div>
  <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Output</span><button id="copyBtn" class="btn btn-sm btn-secondary ml-auto">Copy</button></div><pre id="output" class="code-output">Enter text and a key, then click Encrypt or Decrypt.</pre></div>
  <section slot="relatedArticles" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2><div class="space-y-3">
      <a href="/guides/crypto-tools-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Crypto Tools Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Hashing, HMAC, encryption and password security.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/hash-generator/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Hash Generator</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">MD5, SHA-1, SHA-256, SHA-512.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/hmac-generator/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">HMAC Generator</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Generate HMAC with SHA-256 and SHA-512.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
  </div></section>
  <script>
    const text=document.getElementById('text') as HTMLTextAreaElement,key=document.getElementById('key') as HTMLInputElement,output=document.getElementById('output')!,encryptBtn=document.getElementById('encryptBtn')!,decryptBtn=document.getElementById('decryptBtn')!,copyBtn=document.getElementById('copyBtn')!;
    async function getKey(pw:string):Promise<CryptoKey>{const enc=new TextEncoder();const k=await crypto.subtle.importKey('raw',enc.encode(pw),'PBKDF2',false,['deriveKey']);return crypto.subtle.deriveKey({name:'PBKDF2',salt:enc.encode('aes-tool-salt'),iterations:100000,hash:'SHA-256'},k,{name:'AES-GCM',length:256},false,['encrypt','decrypt'])}
    encryptBtn.addEventListener('click',async()=>{if(!text.value||!key.value)return;try{const k=await getKey(key.value);const iv=crypto.getRandomValues(new Uint8Array(12));const enc=new TextEncoder();const ct=await crypto.subtle.encrypt({name:'AES-GCM',iv},k,enc.encode(text.value));const combined=new Uint8Array(iv.length+ct.byteLength);combined.set(iv);combined.set(new Uint8Array(ct),12);output.textContent=btoa(String.fromCharCode(...combined))}catch(e){output.textContent='Encryption failed. Check key and try again.'}})
    decryptBtn.addEventListener('click',async()=>{if(!text.value||!key.value)return;try{const k=await getKey(key.value);const data=Uint8Array.from(atob(text.value),c=>c.charCodeAt(0));const iv=data.slice(0,12);const ct=data.slice(12);const dec=new TextDecoder();const pt=await crypto.subtle.decrypt({name:'AES-GCM',iv},k,ct);output.textContent=dec.decode(pt)}catch(e){output.textContent='Decryption failed. Wrong key or invalid ciphertext.'}})
    copyBtn.addEventListener('click',()=>navigator.clipboard.writeText(output.textContent||''))
  </script>
</ToolLayout>
