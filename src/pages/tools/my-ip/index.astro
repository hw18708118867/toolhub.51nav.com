---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'my-ip')!
---
<ToolLayout tool={tool} description="Free My IP Address tool. See your public IP address, location, ISP, and browser information instantly. All processing is local.">
  <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Your IP Information</span></div><div class="p-4 space-y-3" id="ipInfo"><p class="text-gray-400">Loading...</p></div></div>
  <section slot="tutorial" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">About IP Addresses</h2><div class="text-gray-500 dark:text-gray-400 leading-relaxed space-y-3"><p>An IP (Internet Protocol) address is a unique identifier assigned to your device when it connects to the internet. Your public IP is the address visible to websites and services you visit. IPv4 addresses look like <code>192.168.1.1</code>, while IPv6 addresses look like <code>2001:0db8:85a3::8a2e:0370:7334</code>.</p><p>Your ISP assigns your public IP address. It can change over time unless you have a static IP. The IP address reveals your approximate geographic location (city/region level) and your Internet Service Provider.</p></div></section>
  <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="space-y-3">
      <a href="/guides/ip-addresses-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">IP Addresses & Geolocation</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">IPv4 vs IPv6, public vs private, geolocation accuracy.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    </div>
  </section>
  <script is:inline>
    async function getIpInfo() {
      var el = document.getElementById('ipInfo');
      try {
        var info = {};
        var rtc = new RTCPeerConnection({ iceServers: [{ urls: 'stun:stun.l.google.com:19302' }] });
        rtc.createDataChannel('');
        var offer = await rtc.createOffer();
        rtc.setLocalDescription(offer);
        var ip = await new Promise(function(resolve) {
          rtc.onicecandidate = function(e) { if (e.candidate) { var m = e.candidate.candidate.match(/(\d+\.\d+\.\d+\.\d+)/); if (m) resolve(m[1]); } };
          setTimeout(function() { resolve('Unable to detect'); }, 3000);
        });
        rtc.close();
        info['IP Address'] = ip;
        var ua = navigator.userAgent;
        info['Browser'] = ua.indexOf('Chrome') >= 0 ? 'Chrome' : ua.indexOf('Firefox') >= 0 ? 'Firefox' : ua.indexOf('Safari') >= 0 ? 'Safari' : 'Other';
        info['Platform'] = navigator.platform || 'Unknown';
        info['Language'] = navigator.language;
        info['Cookies'] = navigator.cookieEnabled ? 'Enabled' : 'Disabled';
        var keys = Object.keys(info);
        var html = '';
        for (var i = 0; i < keys.length; i++) {
          var k = keys[i];
          html += '<div class="flex justify-between bg-gray-50 rounded-lg p-3 dark:bg-gray-800"><span class="text-gray-500 dark:text-gray-400">' + k + '</span><span class="font-mono text-gray-900 dark:text-white">' + info[k] + '</span></div>';
        }
        el.innerHTML = html;
      } catch(e) {
        el.innerHTML = '<p class="text-red-400">Could not detect IP address. Check your network connection.</p>';
      }
    }
    getIpInfo();
  </script>
</ToolLayout>