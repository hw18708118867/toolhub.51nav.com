---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'image-crop')!
const steps = [
  { name: 'Upload an Image', text: 'Click or drag an image file. The tool loads it into an interactive canvas where you can draw a crop rectangle by clicking and dragging.' },
  { name: 'Select the Crop Area', text: 'Click and drag on the image to draw a crop rectangle. Resize by dragging the handles. The selected area is highlighted. You can redraw by clicking and dragging again.' },
  { name: 'Download the Cropped Image', text: 'Click "Crop & Download" to save only the selected area. The downloaded image is in PNG format at the cropped dimensions.' },
]
const faq = [
  { question: 'Can I crop to specific dimensions?', answer: 'This tool does free-form cropping. For exact pixel dimensions, use our Image Resize tool after cropping. The crop rectangle shows its dimensions as you draw. For precise crops (e.g., 1:1 square for social media), crop visually then resize to exact dimensions.' },
  { question: 'Does cropping affect image quality?', answer: 'No. Cropping only removes the outer portions of the image — it does not re-encode or compress the remaining area. The cropped output uses the original image quality. If you need to both crop and compress, use this tool first, then the Image Compressor.' },
]
---
<ToolLayout tool={tool} description="Free online image crop tool. Select and crop any area of an image with drag-to-select. Download the cropped result as PNG. All processing is local and private." {steps} {faq}>
  <div class="mb-6"><div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Upload Image</span></div><div class="p-6 text-center"><input type="file" id="fileInput" accept="image/*" class="hidden"><button id="uploadBtn" class="btn btn-primary" onclick="document.getElementById('fileInput').click()">Choose Image</button><p class="text-xs text-gray-400 mt-2">or drag and drop anywhere</p></div></div></div>
  <div class="hidden" id="editor"><div class="code-panel mb-4"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Crop Area (drag to select)</span><span id="cropDims" class="text-xs text-gray-400 ml-2"></span><button id="cropBtn" class="btn btn-sm btn-primary ml-auto">Crop & Download</button><button id="resetBtn" class="btn btn-sm btn-secondary ml-2">Reset</button></div><div class="relative bg-gray-100 dark:bg-gray-800 rounded-b-xl overflow-hidden" style="max-height:500px"><canvas id="canvas" class="max-w-full cursor-crosshair"></canvas></div></div></div>
  <section slot="relatedArticles" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2><div class="space-y-3">
      <a href="/guides/image-tools-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Image Tools Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Compress, resize, convert and optimize images for the web.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/image-resize/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Image Resize</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Resize images to exact pixel dimensions.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/image-compressor/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Image Compressor</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Compress JPEG, PNG and WebP images.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
  </div></section>
  <script>
    const fileInput=document.getElementById('fileInput') as HTMLInputElement,uploadBtn=document.getElementById('uploadBtn')!,editor=document.getElementById('editor')!,canvas=document.getElementById('canvas') as HTMLCanvasElement,cropBtn=document.getElementById('cropBtn')!,resetBtn=document.getElementById('resetBtn')!,cropDims=document.getElementById('cropDims')!;
    let img:HTMLImageElement|null=null,startX=0,startY=0,endX=0,endY=0,dragging=false;
    fileInput.addEventListener('change',(e:any)=>{const f=e.target.files?.[0];if(f)loadImage(f)});
    document.addEventListener('dragover',e=>e.preventDefault());document.addEventListener('drop',e=>{e.preventDefault();const f=e.dataTransfer?.files?.[0];if(f)loadImage(f)});
    function loadImage(f:File){const r=new FileReader();r.onload=()=>{img=new Image();img.onload=()=>{canvas.width=img!.width;canvas.height=img!.height;editor.classList.remove('hidden');draw()};img.src=r.result as string};r.readAsDataURL(f)}
    function draw(){if(!img)return;const ctx=canvas.getContext('2d')!;ctx.clearRect(0,0,canvas.width,canvas.height);ctx.drawImage(img,0,0);if(startX!==endX||startY!==endY){const x=Math.min(startX,endX),y=Math.min(startY,endY),w=Math.abs(endX-startX),h=Math.abs(endY-startY);ctx.fillStyle='rgba(0,0,0,0.4)';ctx.fillRect(0,0,canvas.width,y);ctx.fillRect(0,y,x,h);ctx.fillRect(x+w,y,canvas.width-x-w,h);ctx.fillRect(0,y+h,canvas.width,canvas.height-y-h);ctx.strokeStyle='#3b82f6';ctx.lineWidth=2;ctx.strokeRect(x,y,w,h);cropDims.textContent=`${Math.round(w)} × ${Math.round(h)}`}}
    canvas.addEventListener('mousedown',e=>{startX=e.offsetX;startY=e.offsetY;dragging=true});canvas.addEventListener('mousemove',e=>{if(!dragging)return;endX=e.offsetX;endY=e.offsetY;draw()});canvas.addEventListener('mouseup',()=>{dragging=false});canvas.addEventListener('mouseleave',()=>{dragging=false});
    cropBtn.addEventListener('click',()=>{if(!img)return;const x=Math.min(startX,endX),y=Math.min(startY,endY),w=Math.abs(endX-startX),h=Math.abs(endY-startY);if(w<5||h<5)return;const c=document.createElement('canvas');c.width=w;c.height=h;c.getContext('2d')!.drawImage(img,x,y,w,h,0,0,w,h);const a=document.createElement('a');a.href=c.toDataURL();a.download='cropped.png';a.click()});
    resetBtn.addEventListener('click',()=>{startX=0;startY=0;endX=0;endY=0;cropDims.textContent='';draw()});
  </script>
</ToolLayout>
