---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import StatusMessage from '../../../components/StatusMessage.astro'
import { tools } from '../../../data/tools'

const tool = tools.find(t => t.id === 'dedupe-lines')!

const steps = [
  { name: 'Paste Your Text', text: 'Paste the text with duplicate lines into the input panel. Each line is treated as a separate entry.' },
  { name: 'Choose an Action', text: 'Click "Remove Duplicates" to eliminate duplicate lines while preserving the order of first occurrence. Click "Sort Lines" to alphabetically sort all lines.' },
  { name: 'Copy the Result', text: 'The deduplicated or sorted text appears in the output panel. The status message shows how many duplicates were removed.' },
]

const faq = [
  { question: 'What is line deduplication?', answer: 'Line deduplication removes duplicate lines from text while preserving the first occurrence of each line. This is useful for cleaning up lists, removing duplicate entries from data files, and consolidating multiple sources of information.' },
  { question: 'Does the order of lines matter?', answer: 'When removing duplicates, this tool preserves the order of first occurrence. The first time a line appears, it is kept; subsequent occurrences are removed. If you need lines sorted alphabetically instead, use the "Sort Lines" button.' },
  { question: 'Is the comparison case-sensitive?', answer: 'Yes, the comparison is case-sensitive. "Hello" and "hello" are treated as different lines. If you need case-insensitive deduplication, convert all text to lowercase first using the Text Case tool.' },
  { question: 'When would I use this tool?', answer: 'Common use cases include: cleaning up email lists, removing duplicate entries from CSV data, consolidating multiple search results, cleaning up log files, and deduplicating any list where each item is on its own line.' },
]

---

<ToolLayout
  tool={tool}
  description="Free online line deduplication tool. Remove duplicate lines and sort text instantly. Perfect for cleaning up lists and data. All processing is local and private." {steps} {faq}
>
  <div class="flex flex-wrap gap-3 mb-6">
    <button id="dedupeBtn" class="btn btn-primary">Remove Duplicates</button>
    <button id="sortBtn" class="btn btn-secondary">Sort Lines</button>
    <button id="sampleBtn" class="btn btn-secondary">Load Sample</button>
    <button id="clearBtn" class="btn btn-secondary">Clear</button>
  </div>
  <div class="grid lg:grid-cols-2 gap-6">
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Input</span></div><textarea id="dedupeInput" class="code-input" placeholder="Enter lines..."></textarea></div>
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Output</span></div><pre id="dedupeOutput" class="code-output"></pre></div>
  </div>
  <StatusMessage id="dedupeStatus" />

  <section slot="examples" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Example</h2>
    <div class="grid md:grid-cols-2 gap-6">
      <div><h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 dark:text-gray-400">Before (With Duplicates)</h3><pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>apple
banana
apple
cherry
banana
date</code></pre></div>
      <div><h3 class="text-sm font-semibold text-green-600 uppercase tracking-wider mb-3">After (Deduplicated)</h3><pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>apple
banana
cherry
date</code></pre></div>
    </div>
  </section>

  <section slot="tutorial" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Common Use Cases</h2>
    <div class="prose prose-gray max-w-none dark:prose-invert">
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">Line deduplication is a simple but powerful operation that saves time when working with lists and data files.</p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3 dark:text-white">Typical Scenarios</h3>
      <ul class="list-disc list-inside space-y-2 text-gray-500 dark:text-gray-400">
        <li>Cleaning up email lists by removing duplicate addresses</li>
        <li>Consolidating multiple search results into a unique list</li>
        <li>Removing duplicate entries from CSV or TSV files</li>
        <li>Cleaning log files by removing repeated error messages</li>
        <li>Creating unique word lists from text analysis</li>
      </ul>
    </div>
  </section>

    <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="space-y-3">
      <a href="/guides/line-deduplication-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Line Deduplication Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Remove duplicates, preserve order, clean up lists.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
      <a href="/tools/sort-lines/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Sort Lines</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Sort text lines alphabetically.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    </div>
  </section>

  <script>
    import { copyToClipboard } from '../../../utils/copyToClipboard'
    const dedupeBtn = document.getElementById('dedupeBtn')!; const sortBtn = document.getElementById('sortBtn')!; const clearBtn = document.getElementById('clearBtn')!; const sampleBtn = document.getElementById('sampleBtn')!; const dedupeInput = document.getElementById('dedupeInput'); const dedupeOutput = document.getElementById('dedupeOutput')!
    function showStatus(message: string, type: 'success' | 'error') { const statusEl = document.getElementById('dedupeStatus')!; statusEl.textContent = message; statusEl.classList.remove('hidden'); statusEl.className = type === 'success' ? 'mt-4 px-4 py-3 rounded-lg bg-green-900/40 border border-green-800 text-green-400' : 'mt-4 px-4 py-3 rounded-lg bg-red-900/40 border border-red-800 text-red-400'; setTimeout(() => statusEl.classList.add('hidden'), 3000) }
    dedupeBtn.addEventListener('click', () => { const lines = dedupeInput.value.split('\n'); const seen = new Set(); const out: string[] = []; lines.forEach(line => { if (!seen.has(line)) { seen.add(line); out.push(line) } }); dedupeOutput.textContent = out.join('\n'); showStatus('Removed ' + (lines.length - out.length) + ' duplicate lines!', 'success') })
    sortBtn.addEventListener('click', () => { const lines = dedupeInput.value.split('\n'); lines.sort((a, b) => a.localeCompare(b)); dedupeOutput.textContent = lines.join('\n') })
    clearBtn.addEventListener('click', () => { dedupeInput.value = ''; dedupeOutput.textContent = '' })
    sampleBtn.addEventListener('click', () => { dedupeInput.value = 'apple\nbanana\napple\ncherry\nbanana\ndate'; dedupeOutput.textContent = '' })
  </script>
</ToolLayout>