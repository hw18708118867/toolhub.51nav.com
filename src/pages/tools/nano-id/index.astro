---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'nano-id')!
const steps = [
  { name: 'Configure Settings', text: 'Choose the ID length (8-36 characters) and how many IDs you need (1-50). You can also choose whether to use uppercase letters.' },
  { name: 'Generate IDs', text: 'Click "Generate" to create Nano IDs. Nano ID uses a larger alphabet than UUID (64 characters) making it more compact — a 21-character Nano ID has similar collision probability to a UUID.' },
  { name: 'Copy or Download', text: 'Use "Copy All" to copy the IDs, or "Download" to save them as a text file.' },
]
const faq = [
  { question: 'What is Nano ID?', answer: 'Nano ID is a tiny, secure, URL-friendly unique string ID generator. It\'s smaller than UUID (21 chars vs 36 chars for the same collision probability), faster to generate, and uses a more compact alphabet of 64 characters.' },
  { question: 'Nano ID vs UUID — which should I use?', answer: 'Nano ID is smaller (21 chars vs 36), making it better for URLs and database keys where space matters. UUID is more widely recognized and has built-in support in most databases. Both are suitable for distributed systems. Choose Nano ID for compactness, UUID for compatibility.' },
  { question: 'How likely is a Nano ID collision?', answer: 'With the default 21-character length and 64-character alphabet, you need to generate ~10^19 IDs for a 1% collision chance. For most applications, the collision risk is negligible.' },
]
---
<ToolLayout tool={tool} description="Free Nano ID generator. Generate compact, URL-friendly unique IDs. Smaller and faster than UUID. All processing is local." {steps} {faq}>
  <div class="mb-6 space-y-4"><div class="flex flex-wrap gap-4 items-center"><div class="flex items-center gap-2"><label class="font-medium text-gray-700 dark:text-gray-300">Length:</label><select id="nanoLen" class="form-select bg-white border border-gray-200 text-gray-900 rounded-lg px-3 py-2 w-24 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100"><option>8</option><option>12</option><option selected>21</option><option>36</option></select></div><div class="flex items-center gap-2"><label class="font-medium text-gray-700 dark:text-gray-300">Count:</label><select id="nanoCount" class="form-select bg-white border border-gray-200 text-gray-900 rounded-lg px-3 py-2 w-24 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100"><option>1</option><option>5</option><option>10</option><option>20</option><option>50</option></select></div></div></div>
  <div class="flex flex-wrap gap-3 mb-6"><button id="generateBtn" class="btn btn-primary">Generate</button><button id="copyBtn" class="btn btn-secondary">Copy All</button><button id="clearBtn" class="btn btn-secondary">Clear</button></div>
  <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Generated IDs</span><button id="downloadBtn" class="btn btn-sm btn-secondary">Download</button></div><pre id="nanoOutput" class="code-output">Click "Generate" to get started</pre></div>
  <section slot="examples" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Example</h2><pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-lg text-gray-700 font-mono text-center dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>V1StGXR8_Z5jdHi6B-myT</code></pre><p class="text-sm text-gray-400 mt-3 text-center">21 characters, URL-safe, collision-resistant.</p></section>
  <section slot="tutorial" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">About Nano ID</h2><div class="text-gray-500 dark:text-gray-400 leading-relaxed space-y-3"><p>Nano ID uses a 64-character alphabet (A-Z, a-z, 0-9, _ and -) and cryptographically secure random number generation. The URL-safe alphabet means Nano IDs can be used directly in URLs without encoding. The default 21-character length provides ~126 bits of entropy — comparable to UUID v4.</p><p>Nano ID is an excellent choice for database primary keys, URL slugs, file names, and any scenario where you need compact unique identifiers.</p></div></section>
  <script is:inline>
    async function copyText(text) { try { await navigator.clipboard.writeText(text) } catch {} }
    var alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789_-';
    var generateBtn = document.getElementById('generateBtn');
    var copyBtn = document.getElementById('copyBtn');
    var clearBtn = document.getElementById('clearBtn');
    var downloadBtn = document.getElementById('downloadBtn');
    var nanoLen = document.getElementById('nanoLen');
    var nanoCount = document.getElementById('nanoCount');
    var nanoOutput = document.getElementById('nanoOutput');
    function nanoid(len) { var id = ''; var arr = new Uint8Array(len); crypto.getRandomValues(arr); for (var i = 0; i < len; i++) id += alphabet[arr[i] % alphabet.length]; return id; }
    generateBtn.addEventListener('click', function() { var len = parseInt(nanoLen.value); var count = parseInt(nanoCount.value); var ids = []; for (var i = 0; i < count; i++) ids.push(nanoid(len)); nanoOutput.textContent = ids.join('\n'); });
    copyBtn.addEventListener('click', async function() { await copyText(nanoOutput.textContent || ''); });
    clearBtn.addEventListener('click', function() { nanoOutput.textContent = 'Click "Generate" to get started'; });
    downloadBtn.addEventListener('click', function() { var blob = new Blob([nanoOutput.textContent || ''], { type: 'text/plain' }); var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'nanoids.txt'; a.click(); URL.revokeObjectURL(a.href); });
  </script>

  <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-2xl">
      <a href="/guides/password-hash-guide/" class="group"><div class="bg-white border border-gray-200 rounded-xl p-5 flex gap-4 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-1 dark:text-white">Password Security & Hash Algorithms</h4><p class="text-xs text-gray-500 mt-1 dark:text-gray-400">MD5 vs SHA-256, bcrypt, password best practices.</p></div></div></a>
      <a href="/guides/password-hash-guide/" class="group"><div class="bg-white border border-gray-200 rounded-xl p-5 flex gap-4 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-1 dark:text-white">Password Security & Hash Algorithms</h4><p class="text-xs text-gray-500 mt-1 dark:text-gray-400">MD5 vs SHA-256, bcrypt, password best practices.</p></div></div></a>
    </div>
  </section>
</ToolLayout>