---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'image-compressor')!
const steps = [
  { name: 'Upload an Image', text: 'Click or drag an image file into the upload area. Supports JPEG, PNG, and WebP formats. The tool processes everything locally in your browser — no server upload.' },
  { name: 'Adjust Quality', text: 'Use the quality slider to balance file size against visual quality. Lower quality = smaller file. The preview updates to show compression results in real-time.' },
  { name: 'Download the Compressed Image', text: 'Click "Download" to save the compressed image. Compare the original and compressed file sizes. Typical savings: 50-80% for JPEG, 30-60% for PNG.' },
]
const faq = [
  { question: 'How does image compression work?', answer: 'For JPEG and WebP, compression reduces quality by discarding visual data the human eye barely notices — this is lossy compression. For PNG, the browser\'s encoder applies lossless compression. Our tool uses the Canvas API to re-encode images at your chosen quality setting. All processing is local — images never leave your browser.' },
  { question: 'What quality setting should I use?', answer: 'For photos on the web: 70-85% quality is the sweet spot — good visual quality at significantly reduced size. For images with text or sharp lines: use 85-95% to preserve clarity. For thumbnail previews: 50-60% is acceptable. Always check the preview before downloading — what is acceptable depends on your use case.' },
  { question: 'Can I compress PNG images?', answer: 'Yes. The tool compresses PNG by re-encoding with the browser\'s PNG encoder. Savings are typically smaller than JPEG (30-60% vs 50-80%) because PNG uses lossless compression internally. For maximum PNG compression, use dedicated tools like pngquant or oxipng that apply advanced quantization.' },
]
---
<ToolLayout tool={tool} description="Free online image compressor. Reduce JPEG, PNG and WebP file size without leaving your browser. Adjust quality and preview in real-time. All processing is local and private." {steps} {faq}>
  <div class="mb-6"><div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Upload Image</span></div><div class="p-6 text-center"><input type="file" id="fileInput" accept="image/jpeg,image/png,image/webp" class="hidden"><button id="uploadBtn" class="btn btn-primary" onclick="document.getElementById('fileInput').click()">Choose Image</button><p class="text-xs text-gray-400 mt-2">or drag and drop anywhere • JPEG, PNG, WebP</p></div></div></div>
  <div class="mb-6 hidden" id="controls"><div class="flex items-center gap-4"><label class="text-sm text-gray-600 dark:text-gray-400">Quality: <span id="qualityVal">80</span>%</label><input type="range" id="quality" class="flex-1" min="10" max="100" value="80"><button id="downloadBtn" class="btn btn-primary">Download</button></div><div class="flex gap-4 mt-3 text-sm text-gray-400"><span>Original: <span id="origSize" class="text-gray-600 dark:text-gray-300">-</span></span><span>Compressed: <span id="newSize" class="text-green-500">-</span></span><span>Saved: <span id="savedPct" class="text-green-500">-</span></span></div></div>
  <div class="grid md:grid-cols-2 gap-6 hidden" id="previews"><div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Original</span></div><div class="p-4 flex items-center justify-center"><img id="origPreview" class="max-h-64 max-w-full object-contain"></div></div><div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Compressed Preview</span></div><div class="p-4 flex items-center justify-center"><img id="newPreview" class="max-h-64 max-w-full object-contain"></div></div></div>
  <section slot="relatedArticles" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2><div class="space-y-3">
      <a href="/guides/image-tools-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Image Tools Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Compress, resize, convert and optimize images for the web.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/image-resize/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Image Resize</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Resize images to exact dimensions.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/image-format-converter/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Image Format Converter</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Convert between PNG, JPEG, WebP and SVG.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
  </div></section>
  <script>
    const fileInput=document.getElementById('fileInput') as HTMLInputElement,uploadBtn=document.getElementById('uploadBtn')!,controls=document.getElementById('controls')!,previews=document.getElementById('previews')!,quality=document.getElementById('quality') as HTMLInputElement,qualityVal=document.getElementById('qualityVal')!,downloadBtn=document.getElementById('downloadBtn')!,origPreview=document.getElementById('origPreview') as HTMLImageElement,newPreview=document.getElementById('newPreview') as HTMLImageElement,origSize=document.getElementById('origSize')!,newSize=document.getElementById('newSize')!,savedPct=document.getElementById('savedPct')!;
    let origBlob:Blob|null=null,origUrl='';
    fileInput.addEventListener('change',(e:any)=>{const f=e.target.files?.[0];if(f) loadImage(f)});
    document.addEventListener('dragover',e=>e.preventDefault());
    document.addEventListener('drop',e=>{e.preventDefault();const f=e.dataTransfer?.files?.[0];if(f&&f.type.startsWith('image/'))loadImage(f)});
    function loadImage(f:File){origBlob=f;origUrl=URL.createObjectURL(f);origPreview.src=origUrl;origSize.textContent=formatSize(f.size);controls.classList.remove('hidden');previews.classList.remove('hidden');compress()}
    function compress(){if(!origBlob)return;const img=new Image();img.onload=()=>{const c=document.createElement('canvas');c.width=img.width;c.height=img.height;const ctx=c.getContext('2d')!;ctx.drawImage(img,0,0);const q=parseInt(quality.value)/100;c.toBlob(b=>{if(!b)return;newPreview.src=URL.createObjectURL(b);newSize.textContent=formatSize(b.size);const pct=Math.round((1-b.size/origBlob!.size)*100);savedPct.textContent=pct+'%'},'image/jpeg',q)};img.src=origUrl}
    quality.addEventListener('input',()=>{qualityVal.textContent=quality.value;compress()});
    downloadBtn.addEventListener('click',()=>{const a=document.createElement('a');a.href=newPreview.src;a.download='compressed.jpg';a.click()});
    function formatSize(b:number):string{return b<1024?b+' B':b<1048576?(b/1024).toFixed(1)+' KB':(b/1048576).toFixed(1)+' MB'}
  </script>
</ToolLayout>
