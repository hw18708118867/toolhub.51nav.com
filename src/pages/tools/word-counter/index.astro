---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'

const tool = tools.find(t => t.id === 'word-counter')!

const steps = [
  { name: 'Enter Your Text', text: 'Type or paste any text into the input panel. The tool accepts any text — articles, code, documents, emails, or social media posts.' },
  { name: 'View Real-Time Counts', text: 'As you type, the tool automatically counts characters, words, lines, and sentences. The numbers update in real-time with no delay.' },
  { name: 'Use the Results', text: 'The counts are displayed in four easy-to-read cards. Use them for content planning, SEO optimization, or meeting length requirements.' },
]

const faq = [
  { question: 'How are words counted?', answer: 'Words are counted by splitting the text on whitespace characters (spaces, tabs, newlines) and counting non-empty segments. This matches the behavior of most word processors and text editors. Punctuation attached to words is counted as part of the word.' },
  { question: 'How are sentences counted?', answer: 'Sentences are counted by detecting sentence-ending punctuation: periods (.), exclamation marks (!), and question marks (?). This is a simple heuristic and may not handle all edge cases (like abbreviations or decimal numbers) perfectly.' },
  { question: 'What counts as a character?', answer: 'Every character including spaces, punctuation, and line breaks is counted. This gives you the total character count, which is useful for social media limits (like Twitter) or SEO meta description length requirements.' },
  { question: 'Can I use this for SEO content optimization?', answer: 'Yes! This tool is great for checking content length against SEO best practices. Meta descriptions should be 150-160 characters, title tags should be 50-60 characters, and blog posts typically perform best at 1,500-2,500 words.' },
]

---

<ToolLayout
  tool={tool}
  description="Free online word counter. Count characters, words, lines, and sentences in real-time. Perfect for SEO, content writing, and social media. All processing is local and private." {steps} {faq}
>
  <div class="code-panel mb-6"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Your Text</span></div><textarea id="countInput" class="code-input" placeholder="Enter text..."></textarea></div>
  <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Counts</span></div><div class="p-4 grid grid-cols-2 md:grid-cols-4 gap-4"><div class="bg-gray-50 rounded-lg p-4 text-center dark:bg-gray-800"><div class="text-3xl font-bold text-blue-600 dark:text-blue-400" id="charsCount">0</div><div class="text-gray-400">Characters</div></div><div class="bg-gray-50 rounded-lg p-4 text-center dark:bg-gray-800"><div class="text-3xl font-bold text-green-600 dark:text-green-400" id="wordsCount">0</div><div class="text-gray-400">Words</div></div><div class="bg-gray-50 rounded-lg p-4 text-center dark:bg-gray-800"><div class="text-3xl font-bold text-purple-600 dark:text-purple-400" id="linesCount">0</div><div class="text-gray-400">Lines</div></div><div class="bg-gray-50 rounded-lg p-4 text-center dark:bg-gray-800"><div class="text-3xl font-bold text-orange-600 dark:text-orange-400" id="sentencesCount">0</div><div class="text-gray-400">Sentences</div></div></div></div>

  <section slot="examples" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">SEO Content Metrics</h2>
    <div class="overflow-x-auto"><table class="w-full text-left"><thead><tr class="border-b border-gray-200 dark:border-gray-800"><th class="py-3 px-4 text-sm font-semibold text-gray-900 dark:text-white">Content Type</th><th class="py-3 px-4 text-sm font-semibold text-gray-900 dark:text-white">Recommended Length</th></tr></thead><tbody class="text-gray-500 dark:text-gray-400"><tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4">Meta Description</td><td class="py-3 px-4">150-160 characters</td></tr><tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4">Title Tag</td><td class="py-3 px-4">50-60 characters</td></tr><tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4">Blog Post</td><td class="py-3 px-4">1,500-2,500 words</td></tr><tr><td class="py-3 px-4">Tweet</td><td class="py-3 px-4">280 characters</td></tr></tbody></table></div>
  </section>

  <section slot="tutorial" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Why Word Count Matters</h2>
    <div class="prose prose-gray max-w-none dark:prose-invert">
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">Whether you're writing for SEO, social media, or academic purposes, word count impacts how your content performs. Search engines favor comprehensive content, social platforms have character limits, and readers appreciate content that respects their time.</p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3 dark:text-white">Content Length Tips</h3>
      <ul class="list-disc list-inside space-y-2 text-gray-500 dark:text-gray-400">
        <li>Blog posts: 1,500+ words for SEO, but quality over quantity</li>
        <li>Social media: Keep it concise — less is often more</li>
        <li>Email subject lines: 30-50 characters for best open rates</li>
        <li>Product descriptions: 150-300 words for e-commerce</li>
      </ul>
    </div>
  </section>

  <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-2xl">
      <a href="/guides/word-count-seo-guide/" class="group"><div class="bg-white border border-gray-200 rounded-xl p-5 flex gap-4 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-1 dark:text-white">Word Counts & SEO</h4><p class="text-xs text-gray-500 mt-1 dark:text-gray-400">Content length benchmarks for every content type.</p></div></div></a>
      <a href="/guides/word-count-seo-guide/" class="group"><div class="bg-white border border-gray-200 rounded-xl p-5 flex gap-4 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-1 dark:text-white">Word Counts & SEO</h4><p class="text-xs text-gray-500 mt-1 dark:text-gray-400">Content length benchmarks for every content type.</p></div></div></a>
    </div>
  </section>

  <script>
    const countInput = document.getElementById('countInput'); const charsCount = document.getElementById('charsCount')!; const wordsCount = document.getElementById('wordsCount')!; const linesCount = document.getElementById('linesCount')!; const sentencesCount = document.getElementById('sentencesCount')!
    function count() { const text = countInput.value; charsCount.textContent = text.length.toString(); wordsCount.textContent = text.trim() ? text.trim().split(/\s+/).filter(w => w).length.toString() : '0'; linesCount.textContent = text ? text.split('\n').length.toString() : '0'; sentencesCount.textContent = (text.match(/[.!?]/g) || []).length.toString() }
    countInput.addEventListener('input', count)
  </script>
</ToolLayout>