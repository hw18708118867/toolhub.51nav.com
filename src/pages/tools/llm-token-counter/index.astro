---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'llm-token-counter')!
const steps = [
  { name: 'Paste Your Text', text: 'Paste the text you want to count tokens for — a prompt, API response, code, or any text. The tool supports all common text input.' },
  { name: 'Select the Model', text: 'Choose the target model — GPT-4o, GPT-4, Claude Opus/Sonnet/Haiku, or Gemini Pro/Flash. Each model uses a different tokenizer, and counts will vary between them.' },
  { name: 'Read the Token Count', text: 'The tool shows estimated token count and approximate cost based on current API pricing. Use this to budget API calls, optimize prompts, or check if your input exceeds context limits.' },
]
const faq = [
  { question: 'What is a token?', answer: 'LLMs process text in tokens, not characters. A token is roughly 3/4 of a word — about 4 characters in English. "Hello world" is 2 tokens. API pricing is per token (both input and output). Context windows are measured in tokens: GPT-4o supports 128K tokens. Understanding token counts helps you budget costs and avoid hitting context limits.' },
  { question: 'Are these counts exact?', answer: 'Exact tokenization requires the model\'s specific tokenizer (tiktoken for OpenAI, Claude\'s tokenizer for Anthropic). Our tool uses character-based estimation: OpenAI ~4 chars/token, Claude ~3.5 chars/token, Gemini ~4 chars/token. This is accurate within 10-15% for English text. For precise counts, use the official tokenizer libraries (tiktoken for Python, @anthropic-ai/tokenizer for Node).' },
  { question: 'Why do token counts differ between models?', answer: 'Each model uses a different tokenizer with a different vocabulary. The same text can produce different token counts on GPT-4o vs Claude vs Gemini. Generally they\'re within 10-20% of each other for English. For code, non-English languages, and technical content, the differences can be larger.' },
]
---
<ToolLayout tool={tool} description="Free online LLM token counter. Estimate token counts for OpenAI GPT-4, Claude and Gemini models. Budget API costs and check context limits. All processing is local and private." {steps} {faq}>
  <div class="code-panel mb-6"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Input Text</span></div><textarea id="input" class="code-input" placeholder="Paste text to count tokens..."></textarea></div>
  <div class="flex flex-wrap gap-3 mb-6"><select id="model" class="form-select bg-white border border-gray-200 rounded-lg px-3 py-2 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100"><optgroup label="OpenAI"><option value="gpt4o">GPT-4o (128K)</option><option value="gpt4">GPT-4 Turbo (128K)</option></optgroup><optgroup label="Anthropic"><option value="claude-opus">Claude Opus 4 (200K)</option><option value="claude-sonnet">Claude Sonnet 4 (200K)</option><option value="claude-haiku">Claude Haiku 4 (200K)</option></optgroup><optgroup label="Google"><option value="gemini-pro">Gemini 2.5 Pro (1M)</option><option value="gemini-flash">Gemini 2.5 Flash (1M)</option></optgroup></select></div>
  <div class="grid sm:grid-cols-3 gap-4 mb-6">
    <div class="code-panel"><div class="text-center p-4"><div class="text-3xl font-bold text-blue-600 dark:text-blue-400" id="tokenCount">0</div><div class="text-sm text-gray-400 mt-1">Tokens</div></div></div>
    <div class="code-panel"><div class="text-center p-4"><div class="text-3xl font-bold text-green-600 dark:text-green-400" id="charCount">0</div><div class="text-sm text-gray-400 mt-1">Characters</div></div></div>
    <div class="code-panel"><div class="text-center p-4"><div class="text-3xl font-bold text-purple-600 dark:text-purple-400" id="costEst">$0</div><div class="text-sm text-gray-400 mt-1">Est. Cost (input)</div></div></div>
  </div>
  <section slot="examples" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Token Estimation Reference</h2><div class="overflow-x-auto"><table class="w-full text-left"><thead><tr class="border-b border-gray-200 dark:border-gray-800"><th class="py-3 px-4 text-sm font-semibold text-gray-900 dark:text-white">Model</th><th class="py-3 px-4 text-sm font-semibold text-gray-900 dark:text-white">Context</th><th class="py-3 px-4 text-sm font-semibold text-gray-900 dark:text-white">Est. Input Cost</th></tr></thead><tbody class="text-gray-500 dark:text-gray-400 text-sm"><tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4">GPT-4o</td><td class="py-3 px-4">128K</td><td class="py-3 px-4">$2.50/1M tokens</td></tr><tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4">Claude Sonnet 4</td><td class="py-3 px-4">200K</td><td class="py-3 px-4">$3.00/1M tokens</td></tr><tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4">Gemini 2.5 Flash</td><td class="py-3 px-4">1M</td><td class="py-3 px-4">$0.15/1M tokens</td></tr><tr><td class="py-3 px-4">Claude Haiku 4</td><td class="py-3 px-4">200K</td><td class="py-3 px-4">$0.80/1M tokens</td></tr></tbody></table></div></section>
  <section slot="relatedArticles" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2><div class="space-y-3">
      <a href="/guides/dev-tools-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Dev Tools Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">JSON Schema, LLM tokens, prompts and mock data.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/prompt-tools/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Prompt Tools</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Format and optimize LLM prompts.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
  </div></section>
  <script>
    const input=document.getElementById('input') as HTMLTextAreaElement,model=document.getElementById('model') as HTMLSelectElement,tokenCount=document.getElementById('tokenCount')!,charCount=document.getElementById('charCount')!,costEst=document.getElementById('costEst')!;
    const rates:Record<string,[number,number]>={
      gpt4o:[4,2.5],gpt4:[4,10],'claude-opus':[3.5,15],'claude-sonnet':[3.5,3],'claude-haiku':[3.5,0.8],'gemini-pro':[4,1.25],'gemini-flash':[4,0.15]};
    input.addEventListener('input',()=>{const t=input.value;charCount.textContent=t.length.toString();const m=model.value,r=rates[m]||[4,0];const tokens=Math.ceil(t.length/r[0]);tokenCount.textContent=tokens.toString();costEst.textContent='$'+((tokens/1000000)*r[1]).toFixed(4)})
    model.addEventListener('change',()=>input.dispatchEvent(new Event('input')))
  </script>
</ToolLayout>
