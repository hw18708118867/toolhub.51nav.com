---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'prompt-tools')!
const steps = [
  { name: 'Paste Your Prompt', text: 'Paste the prompt you want to format or optimize. This can be a raw draft, a prompt from another source, or a prompt that needs cleaning up.' },
  { name: 'Choose an Action', text: '"Format" structures the prompt with clear sections (role, task, context, format). "Clean" removes extra whitespace and fixes formatting. "Template" wraps it in a reusable prompt template.' },
  { name: 'Copy the Result', text: 'The formatted prompt is ready to use with any LLM. Well-structured prompts produce more consistent and predictable outputs from AI models.' },
]
const faq = [
  { question: 'Why structure prompts?', answer: 'LLMs respond better to well-structured prompts. A clear prompt with separated sections (role, task, context, output format) produces more consistent results than a wall of text. This is called "prompt engineering" — it\'s not about tricks, it\'s about clarity. A well-structured prompt reduces ambiguity and gives the model clear instructions to follow.' },
  { question: 'Does this tool use AI to optimize prompts?', answer: 'No. This tool applies structural formatting — adding section headers, cleaning whitespace, and wrapping in templates. It does not call any AI API or modify the semantic content of your prompt. The optimization is structural, not semantic. For AI-powered prompt improvement, use the target LLM itself with a meta-prompt asking it to improve your prompt.' },
]
---
<ToolLayout tool={tool} description="Free online prompt formatter. Structure and organize LLM prompts for better results. Format with sections, clean whitespace, and create reusable templates. All processing is local and private." {steps} {faq}>
  <div class="code-panel mb-6"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Input Prompt</span></div><textarea id="input" class="code-input" placeholder="Paste your prompt here..."></textarea></div>
  <div class="flex flex-wrap gap-3 mb-6"><button id="formatBtn" class="btn btn-primary" data-action="format">Format</button><button id="cleanBtn" class="btn btn-secondary" data-action="clean">Clean</button><button id="templateBtn" class="btn btn-secondary" data-action="template">Template</button><button id="sampleBtn" class="btn btn-secondary">Load Sample</button></div>
  <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Output</span><button id="copyBtn" class="btn btn-sm btn-secondary ml-auto">Copy</button></div><pre id="output" class="code-output text-sm"></pre></div>
  <section slot="examples" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Prompt Structure Guide</h2><div class="overflow-x-auto"><table class="w-full text-left"><thead><tr class="border-b border-gray-200 dark:border-gray-800"><th class="py-3 px-4 text-sm font-semibold text-gray-900 dark:text-white">Section</th><th class="py-3 px-4 text-sm font-semibold text-gray-900 dark:text-white">Purpose</th></tr></thead><tbody class="text-gray-500 dark:text-gray-400 text-sm"><tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4 font-mono">Role</td><td class="py-3 px-4">Define who the AI should act as</td></tr><tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4 font-mono">Task</td><td class="py-3 px-4">Clear, specific instruction of what to do</td></tr><tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4 font-mono">Context</td><td class="py-3 px-4">Background info the model needs</td></tr><tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4 font-mono">Format</td><td class="py-3 px-4">How the output should be structured</td></tr><tr><td class="py-3 px-4 font-mono">Constraints</td><td class="py-3 px-4">Limits, tone, or things to avoid</td></tr></tbody></table></div></section>
  <section slot="relatedArticles" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2><div class="space-y-3">
      <a href="/guides/dev-tools-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Dev Tools Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">JSON Schema, LLM tokens, prompts and mock data.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/llm-token-counter/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">LLM Token Counter</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Count tokens for OpenAI, Claude and Gemini.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/json-formatter/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">JSON Formatter</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Format, validate and minify JSON.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
  </div></section>
  <script>
    const input=document.getElementById('input') as HTMLTextAreaElement,output=document.getElementById('output')!,formatBtn=document.getElementById('formatBtn')!,cleanBtn=document.getElementById('cleanBtn')!,templateBtn=document.getElementById('templateBtn')!,sampleBtn=document.getElementById('sampleBtn')!,copyBtn=document.getElementById('copyBtn')!;
    function doFormat(){const t=input.value.trim();if(!t)return;output.textContent='## Role\n[Define the AI role]\n\n## Task\n'+t+'\n\n## Context\n[Add relevant background]\n\n## Output Format\n[Specify format, length, tone]\n\n## Constraints\n[List any restrictions]'}
    function doClean(){output.textContent=input.value.replace(/\n{3,}/g,'\n\n').replace(/[ \t]+$/gm,'').trim()}
    function doTemplate(){const t=input.value.trim();if(!t)return;output.textContent='You are a helpful assistant.\n\nTask: '+t+'\n\nRespond concisely and accurately.'}
    [formatBtn,cleanBtn,templateBtn].forEach(b=>b.addEventListener('click',()=>{const a=(b as HTMLElement).dataset.action;if(a==='format')doFormat();else if(a==='clean')doClean();else doTemplate()}))
    sampleBtn.addEventListener('click',()=>{input.value='write a function to sort an array of objects by date\nit should handle null dates\ni need it in typescript\nplease make it efficient';doFormat()})
    copyBtn.addEventListener('click',()=>navigator.clipboard.writeText(output.textContent||''))
  </script>
</ToolLayout>
