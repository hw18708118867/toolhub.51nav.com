---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import StatusMessage from '../../../components/StatusMessage.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'css-formatter')!
const steps = [
  { name: 'Paste CSS', text: 'Paste your CSS code into the input panel. The tool accepts minified, messy, or normally formatted CSS.' },
  { name: 'Format or Minify', text: 'Click "Format" to beautify with proper indentation. Click "Minify" to compress to a single line.' },
  { name: 'Copy the Result', text: 'The output appears in the right panel. All processing happens locally.' },
]
const faq = [
  { question: 'What does CSS formatting do?', answer: 'CSS formatting adds proper indentation, line breaks, and spacing to make your stylesheet readable. It groups related properties, aligns values, and makes the structure easy to scan. Formatted CSS is easier to debug and maintain.' },
  { question: 'When should I minify CSS?', answer: 'Minify CSS for production deployments to reduce file size. Minified CSS removes all unnecessary whitespace, comments, and formatting. This reduces bandwidth usage and improves page load times. Always keep the formatted version in your source code.' },
  { question: 'Does formatting change how my CSS works?', answer: 'No. Formatting only changes whitespace — it does not modify selectors, properties, or values. Your CSS will work exactly the same after formatting. Minification also preserves functionality.' },
]
---
<ToolLayout tool={tool} description="Free online CSS formatter. Format, beautify, and minify CSS code instantly. All processing happens locally in your browser." {steps} {faq}>
  <div class="flex flex-wrap gap-3 mb-6">
    <button id="formatBtn" class="btn btn-primary">Format</button>
    <button id="minifyBtn" class="btn btn-secondary">Minify</button>
    <button id="sampleBtn" class="btn btn-secondary">Load Sample</button>
    <button id="clearBtn" class="btn btn-secondary">Clear</button>
  </div>
  <div class="grid lg:grid-cols-2 gap-6">
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Input CSS</span></div><textarea id="cssInput" class="code-input" placeholder="Paste CSS..."></textarea></div>
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Output</span></div><pre id="cssOutput" class="code-output"></pre></div>
  </div>
  <StatusMessage id="cssStatus" />
  <section slot="examples" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Example</h2><div class="grid lg:grid-cols-2 gap-6"><div><h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 dark:text-gray-400">Before</h3><pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>.btn&#123;color:white;background:blue;padding:8px 16px;border-radius:8px&#125;.btn:hover&#123;background:darkblue&#125;</code></pre></div><div><h3 class="text-sm font-semibold text-green-600 uppercase tracking-wider mb-3">After</h3><pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>.btn &#123;
  color: white;
  background: blue;
  padding: 8px 16px;
  border-radius: 8px;
&#125;

.btn:hover &#123;
  background: darkblue;
&#125;</code></pre></div></div></section>
  <script is:inline>
    async function copyText(text) { try { await navigator.clipboard.writeText(text) } catch {} }
    const formatBtn = document.getElementById('formatBtn');
    const minifyBtn = document.getElementById('minifyBtn');
    const sampleBtn = document.getElementById('sampleBtn');
    const clearBtn = document.getElementById('clearBtn');
    const cssInput = document.getElementById('cssInput');
    const cssOutput = document.getElementById('cssOutput');
    function showStatus(m, t) {
      var el = document.getElementById('cssStatus');
      el.textContent = m;
      el.classList.remove('hidden');
      el.className = t === 'success' ? 'mt-4 px-4 py-3 rounded-lg bg-green-900/40 border border-green-800 text-green-400' : 'mt-4 px-4 py-3 rounded-lg bg-red-900/40 border border-red-800 text-red-400';
      setTimeout(function() { el.classList.add('hidden') }, 3000);
    }
    function format() {
      var css = cssInput.value.trim();
      if (!css) { showStatus('Enter CSS first!', 'error'); return; }
      css = css.replace(/\s*\{/g, ' {\n  ');
      css = css.replace(/;\s*/g, ';\n  ');
      css = css.replace(/;\s*\n\s*\}/g, ';\n}');
      css = css.replace(/\}\s*/g, '}\n\n');
      css = css.replace(/\n\s*\n/g, '\n');
      cssOutput.textContent = css.trim();
      showStatus('CSS formatted!', 'success');
    }
    function minify() {
      var css = cssInput.value.trim();
      if (!css) { showStatus('Enter CSS first!', 'error'); return; }
      cssOutput.textContent = css.replace(/\s+/g, ' ').replace(/\s*\{/g, '{').replace(/\}\s*/g, '}').replace(/;\s*/g, ';').trim();
      showStatus('CSS minified!', 'success');
    }
    formatBtn.addEventListener('click', format);
    minifyBtn.addEventListener('click', minify);
    clearBtn.addEventListener('click', function() { cssInput.value = ''; cssOutput.textContent = ''; });
    sampleBtn.addEventListener('click', function() { cssInput.value = '.btn{color:white;background:blue;padding:8px 16px;border-radius:8px}.btn:hover{background:darkblue}.card{background:white;border:1px solid #eee;padding:20px;border-radius:12px}'; cssOutput.textContent = ''; });
  </script>

  <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="space-y-3">
      <a href="/guides/css-color-gradient-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">CSS Colors & Gradients Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">HEX, RGB, HSL explained. Build palettes and gradients.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
      <a href="/guides/css-color-gradient-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">CSS Colors & Gradients Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">HEX, RGB, HSL explained. Build palettes and gradients.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    </div>
  </section>
</ToolLayout>