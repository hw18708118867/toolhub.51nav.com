---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import StatusMessage from '../../../components/StatusMessage.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'js-formatter')!
const steps = [
  { name: 'Paste JavaScript', text: 'Paste your JavaScript or TypeScript code into the input panel. The tool accepts any JS code — minified, messy, or normally formatted.' },
  { name: 'Format or Minify', text: 'Click "Format" to beautify with proper indentation. Click "Minify" to compress to a single line.' },
  { name: 'Copy the Result', text: 'The output appears in the right panel. All processing happens locally.' },
]
const faq = [
  { question: 'What does JS formatting do?', answer: 'JS formatting adds proper indentation, line breaks, and spacing to make your code readable. It uses consistent indentation for blocks, adds spaces around operators, and makes the code structure clear.' },
  { question: 'When should I minify JavaScript?', answer: 'Minify JavaScript for production to reduce file size and improve load times. Minification removes whitespace, shortens variable names, and eliminates dead code. For production, use a build tool like webpack or esbuild that handles minification automatically.' },
  { question: 'Does this tool support TypeScript?', answer: 'This tool uses basic formatting rules that work with both JavaScript and TypeScript. For advanced TypeScript formatting with type-aware rules, use a dedicated formatter like Prettier or the TypeScript compiler.' },
]
---
<ToolLayout tool={tool} description="Free online JavaScript formatter. Format, beautify, and minify JS/TS code instantly. All processing happens locally in your browser." {steps} {faq}>
  <div class="flex flex-wrap gap-3 mb-6">
    <button id="formatBtn" class="btn btn-primary">Format</button>
    <button id="minifyBtn" class="btn btn-secondary">Minify</button>
    <button id="sampleBtn" class="btn btn-secondary">Load Sample</button>
    <button id="clearBtn" class="btn btn-secondary">Clear</button>
  </div>
  <div class="grid lg:grid-cols-2 gap-6">
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Input JS</span></div><textarea id="jsInput" class="code-input" placeholder="Paste JavaScript..."></textarea></div>
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Output</span></div><pre id="jsOutput" class="code-output"></pre></div>
  </div>
  <StatusMessage id="jsStatus" />
  <section slot="examples" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Example</h2><div class="grid lg:grid-cols-2 gap-6"><div><h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 dark:text-gray-400">Before</h3><pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>function add(a,b)&#123;return a+b&#125;const result=add(1,2);console.log(result)</code></pre></div><div><h3 class="text-sm font-semibold text-green-600 uppercase tracking-wider mb-3">After</h3><pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>function add(a, b) &#123;
  return a + b;
&#125;

const result = add(1, 2);
console.log(result);</code></pre></div></div></section>
  <script is:inline>
    async function copyText(text) { try { await navigator.clipboard.writeText(text) } catch {} }
    var formatBtn = document.getElementById('formatBtn');
    var minifyBtn = document.getElementById('minifyBtn');
    var sampleBtn = document.getElementById('sampleBtn');
    var clearBtn = document.getElementById('clearBtn');
    var jsInput = document.getElementById('jsInput');
    var jsOutput = document.getElementById('jsOutput');
    function showStatus(m, t) {
      var el = document.getElementById('jsStatus');
      el.textContent = m;
      el.classList.remove('hidden');
      el.className = t === 'success' ? 'mt-4 px-4 py-3 rounded-lg bg-green-900/40 border border-green-800 text-green-400' : 'mt-4 px-4 py-3 rounded-lg bg-red-900/40 border border-red-800 text-red-400';
      setTimeout(function() { el.classList.add('hidden') }, 3000);
    }
    function format() {
      var js = jsInput.value.trim();
      if (!js) { showStatus('Enter JS first!', 'error'); return; }
      js = js.replace(/\s*\{/g, ' {\n  ');
      js = js.replace(/;\s*/g, ';\n');
      js = js.replace(/\}\s*/g, '}\n');
      js = js.replace(/,\s*/g, ', ');
      var indent = 0;
      var lines = js.split('\n');
      var result = [];
      for (var i = 0; i < lines.length; i++) {
        var line = lines[i].trim();
        if (!line) continue;
        if (line.startsWith('}')) indent = Math.max(0, indent - 1);
        result.push('  '.repeat(indent) + line);
        if (line.endsWith('{') && !line.startsWith('}')) indent++;
      }
      jsOutput.textContent = result.join('\n');
      showStatus('JS formatted!', 'success');
    }
    function minify() {
      var js = jsInput.value.trim();
      if (!js) { showStatus('Enter JS first!', 'error'); return; }
      jsOutput.textContent = js.replace(/\s+/g, ' ').replace(/\s*\{/g, '{').replace(/\}\s*/g, '}').replace(/;\s*/g, ';').trim();
      showStatus('JS minified!', 'success');
    }
    formatBtn.addEventListener('click', format);
    minifyBtn.addEventListener('click', minify);
    clearBtn.addEventListener('click', function() { jsInput.value = ''; jsOutput.textContent = ''; });
    sampleBtn.addEventListener('click', function() { jsInput.value = 'function add(a,b){return a+b}const result=add(1,2);console.log(result)'; jsOutput.textContent = ''; });
  </script>

  <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-2xl">
      <a href="/guides/text-processing-guide/" class="group"><div class="bg-white border border-gray-200 rounded-xl p-5 flex gap-4 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-1 dark:text-white">Text Processing for Developers</h4><p class="text-xs text-gray-500 mt-1 dark:text-gray-400">Regex, case conversion, deduplication workflows.</p></div></div></a>
      <a href="/guides/text-processing-guide/" class="group"><div class="bg-white border border-gray-200 rounded-xl p-5 flex gap-4 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-1 dark:text-white">Text Processing for Developers</h4><p class="text-xs text-gray-500 mt-1 dark:text-gray-400">Regex, case conversion, deduplication workflows.</p></div></div></a>
    </div>
  </section>
</ToolLayout>