---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import StatusMessage from '../../../components/StatusMessage.astro'
import { tools } from '../../../data/tools'

const tool = tools.find(t => t.id === 'binary-converter')!

const steps = [
  { name: 'Enter Your Data', text: 'Type or paste text into the input panel. You can enter regular text to convert to binary, or a binary string to convert back to text.' },
  { name: 'Choose Direction', text: 'Click "Text to Binary" to get the 8-bit binary representation of each character, or "Binary to Text" to decode a binary string.' },
  { name: 'Copy and Use', text: 'The result appears on the right. You can choose spaced format (with separators) or continuous format.' },
]

const faq = [
  { question: 'How does text-to-binary conversion work?', answer: 'Each character is converted to its numeric code point (usually via UTF-8 or ASCII), then that number is expressed as an 8-bit binary string (a sequence of 0s and 1s). For example, "A" has ASCII code 65, which in binary is 01000001.' },
  { question: 'What\'s the difference between binary and hex?', answer: 'Binary uses base 2 (0s and 1s), hex uses base 16 (0-9, A-F). Binary is the fundamental language of computers, while hex is a more compact human-readable representation. One hex digit represents exactly 4 binary digits (a nibble), so two hex digits = 8 bits = 1 byte.' },
  { question: 'Can I convert binary back to the original text?', answer: 'Yes, as long as the binary was encoded with a consistent scheme (8 bits per character). The decoder expects 8-bit groups separated by spaces or as a continuous string. It uses UTF-8 decoding, so it handles ASCII and multi-byte characters correctly.' },
]
---

<ToolLayout
  tool={tool}
  description="Free online binary converter. Convert text to binary (0s and 1s) or decode binary back to readable text. Supports UTF-8, with optional space separators for readability." {steps} {faq}
>
  <div class="flex flex-wrap gap-3 mb-6">
    <button id="encodeBtn" class="btn btn-primary">Text to Binary</button>
    <button id="decodeBtn" class="btn btn-secondary">Binary to Text</button>
    <button id="sampleBtn" class="btn btn-secondary">Load Sample</button>
    <button id="clearBtn" class="btn btn-secondary">Clear</button>
  </div>

  <div class="grid lg:grid-cols-2 gap-6">
    <div class="code-panel">
      <div class="code-panel-header">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400" id="inputLabel">Text</span>
        <button id="copyInputBtn" class="btn btn-sm btn-secondary">Copy</button>
      </div>
      <textarea id="inputEl" class="code-input" placeholder="Enter text or binary..."></textarea>
    </div>
    <div class="code-panel">
      <div class="code-panel-header">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400" id="outputLabel">Binary</span>
        <button id="copyOutputBtn" class="btn btn-sm btn-secondary">Copy</button>
      </div>
      <pre id="outputEl" class="code-output"></pre>
    </div>
  </div>
  <StatusMessage id="statusEl" />

  <section slot="examples" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Examples</h2>
    <div class="grid lg:grid-cols-2 gap-6">
      <div>
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 dark:text-gray-400">Plain Text</h3>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>Hello</code></pre>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-green-600 uppercase tracking-wider mb-3">Binary</h3>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>01001000 01100101 01101100 01101100 01101111</code></pre>
      </div>
    </div>
  </section>

  <section slot="tutorial" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Binary Encoding in Practice</h2>
    <div class="prose prose-gray max-w-none dark:prose-invert">
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">
        Binary is the native language of computers — every piece of text, every image, every program ultimately reduces to a sequence of 0s and 1s. Understanding how text maps to binary helps you grasp encoding fundamentals, debug low-level issues, and appreciate how character encodings like ASCII and UTF-8 work.
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3 dark:text-white">When Binary Conversion Is Useful</h3>
      <ul class="list-disc list-inside space-y-2 text-gray-500 dark:text-gray-400">
        <li>Learning how computers represent text at the bit level</li>
        <li>Teaching computer science concepts (binary, bits, bytes)</li>
        <li>Debugging bit-level operations and bitmasks</li>
        <li>Working with hardware protocols that use binary data</li>
        <li>Creating steganography or encoding puzzles</li>
      </ul>
    </div>
  </section>

  <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="space-y-3">
      <a href="/guides/character-encoding-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Character Encoding Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Unicode, UTF-8, binary, hex — full encoding coverage.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
      <a href="/guides/number-bases-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Number Bases Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Binary, hex, decimal, octal conversions explained.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    </div>
  </section>

  <script>
    import { copyToClipboard } from '../../../utils/copyToClipboard'

    const inputEl = document.getElementById('inputEl') as HTMLTextAreaElement
    const outputEl = document.getElementById('outputEl')!
    const inputLabel = document.getElementById('inputLabel')!
    const outputLabel = document.getElementById('outputLabel')!

    function showStatus(msg: string, type: 'success' | 'error') {
      const el = document.getElementById('statusEl')!
      el.textContent = msg; el.classList.remove('hidden')
      el.className = type === 'success' ? 'mt-4 px-4 py-3 rounded-lg bg-green-900/40 border border-green-800 text-green-400' : 'mt-4 px-4 py-3 rounded-lg bg-red-900/40 border border-red-800 text-red-400'
      setTimeout(() => el.classList.add('hidden'), 3000)
    }

    function textToBinary(text: string): string {
      const bytes = new TextEncoder().encode(text)
      return Array.from(bytes).map(b => b.toString(2).padStart(8, '0')).join(' ')
    }

    function binaryToText(binary: string): string {
      // Strip all whitespace
      const cleaned = binary.replace(/\s/g, '')
      if (cleaned.length % 8 !== 0) throw new Error('Binary string length must be a multiple of 8')
      const bytes: number[] = []
      for (let i = 0; i < cleaned.length; i += 8) {
        const byte = cleaned.substring(i, i + 8)
        if (!/^[01]{8}$/.test(byte)) throw new Error('Invalid binary group: ' + byte)
        bytes.push(parseInt(byte, 2))
      }
      return new TextDecoder().decode(new Uint8Array(bytes))
    }

    document.getElementById('encodeBtn')!.addEventListener('click', () => {
      const v = inputEl.value
      if (!v) { showStatus('Enter some text first', 'error'); return }
      inputLabel.textContent = 'Text'
      outputLabel.textContent = 'Binary'
      outputEl.textContent = textToBinary(v)
      showStatus('Converted to binary!', 'success')
    })

    document.getElementById('decodeBtn')!.addEventListener('click', () => {
      const v = inputEl.value.trim()
      if (!v) { showStatus('Enter binary string first', 'error'); return }
      try {
        inputLabel.textContent = 'Binary'
        outputLabel.textContent = 'Text'
        outputEl.textContent = binaryToText(v)
        showStatus('Decoded from binary!', 'success')
      } catch (e) {
        showStatus('Invalid binary: ' + (e as Error).message, 'error')
      }
    })

    document.getElementById('sampleBtn')!.addEventListener('click', () => {
      inputEl.value = 'Hello'
      outputEl.textContent = ''
      inputLabel.textContent = 'Text'
      outputLabel.textContent = 'Binary'
    })

    document.getElementById('clearBtn')!.addEventListener('click', () => { inputEl.value = ''; outputEl.textContent = '' })

    document.getElementById('copyInputBtn')!.addEventListener('click', async () => {
      const ok = await copyToClipboard(inputEl.value)
      showStatus(ok ? 'Copied!' : 'Copy failed', ok ? 'success' : 'error')
    })
    document.getElementById('copyOutputBtn')!.addEventListener('click', async () => {
      const ok = await copyToClipboard(outputEl.textContent || '')
      showStatus(ok ? 'Copied!' : 'Copy failed', ok ? 'success' : 'error')
    })
  </script>
</ToolLayout>
