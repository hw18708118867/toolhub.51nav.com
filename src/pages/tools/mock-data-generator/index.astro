---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'mock-data-generator')!
const steps = [
  { name: 'Define Your Fields', text: 'Add fields with names and types — string, number, boolean, date, email, name, UUID, or custom. Configure how many records you need (1-100).' },
  { name: 'Generate Mock Data', text: 'Click "Generate" to create realistic fake data. Each field uses appropriate random values — real-looking names, valid emails, random UUIDs, and sensible numbers.' },
  { name: 'Copy the JSON', text: 'The output is a JSON array ready to use as mock API responses, database seed data, or test fixtures. Copy it directly into your project.' },
]
const faq = [
  { question: 'What can I use mock data for?', answer: 'Mock data is used for: frontend development before the API is ready, unit and integration tests, database seeding, load testing with realistic data volumes, API documentation examples, and demo/prototype presentations. It gives you realistic data without exposing real user information or connecting to production databases.' },
  { question: 'How is this different from the Random String Generator?', answer: 'The Random String Generator produces raw random strings. This tool produces structured, realistic data with field types that match actual use cases — email addresses that look real, names from common name lists, dates in correct formats. Use the Random String Generator for tokens and IDs. Use this for API mocks and test fixtures.' },
]
---
<ToolLayout tool={tool} description="Free online mock data generator. Generate realistic fake JSON with names, emails, dates and UUIDs. Perfect for API mocking, testing and database seeding. All processing is local and private." {steps} {faq}>
  <div class="mb-6 space-y-4"><div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Field Definitions</span><button id="addFieldBtn" class="btn btn-sm btn-secondary ml-auto">+ Add Field</button></div><div class="p-4 space-y-3" id="fields"></div></div>
    <div class="flex items-center gap-4"><label class="text-sm text-gray-600 dark:text-gray-400">Records:</label><input type="number" id="count" class="w-24 bg-white border border-gray-200 rounded-lg px-3 py-2 text-sm dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100" value="10" min="1" max="100"><button id="generateBtn" class="btn btn-primary">Generate</button></div></div>
  <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Generated Data</span><button id="copyBtn" class="btn btn-sm btn-secondary ml-auto">Copy</button></div><pre id="output" class="code-output text-sm">Add fields and click "Generate" to create mock data.</pre></div>
  <section slot="relatedArticles" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2><div class="space-y-3">
      <a href="/guides/dev-tools-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Dev Tools Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">JSON Schema, LLM tokens, prompts and mock data.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/json-formatter/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">JSON Formatter</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Format, validate and minify JSON.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
  </div></section>
  <script>
    const fields=document.getElementById('fields')!,addFieldBtn=document.getElementById('addFieldBtn')!,count=document.getElementById('count') as HTMLInputElement,output=document.getElementById('output')!,generateBtn=document.getElementById('generateBtn')!,copyBtn=document.getElementById('copyBtn')!;
    const names=['Alice','Bob','Charlie','Diana','Eve','Frank','Grace','Henry','Iris','Jack'],domains=['example.com','test.org','demo.dev'];
    const types=['string','number','boolean','email','name','uuid','date'];
    function addField(){const d=document.createElement('div');d.className='flex gap-3 items-center field-row';d.innerHTML='<input class="flex-1 bg-white border border-gray-200 rounded-lg px-3 py-2 text-sm dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100" placeholder="field_name"><select class="form-select w-32 bg-white border border-gray-200 rounded-lg px-2 py-1 text-sm dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100">'+types.map(t=>`<option value="${t}">${t}</option>`).join('')+'</select><button class="btn btn-sm btn-secondary remove-btn">×</button>';d.querySelector('.remove-btn')!.addEventListener('click',()=>d.remove());fields.appendChild(d)}
    addField();addField();addField();
    addFieldBtn.addEventListener('click',addField);
    function gen(type:string):any{switch(type){case'string':return'Hello World';case'number':return Math.floor(Math.random()*100);case'boolean':return Math.random()>0.5;case'email':return names[Math.floor(Math.random()*names.length)].toLowerCase()+'@'+domains[Math.floor(Math.random()*domains.length)];case'name':return names[Math.floor(Math.random()*names.length)];case'uuid':return crypto.randomUUID?crypto.randomUUID():'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g,c=>{const r=Math.random()*16|0;return(c==='x'?r:r&0x3|0x8).toString(16)});case'date':return new Date(Date.now()-Math.random()*31536000000).toISOString().split('T')[0];default:return''}}
    generateBtn.addEventListener('click',()=>{const rows=document.querySelectorAll('.field-row');const defs:any[]=[];rows.forEach(r=>{const name=(r.children[0]as HTMLInputElement).value.trim(),type=(r.children[1]as HTMLSelectElement).value;if(name)defs.push({name,type})});if(defs.length===0)return;const result=[];const n=parseInt(count.value)||10;for(let i=0;i<n;i++){const obj:any={};defs.forEach(d=>obj[d.name]=gen(d.type));result.push(obj)}output.textContent=JSON.stringify(result,null,2)})
    copyBtn.addEventListener('click',()=>navigator.clipboard.writeText(output.textContent||''))
  </script>
</ToolLayout>
