---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'chmod-calculator')!
const steps = [
  { name: 'Toggle Permissions', text: 'Check or uncheck the Read, Write, and Execute boxes for Owner, Group, and Others. The numeric and symbolic values update in real-time as you change permissions.' },
  { name: 'Read the chmod Value', text: 'The numeric (octal) chmod value appears at the top — e.g., 755 or 644. The symbolic form is shown below — e.g., rwxr-xr-x. Both represent the same permission set.' },
  { name: 'Copy and Use', text: 'Copy the chmod command and paste it into your terminal: chmod 755 script.sh. The tool shows you exactly which permissions each digit represents.' },
]
const faq = [
  { question: 'What do chmod numbers mean?', answer: 'Each digit represents permissions for Owner, Group, and Others respectively. Each digit is the sum of: read=4, write=2, execute=1. So 7 = 4+2+1 = rwx (full access), 5 = 4+1 = r-x (read and execute), 6 = 4+2 = rw- (read and write), 4 = r-- (read only), 0 = --- (no access). chmod 755 means: owner gets rwx, group gets r-x, others get r-x.' },
  { question: 'What are common chmod values?', answer: '644 (rw-r--r--): standard for files — owner can read/write, everyone else can read. 755 (rwxr-xr-x): standard for directories and executables — owner has full access, others can read and execute. 600 (rw-------): private files — only owner can read/write. 777 (rwxrwxrwx): everyone has full access — security risk, almost never use this. 700 (rwx------): private scripts — only owner can access.' },
  { question: 'How do I set permissions recursively?', answer: 'Add the -R flag: chmod -R 755 directory/. This applies the permission to the directory and everything inside it — all files and subdirectories. Be careful with -R on existing directories — it can change permissions on files that were deliberately set differently. For new deployments, set directory permissions first, then file permissions separately.' },
]
---
<ToolLayout tool={tool} description="Free online chmod calculator. Convert Unix file permissions between numeric (755), symbolic (rwxr-xr-x) and human-readable formats. Interactive permission toggle for Owner, Group and Others." {steps} {faq}>
  <div class="code-panel mb-6"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">chmod Calculator</span></div><div class="p-6">
    <div class="text-center mb-6"><div class="text-4xl font-bold text-blue-600 dark:text-blue-400 font-mono" id="numeric">755</div><div class="text-lg text-gray-400 font-mono mt-2" id="symbolic">rwxr-xr-x</div></div>
    <div class="overflow-x-auto"><table class="w-full text-center" id="permTable"><thead><tr class="border-b border-gray-200 dark:border-gray-800"><th class="py-2 px-4 text-sm font-semibold text-gray-900 dark:text-white"></th><th class="py-2 px-4 text-sm font-semibold text-gray-900 dark:text-white">Owner</th><th class="py-2 px-4 text-sm font-semibold text-gray-900 dark:text-white">Group</th><th class="py-2 px-4 text-sm font-semibold text-gray-900 dark:text-white">Others</th></tr></thead><tbody class="text-gray-500 dark:text-gray-400"></tbody></table></div>
    <div class="mt-4 p-3 bg-gray-50 rounded-lg font-mono text-sm text-gray-700 dark:bg-gray-800 dark:text-gray-300 text-center" id="command">chmod 755 file</div></div></div>
  <section slot="examples" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Common chmod Values</h2><div class="overflow-x-auto"><table class="w-full text-left"><thead><tr class="border-b border-gray-200 dark:border-gray-800"><th class="py-3 px-4 text-sm font-semibold text-gray-900 dark:text-white">chmod</th><th class="py-3 px-4 text-sm font-semibold text-gray-900 dark:text-white">Symbolic</th><th class="py-3 px-4 text-sm font-semibold text-gray-900 dark:text-white">Use Case</th></tr></thead><tbody class="text-gray-500 dark:text-gray-400 text-sm font-mono"><tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4">777</td><td class="py-3 px-4">rwxrwxrwx</td><td class="py-3 px-4">Everyone can do everything — avoid</td></tr><tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4">755</td><td class="py-3 px-4">rwxr-xr-x</td><td class="py-3 px-4">Directories and executable scripts</td></tr><tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4">644</td><td class="py-3 px-4">rw-r--r--</td><td class="py-3 px-4">Standard file permissions</td></tr><tr><td class="py-3 px-4">600</td><td class="py-3 px-4">rw-------</td><td class="py-3 px-4">Private files (SSH keys, configs)</td></tr></tbody></table></div></section>
  <section slot="relatedArticles" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2><div class="space-y-3">
      <a href="/guides/shell-tools-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Shell Tools Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Unix permissions, shell escaping for safe commands.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/shell-escape/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Shell Escape</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Escape strings for bash and command line.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
  </div></section>
  <script>
    // Build permission table
    const tbody=document.querySelector('#permTable tbody')!;
    const permNames=['Read','Write','Execute'],vals=[4,2,1],checkedInit=[true,true,false,true,true,false,true,true,false];
    let ci=0;
    for(let i=0;i<3;i++){var row='<tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4 text-sm font-medium text-gray-700 dark:text-gray-300">'+permNames[i]+'</td>';for(var j=0;j<3;j++){row+='<td class="py-3 px-4"><label class="inline-flex items-center cursor-pointer"><input type="checkbox" class="perm-check w-5 h-5 rounded" data-row="'+i+'" data-col="'+j+'" value="'+vals[i]+'"'+(checkedInit[ci]?' checked':'')+'></label></td>';ci++}row+='</tr>';tbody.innerHTML+=row}

    const numeric=document.getElementById('numeric')!,symbolic=document.getElementById('symbolic')!,command=document.getElementById('command')!;
    const permChars=['r','w','x'];
    function update(){let vals=[0,0,0],sym=['','',''];document.querySelectorAll('.perm-check:checked').forEach((cb:any)=>{const r=parseInt(cb.dataset.row),c=parseInt(cb.dataset.col);vals[c]+=parseInt(cb.value);sym[c]+=permChars[r]});for(let i=0;i<3;i++){while(sym[i].length<3)sym[i]+='-'}const num=vals.join(''),symStr=sym.join('');numeric.textContent=num;symbolic.textContent=symStr;command.textContent=`chmod ${num} file`}
    document.querySelectorAll('.perm-check').forEach(cb=>cb.addEventListener('change',update));
  </script>
</ToolLayout>
