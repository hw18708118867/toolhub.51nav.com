---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'

const tool = tools.find(t => t.id === 'box-shadow-generator')!

const steps = [
  { name: 'Adjust Shadow Properties', text: 'Use the sliders to set the shadow offset (X and Y), blur radius, spread radius, and color. Check "Inset" for inner shadows. The preview box updates in real-time.' },
  { name: 'View the Preview', text: 'The preview box shows exactly how the shadow will render. The box itself has a white background so you can see both the element and its shadow clearly.' },
  { name: 'Copy the CSS', text: 'The generated box-shadow CSS value updates as you adjust settings. Copy it and paste directly into your CSS. You can also add multiple shadows by generating and stacking values.' },
]

const faq = [
  { question: 'What do the box-shadow values mean?', answer: 'box-shadow: offset-x offset-y blur spread color; offset-x: horizontal position (positive = right). offset-y: vertical position (positive = down). blur: how soft the shadow edge is (0 = sharp, higher = softer). spread: how much the shadow expands or contracts (positive = larger, negative = smaller). color: any CSS color value including rgba for transparency. Adding "inset" at the start creates an inner shadow.' },
  { question: 'Can I add multiple shadows?', answer: 'Yes, CSS supports multiple box-shadows on one element, separated by commas. Generate each shadow separately with this tool, copy the values, and combine them: box-shadow: 2px 2px 8px rgba(0,0,0,0.1), 0 0 0 2px #3b82f6; Multiple shadows layer from top to bottom (first shadow on top). This is commonly used for combining a subtle drop shadow with a colored focus ring.' },
  { question: 'Does box-shadow affect layout?', answer: 'No. Box shadows are purely visual — they don\'t take up space or affect the box model. Neighboring elements won\'t shift to accommodate a shadow. This is different from outline and border, which do affect layout (border) or may overlap adjacent elements (outline). If you need a shadow that affects layout, use a pseudo-element with a lower z-index instead.' },
  { question: 'What about performance?', answer: 'Box shadows are GPU-accelerated in modern browsers and have minimal performance impact. However, animating box-shadow (changing it on hover or during transitions) can trigger repaints. For animated shadows, prefer using opacity transitions on a pseudo-element with a fixed shadow — this is more performant than changing the shadow values directly.' },
]

---

<ToolLayout
  tool={tool}
  description="Free visual CSS box-shadow generator. Design shadows with live preview — offset, blur, spread, color and inset. Copy production-ready box-shadow CSS. All processing is local and private." {steps} {faq}
>
  <div class="grid lg:grid-cols-2 gap-6 mb-6">
    <div class="space-y-4">
      <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Shadow Properties</span></div>
        <div class="p-4 space-y-3">
          <div class="flex items-center gap-3"><label class="text-sm text-gray-600 dark:text-gray-400 w-20">Offset X</label><input type="range" id="offsetX" class="flex-1" min="-30" max="30" value="4"><span id="xVal" class="text-sm text-gray-500 w-12">4px</span></div>
          <div class="flex items-center gap-3"><label class="text-sm text-gray-600 dark:text-gray-400 w-20">Offset Y</label><input type="range" id="offsetY" class="flex-1" min="-30" max="30" value="6"><span id="yVal" class="text-sm text-gray-500 w-12">6px</span></div>
          <div class="flex items-center gap-3"><label class="text-sm text-gray-600 dark:text-gray-400 w-20">Blur</label><input type="range" id="blur" class="flex-1" min="0" max="60" value="12"><span id="blurVal" class="text-sm text-gray-500 w-12">12px</span></div>
          <div class="flex items-center gap-3"><label class="text-sm text-gray-600 dark:text-gray-400 w-20">Spread</label><input type="range" id="spread" class="flex-1" min="-20" max="20" value="0"><span id="spreadVal" class="text-sm text-gray-500 w-12">0px</span></div>
          <div class="flex items-center gap-3"><label class="text-sm text-gray-600 dark:text-gray-400 w-20">Color</label><input type="color" id="shadowColor" value="#000000" class="w-10 h-8 rounded cursor-pointer"><span id="opacityVal" class="text-sm text-gray-500"></span></div>
          <div class="flex items-center gap-3"><label class="text-sm text-gray-600 dark:text-gray-400 w-20">Opacity</label><input type="range" id="opacity" class="flex-1" min="0" max="100" value="15"><span id="opacityPct" class="text-sm text-gray-500 w-12">15%</span></div>
          <div class="flex items-center gap-3"><label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" id="inset" class="w-4 h-4 rounded"><span class="text-sm text-gray-600 dark:text-gray-400">Inset (inner shadow)</span></label></div>
        </div>
      </div>
    </div>
    <div>
      <div class="code-panel mb-4"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Live Preview</span></div><div class="p-10 bg-gray-100 dark:bg-gray-800 rounded-b-xl flex items-center justify-center" style="min-height:240px"><div id="previewBox" class="w-40 h-40 bg-white rounded-2xl dark:bg-gray-700"></div></div></div>
      <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Generated CSS</span><button id="copyBtn" class="btn btn-sm btn-secondary ml-auto">Copy</button></div><pre id="cssOutput" class="code-output text-sm"></pre></div>
    </div>
  </div>

  <section slot="tutorial" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Box Shadow Design Tips</h2>
    <div class="prose prose-gray max-w-none dark:prose-invert">
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">Well-designed shadows create depth without being noticed. The best shadows look natural — like light falling on a physical object.</p>
      <ul class="list-disc list-inside space-y-2 text-gray-500 dark:text-gray-400">
        <li><strong>Subtle is better:</strong> Low opacity (5-15%) with moderate blur feels natural. High opacity shadows look harsh and dated.</li>
        <li><strong>Layer shadows:</strong> Use 2-3 stacked shadows for realistic depth — a tight shadow (small offset/blur) with higher opacity plus a wider shadow with lower opacity.</li>
        <li><strong>Match your light source:</strong> Consistent offset direction across all shadows on a page creates a cohesive look.</li>
        <li><strong>Inset for pressed effects:</strong> Inset shadows make elements look pressed or indented — great for active button states and input fields.</li>
      </ul>
    </div>
  </section>

  <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="space-y-3">
      <a href="/guides/box-shadow-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Box Shadow Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Design, layer and optimize CSS shadows for performance.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
      <a href="/tools/border-radius-generator/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Border Radius Generator</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Generate CSS border-radius styles visually.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
      <a href="/guides/css-color-gradient-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">CSS Colors & Gradients Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">HEX, RGB, HSL explained. Build palettes and gradients.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    </div>
  </section>

  <script>
    import { copyToClipboard } from '../../../utils/copyToClipboard'
    const offsetX = document.getElementById('offsetX') as HTMLInputElement;
    const offsetY = document.getElementById('offsetY') as HTMLInputElement;
    const blur = document.getElementById('blur') as HTMLInputElement;
    const spread = document.getElementById('spread') as HTMLInputElement;
    const shadowColor = document.getElementById('shadowColor') as HTMLInputElement;
    const opacity = document.getElementById('opacity') as HTMLInputElement;
    const inset = document.getElementById('inset') as HTMLInputElement;
    const previewBox = document.getElementById('previewBox')!;
    const cssOutput = document.getElementById('cssOutput')!;
    const copyBtn = document.getElementById('copyBtn')!;

    function hexToRgb(hex: string): [number,number,number] {
      return [parseInt(hex.slice(1,3),16), parseInt(hex.slice(3,5),16), parseInt(hex.slice(5,7),16)];
    }

    function update() {
      const x = offsetX.value, y = offsetY.value, b = blur.value, s = spread.value;
      const [r,g,bl] = hexToRgb(shadowColor.value);
      const o = parseInt(opacity.value) / 100;
      document.getElementById('xVal')!.textContent = x + 'px';
      document.getElementById('yVal')!.textContent = y + 'px';
      document.getElementById('blurVal')!.textContent = b + 'px';
      document.getElementById('spreadVal')!.textContent = s + 'px';
      document.getElementById('opacityPct')!.textContent = Math.round(o * 100) + '%';
      const shadowVal = `${inset.checked ? 'inset ' : ''}${x}px ${y}px ${b}px ${s}px rgba(${r},${g},${bl},${o.toFixed(2)})`;
      previewBox.style.boxShadow = shadowVal;
      cssOutput.textContent = `box-shadow: ${shadowVal};`;
    }

    [offsetX, offsetY, blur, spread, shadowColor, opacity, inset].forEach(el => el.addEventListener('input', update));
    copyBtn.addEventListener('click', async () => { await copyToClipboard(cssOutput.textContent || ''); });
    update();
  </script>
</ToolLayout>
