---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import StatusMessage from '../../../components/StatusMessage.astro'
import { tools } from '../../../data/tools'

const tool = tools.find(t => t.id === 'json-to-toml')!

const steps = [
  { name: 'Paste Your JSON', text: 'Paste JSON data into the input panel. The JSON should be a valid object (not an array at the root, since TOML requires a table structure at the top level).' },
  { name: 'Convert to TOML', text: 'Click "JSON to TOML" to transform your data into TOML format. Nested objects become TOML tables (with [header] notation) and arrays become TOML arrays.' },
  { name: 'Copy and Use', text: 'Copy the TOML output for use in configuration files — Cargo.toml (Rust), pyproject.toml (Python), or any TOML-compatible tool.' },
]

const faq = [
  { question: 'What is TOML used for?', answer: 'TOML (Tom\'s Obvious, Minimal Language) is a configuration file format designed to be easy to read and write. It\'s the standard config format for Rust projects (Cargo.toml), Python projects (pyproject.toml), and is supported by many other tools. It\'s like JSON but with comments, cleaner syntax for nested data, and better human readability.' },
  { question: 'Are there limitations to this conversion?', answer: 'The conversion handles objects, arrays, strings, numbers, booleans, and null values. The JSON root should be an object (TOML requires a root table). Very deeply nested structures may produce deeply nested TOML table headers, which can become hard to read — but they will be valid TOML.' },
  { question: 'Does this support all TOML features?', answer: 'The converter outputs a clean subset of TOML: key-value pairs, arrays, inline tables for simple nested objects, and [table] headers for deeper nesting. It does not generate TOML arrays of tables ([[array]]) since the input JSON doesn\'t carry enough information to determine when to use that syntax. The output is valid TOML that any TOML parser can read.' },
]
---

<ToolLayout
  tool={tool}
  description="Free online JSON to TOML converter. Convert JSON objects into TOML configuration format. Useful for creating Cargo.toml, pyproject.toml, and other TOML config files." {steps} {faq}
>
  <div class="flex flex-wrap gap-3 mb-6">
    <button id="convertBtn" class="btn btn-primary">JSON to TOML</button>
    <button id="sampleBtn" class="btn btn-secondary">Load Sample</button>
    <button id="clearBtn" class="btn btn-secondary">Clear</button>
  </div>

  <div class="grid lg:grid-cols-2 gap-6">
    <div class="code-panel">
      <div class="code-panel-header">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400">JSON Input</span>
        <button id="copyInputBtn" class="btn btn-sm btn-secondary">Copy</button>
      </div>
      <textarea id="inputEl" class="code-input" placeholder="Paste JSON here..."></textarea>
    </div>
    <div class="code-panel">
      <div class="code-panel-header">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400">TOML Output</span>
        <button id="copyOutputBtn" class="btn btn-sm btn-secondary">Copy</button>
      </div>
      <pre id="outputEl" class="code-output"></pre>
    </div>
  </div>
  <StatusMessage id="statusEl" />

  <section slot="examples" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Example</h2>
    <div class="grid lg:grid-cols-2 gap-6">
      <div>
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 dark:text-gray-400">JSON</h3>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>&#123;
  "project": &#123;
    "name": "my-app",
    "version": "1.0.0",
    "dependencies": &#123;
      "express": "4.18.0",
      "lodash": "4.17.21"
    &#125;
  &#125;
&#125;</code></pre>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-green-600 uppercase tracking-wider mb-3">TOML</h3>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>[project]
name = "my-app"
version = "1.0.0"

[project.dependencies]
express = "4.18.0"
lodash = "4.17.21"</code></pre>
      </div>
    </div>
  </section>

  <section slot="tutorial" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Why TOML for Configuration</h2>
    <div class="prose prose-gray max-w-none dark:prose-invert">
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">
        TOML was created specifically because JSON, YAML, and INI each have drawbacks as configuration formats. JSON lacks comments — a dealbreaker for config files where you want to explain why a setting has a particular value. YAML's indentation-based syntax leads to subtle errors. INI is too simple for nested data.
      </p>
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">
        TOML hits a sweet spot: it supports comments, has a clear specification, handles nesting with a readable <code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">[section]</code> syntax, and uses explicit types (unlike YAML, where <code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">1.0</code> and <code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">1</code> can behave differently depending on the parser). If you're starting a new project and need a config file format, TOML is worth considering.
      </p>
    </div>
  </section>

  <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="space-y-3">
      <a href="/guides/json-conversion-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">JSON Conversion Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">CSV, XML, TOML — when and how to convert between formats.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
      <a href="/guides/json-structure-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">JSON Structure Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Flattening, tree views, and working with nested JSON.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    </div>
  </section>

  <script>
    import { copyToClipboard } from '../../../utils/copyToClipboard'

    const inputEl = document.getElementById('inputEl') as HTMLTextAreaElement
    const outputEl = document.getElementById('outputEl')!

    function showStatus(msg: string, type: 'success' | 'error') {
      const el = document.getElementById('statusEl')!
      el.textContent = msg; el.classList.remove('hidden')
      el.className = type === 'success' ? 'mt-4 px-4 py-3 rounded-lg bg-green-900/40 border border-green-800 text-green-400' : 'mt-4 px-4 py-3 rounded-lg bg-red-900/40 border border-red-800 text-red-400'
      setTimeout(() => el.classList.add('hidden'), 3000)
    }

    function tomlValue(val: any): string {
      if (val === null || val === undefined) return '""'
      if (typeof val === 'boolean') return val ? 'true' : 'false'
      if (typeof val === 'number') return String(val)
      if (typeof val === 'string') {
        // Use literal string if no special chars, otherwise basic string
        if (val.includes("'")) return JSON.stringify(val)
        if (/[\n\r"\\]/.test(val)) return JSON.stringify(val)
        if (/[^a-zA-Z0-9._\-:\/ ]/.test(val)) return JSON.stringify(val)
        return JSON.stringify(val) // safest approach
      }
      if (Array.isArray(val)) {
        const items = val.map(v => tomlValue(v)).join(', ')
        return `[${items}]`
      }
      if (typeof val === 'object') {
        // Inline table
        const pairs = Object.entries(val).map(([k, v]) => `${k} = ${tomlValue(v)}`).join(', ')
        return `{ ${pairs} }`
      }
      return JSON.stringify(val)
    }

    function jsonToToml(obj: any, prefix = ''): string {
      const lines: string[] = []
      const simplePairs: [string, any][] = []
      const nestedObjects: [string, any][] = []

      if (typeof obj !== 'object' || obj === null || Array.isArray(obj)) {
        return tomlValue(obj)
      }

      Object.entries(obj).forEach(([key, val]) => {
        if (val !== null && typeof val === 'object' && !Array.isArray(val)) {
          nestedObjects.push([key, val])
        } else {
          simplePairs.push([key, val])
        }
      })

      // Write simple key-value pairs
      simplePairs.forEach(([key, val]) => {
        const fullKey = prefix ? `${prefix}.${key}` : key
        lines.push(`${fullKey} = ${tomlValue(val)}`)
      })

      // Write nested tables
      nestedObjects.forEach(([key, val]) => {
        const fullKey = prefix ? `${prefix}.${key}` : key
        if (lines.length > 0) lines.push('')
        lines.push(`[${fullKey}]`)
        const nested = jsonToToml(val, fullKey)
        if (nested) lines.push(nested)
      })

      return lines.join('\n')
    }

    document.getElementById('convertBtn')!.addEventListener('click', () => {
      const v = inputEl.value.trim()
      if (!v) { showStatus('Paste some JSON first', 'error'); return }
      try {
        const obj = JSON.parse(v)
        if (typeof obj !== 'object' || obj === null || Array.isArray(obj)) {
          showStatus('JSON root must be an object {...} for TOML conversion', 'error')
          return
        }
        outputEl.textContent = jsonToToml(obj)
        showStatus('Converted to TOML!', 'success')
      } catch (e) { showStatus('Invalid JSON: ' + (e as Error).message, 'error') }
    })

    document.getElementById('sampleBtn')!.addEventListener('click', () => {
      inputEl.value = '{"project":{"name":"my-app","version":"1.0.0","description":"A sample project","active":true,"port":3000,"dependencies":{"express":"4.18.0","lodash":"4.17.21"},"devDependencies":{"typescript":"5.3.0"},"author":{"name":"Jane","email":"jane@example.com"}}}'
      outputEl.textContent = ''
    })

    document.getElementById('clearBtn')!.addEventListener('click', () => { inputEl.value = ''; outputEl.textContent = '' })

    document.getElementById('copyInputBtn')!.addEventListener('click', async () => {
      const ok = await copyToClipboard(inputEl.value)
      showStatus(ok ? 'Copied!' : 'Copy failed', ok ? 'success' : 'error')
    })
    document.getElementById('copyOutputBtn')!.addEventListener('click', async () => {
      const ok = await copyToClipboard(outputEl.textContent || '')
      showStatus(ok ? 'Copied!' : 'Copy failed', ok ? 'success' : 'error')
    })
  </script>
</ToolLayout>
