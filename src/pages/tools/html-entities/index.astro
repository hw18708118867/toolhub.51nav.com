---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'

const tool = tools.find(t => t.id === 'html-entities')!

const steps = [
  { name: 'Enter Your HTML', text: 'Type or paste HTML code or text containing special characters into the input panel.' },
  { name: 'Choose Direction', text: 'Click "Encode" to convert special characters like <, >, & into HTML entities. Click "Decode" to convert entities back to regular characters.' },
  { name: 'Get the Result', text: 'The converted output appears instantly in the right panel. All processing happens locally in your browser.' },
]

const faq = [
  { question: 'What are HTML entities?', answer: 'HTML entities are special codes used to display characters that have special meaning in HTML. For example, < is encoded as &amp;lt;, > as &amp;gt;, and & as &amp;amp;. Without encoding, these characters would be interpreted as HTML tags rather than displayed as text.' },
  { question: 'When should I use HTML entity encoding?', answer: 'You should encode HTML entities whenever you display user-generated content on a web page to prevent XSS (Cross-Site Scripting) attacks. Also use it when you want to display HTML code as text, such as in documentation or code examples.' },
  { question: 'What is the difference between HTML entities and URL encoding?', answer: 'HTML entities are for displaying special characters in HTML documents (e.g., &amp;lt; for <). URL encoding is for making URLs safe to transmit (e.g., %3C for <). They serve different purposes and use different encoding schemes.' },
  { question: 'What characters are encoded?', answer: 'The main characters that need encoding are: & (ampersand) → &amp;amp;, < (less than) → &amp;lt;, > (greater than) → &amp;gt;, " (double quote) → &amp;quot;, and \' (single quote) → &amp;#39;. These are the five characters that have special meaning in HTML.' },
]

const before = '<div class="example">Hello & Welcome</div>'
const after = '&lt;div class=&quot;example&quot;&gt;Hello &amp; Welcome&lt;/div&gt;'
---

<ToolLayout
  tool={tool}
  description="Free online HTML entity encoder and decoder. Convert special characters to HTML entities and back. All processing happens locally in your browser." {steps} {faq}
>
  <div class="flex flex-wrap gap-3 mb-6">
    <button id="encodeBtn" class="btn btn-primary">Encode</button>
    <button id="decodeBtn" class="btn btn-secondary">Decode</button>
    <button id="sampleBtn" class="btn btn-secondary">Load Sample</button>
    <button id="clearBtn" class="btn btn-secondary">Clear</button>
  </div>
  <div class="grid lg:grid-cols-2 gap-6">
    <div class="code-panel">
      <div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Input</span></div>
      <textarea id="htmlInput" class="code-input" placeholder="Enter HTML..."></textarea>
    </div>
    <div class="code-panel">
      <div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Output</span></div>
      <pre id="htmlOutput" class="code-output"></pre>
    </div>
  </div>

  <section slot="examples" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Examples</h2>
    <div class="grid lg:grid-cols-2 gap-6">
      <div><h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 dark:text-gray-400">Before (Raw HTML)</h3><pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>{before}</code></pre></div>
      <div><h3 class="text-sm font-semibold text-green-600 uppercase tracking-wider mb-3">After (HTML Entities)</h3><pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>{after}</code></pre></div>
    </div>
  </section>

  <section slot="tutorial" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Why HTML Entity Encoding Matters</h2>
    <div class="prose prose-gray max-w-none dark:prose-invert">
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">HTML entity encoding is a critical security practice for web developers. Without proper encoding, user input containing HTML tags or JavaScript could be executed in the browser, leading to XSS attacks. Encoding ensures that special characters are displayed as text, not interpreted as code.</p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3 dark:text-white">The Five Essential HTML Entities</h3>
      <ul class="list-disc list-inside space-y-2 text-gray-500 dark:text-gray-400">
        <li><code>&amp;amp;</code> — ampersand (&)</li>
        <li><code>&amp;lt;</code> — less than (&lt;)</li>
        <li><code>&amp;gt;</code> — greater than (&gt;)</li>
        <li><code>&amp;quot;</code> — double quote (")</li>
        <li><code>&amp;#39;</code> — single quote (')</li>
      </ul>
    </div>
  </section>

  <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="space-y-3">
      <a href="/guides/web-encoding-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Web Encoding Explained</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Base64, URL encoding, HTML entities.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
      <a href="/guides/web-encoding-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Web Encoding Explained</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Base64, URL encoding, HTML entities.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    </div>
  </section>

  <script>
    const encodeBtn = document.getElementById('encodeBtn')!
    const decodeBtn = document.getElementById('decodeBtn')!
    const clearBtn = document.getElementById('clearBtn')!
    const sampleBtn = document.getElementById('sampleBtn')!
    const htmlInput = document.getElementById('htmlInput')
    const htmlOutput = document.getElementById('htmlOutput')!
    const encodeMap: Record<string, string> = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }
    const decodeMap: Record<string, string> = { '&amp;': '&', '&lt;': '<', '&gt;': '>', '&quot;': '"', '&#39;': "'" }
    encodeBtn.addEventListener('click', () => { htmlOutput.textContent = htmlInput.value.replace(/[&<>"]/g, c => encodeMap[c] || c) })
    decodeBtn.addEventListener('click', () => { htmlOutput.textContent = htmlInput.value.replace(/&amp;|&lt;|&gt;|&quot;|&#39;/g, c => decodeMap[c] || c) })
    clearBtn.addEventListener('click', () => { htmlInput.value = ''; htmlOutput.textContent = '' })
    sampleBtn.addEventListener('click', () => { htmlInput.value = '<div class="example">Hello & Welcome</div>'; htmlOutput.textContent = '' })
  </script>
</ToolLayout>