---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import StatusMessage from '../../../components/StatusMessage.astro'
import { tools } from '../../../data/tools'

const tool = tools.find(t => t.id === 'rot13')!

const steps = [
  { name: 'Enter Your Text', text: 'Type or paste any text into the input area. ROT13 works on letters only — numbers, spaces, and punctuation pass through unchanged.' },
  { name: 'Click Convert', text: 'Click "ROT13 Encode/Decode" to shift each letter by 13 positions in the alphabet. Since ROT13 is its own inverse, the same button both encodes and decodes.' },
  { name: 'Copy the Result', text: 'Copy the output text. Apply ROT13 again to the result and you\'ll get back the original text — that\'s the beauty of the ROT13 cipher.' },
]

const faq = [
  { question: 'What is ROT13?', answer: 'ROT13 ("rotate by 13 places") is a Caesar cipher that shifts each letter 13 positions forward in the alphabet. A becomes N, B becomes O, and so on. Because the English alphabet has 26 letters, applying ROT13 twice returns the original text — it\'s its own inverse. ROT13 is NOT encryption and provides zero security; it\'s used mainly for hiding spoilers, puzzle answers, and offensive content on forums.' },
  { question: 'Why 13 positions?', answer: '13 is exactly half of 26 (the number of letters in the English alphabet), which makes ROT13 self-inverse. The same code can both encode and decode — no need for a separate "decode" function. This makes it trivially simple to implement and use. ROT5 (for digits) and ROT47 (for printable ASCII) follow similar principles but with different character ranges.' },
  { question: 'Is ROT13 case-sensitive?', answer: 'Yes, this converter preserves case. Uppercase letters map to uppercase (A→N, N→A), and lowercase letters map to lowercase (a→n, n→a). Non-letter characters (numbers, spaces, punctuation, symbols, emoji) pass through unchanged. This preserves the readability of the original text structure.' },
]
---

<ToolLayout
  tool={tool}
  description="Free online ROT13 cipher encoder. Shift letters by 13 positions. Same tool encodes and decodes — ROT13 is its own inverse. Numbers and punctuation pass through unchanged." {steps} {faq}
>
  <div class="flex flex-wrap gap-3 mb-6">
    <button id="convertBtn" class="btn btn-primary">ROT13 Encode / Decode</button>
    <button id="sampleBtn" class="btn btn-secondary">Load Sample</button>
    <button id="clearBtn" class="btn btn-secondary">Clear</button>
  </div>

  <div class="grid lg:grid-cols-2 gap-6">
    <div class="code-panel">
      <div class="code-panel-header">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400">Input</span>
        <button id="copyInputBtn" class="btn btn-sm btn-secondary">Copy</button>
      </div>
      <textarea id="inputEl" class="code-input" placeholder="Enter text to encode/decode with ROT13..."></textarea>
    </div>
    <div class="code-panel">
      <div class="code-panel-header">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400">Output</span>
        <button id="copyOutputBtn" class="btn btn-sm btn-secondary">Copy</button>
      </div>
      <pre id="outputEl" class="code-output"></pre>
    </div>
  </div>
  <StatusMessage id="statusEl" />

  <section slot="examples" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Examples</h2>
    <div class="grid lg:grid-cols-2 gap-6">
      <div>
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 dark:text-gray-400">Original</h3>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>Hello, World!</code></pre>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-green-600 uppercase tracking-wider mb-3">ROT13</h3>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>Uryyb, Jbeyq!</code></pre>
      </div>
    </div>
  </section>

  <section slot="tutorial" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">ROT13 and the Caesar Cipher Family</h2>
    <div class="prose prose-gray max-w-none dark:prose-invert">
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">
        ROT13 is the most famous member of the Caesar cipher family, named after Julius Caesar who used ROT3 for military communications. While Caesar ciphers have zero security value today (they can be broken by hand in seconds), ROT13 found a niche on the early internet as a quick way to hide content that readers might not want to see — spoilers, puzzle solutions, punchlines, and offensive material.
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3 dark:text-white">ROT Variants</h3>
      <ul class="list-disc list-inside space-y-2 text-gray-500 dark:text-gray-400">
        <li><strong>ROT5</strong> — Shifts digits 0-9 by 5 positions (0↔5, 1↔6, etc.). Self-inverse like ROT13.</li>
        <li><strong>ROT13</strong> — Shifts A-Z/a-z by 13. The most common variant.</li>
        <li><strong>ROT18</strong> — ROT13 for letters + ROT5 for digits. Used in some Usenet communities.</li>
        <li><strong>ROT47</strong> — Shifts all printable ASCII characters (33-126) by 47 positions. More thorough obfuscation.</li>
      </ul>
    </div>
  </section>

  <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="space-y-3">
      <a href="/guides/ciphers-encoding-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Ciphers & Classic Encoding</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">ROT13, Morse code, Caesar ciphers explained.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
      <a href="/guides/string-escaping-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">String Escaping Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Escape sequences in JSON, JS, and more.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    </div>
  </section>

  <script>
    import { copyToClipboard } from '../../../utils/copyToClipboard'

    const inputEl = document.getElementById('inputEl') as HTMLTextAreaElement
    const outputEl = document.getElementById('outputEl')!

    function showStatus(msg: string, type: 'success' | 'error') {
      const el = document.getElementById('statusEl')!
      el.textContent = msg; el.classList.remove('hidden')
      el.className = type === 'success' ? 'mt-4 px-4 py-3 rounded-lg bg-green-900/40 border border-green-800 text-green-400' : 'mt-4 px-4 py-3 rounded-lg bg-red-900/40 border border-red-800 text-red-400'
      setTimeout(() => el.classList.add('hidden'), 3000)
    }

    function rot13(text: string): string {
      return text.replace(/[a-zA-Z]/g, (ch) => {
        const base = ch <= 'Z' ? 65 : 97
        return String.fromCharCode(((ch.charCodeAt(0) - base + 13) % 26) + base)
      })
    }

    document.getElementById('convertBtn')!.addEventListener('click', () => {
      const v = inputEl.value
      if (!v) { showStatus('Enter some text first', 'error'); return }
      outputEl.textContent = rot13(v)
      showStatus('Converted with ROT13!', 'success')
    })

    document.getElementById('sampleBtn')!.addEventListener('click', () => {
      inputEl.value = 'The quick brown fox jumps over the lazy dog.'
      outputEl.textContent = ''
    })

    document.getElementById('clearBtn')!.addEventListener('click', () => { inputEl.value = ''; outputEl.textContent = '' })

    document.getElementById('copyInputBtn')!.addEventListener('click', async () => {
      const ok = await copyToClipboard(inputEl.value)
      showStatus(ok ? 'Copied!' : 'Copy failed', ok ? 'success' : 'error')
    })
    document.getElementById('copyOutputBtn')!.addEventListener('click', async () => {
      const ok = await copyToClipboard(outputEl.textContent || '')
      showStatus(ok ? 'Copied!' : 'Copy failed', ok ? 'success' : 'error')
    })
  </script>
</ToolLayout>
