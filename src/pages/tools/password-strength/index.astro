---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'password-strength')!
const steps = [
  { name: 'Enter a Password', text: 'Type any password into the input field. The tool analyzes it in real-time — no data is sent anywhere.' },
  { name: 'Review the Score', text: 'The strength bar shows the overall score. A detailed checklist shows which criteria your password meets.' },
  { name: 'Improve Your Password', text: 'Use the checklist to identify weaknesses. Add length, mix character types, and avoid common words.' },
]
const faq = [
  { question: 'How is password strength calculated?', answer: 'This tool evaluates length, character variety (lowercase, uppercase, numbers, symbols), and estimates entropy. A strong password is at least 12 characters with a mix of all character types.' },
  { question: 'What is password entropy?', answer: 'Entropy measures unpredictability in bits. Higher entropy means more possible combinations. 60+ bits is considered strong. Entropy = log₂(charset^length).' },
  { question: 'Is this tool safe to use?', answer: 'Yes, all processing happens locally in your browser. Your password is never sent to any server, never stored, and never logged.' },
]
---
<ToolLayout tool={tool} description="Free password strength meter. Evaluate password security with real-time scoring. All processing is local." {steps} {faq}>
  <div class="mb-6">
    <label class="block font-medium text-gray-700 dark:text-gray-300 mb-2">Password</label>
    <input type="text" id="pwInput" class="form-input w-full bg-white border border-gray-200 text-gray-900 rounded-lg px-4 py-3 font-mono dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100" placeholder="Type a password to test...">
  </div>
  <div class="mb-6">
    <div class="h-3 bg-gray-200 rounded-full overflow-hidden dark:bg-gray-700">
      <div id="strengthBar" class="h-full rounded-full transition-all duration-300" style="width:0"></div>
    </div>
    <p class="text-center mt-2 font-bold text-gray-500" id="strengthLabel">Enter a password above</p>
  </div>
  <div class="code-panel">
    <div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Analysis</span></div>
    <div class="p-4 space-y-2" id="pwAnalysis">
      <p class="text-gray-400 text-sm">Enter a password to analyze its strength.</p>
    </div>
  </div>
  <script>
    const pwInput = document.getElementById('pwInput')!
    const strengthBar = document.getElementById('strengthBar')!
    const strengthLabel = document.getElementById('strengthLabel')!
    const pwAnalysis = document.getElementById('pwAnalysis')!
    function evaluate() {
      const pw = pwInput.value
      if (!pw) {
        strengthBar.style.width = '0'
        strengthBar.className = 'h-full rounded-full transition-all duration-300'
        strengthLabel.textContent = 'Enter a password above'
        strengthLabel.className = 'text-center mt-2 font-bold text-gray-500'
        pwAnalysis.innerHTML = '<p class="text-gray-400 text-sm">Enter a password to analyze its strength.</p>'
        return
      }
      let score = 0
      const checks: { label: string; pass: boolean }[] = []
      const hasLen8 = pw.length >= 8
      const hasLen12 = pw.length >= 12
      const hasLower = /[a-z]/.test(pw)
      const hasUpper = /[A-Z]/.test(pw)
      const hasNum = /[0-9]/.test(pw)
      const hasSym = /[^a-zA-Z0-9]/.test(pw)
      checks.push({ label: 'At least 8 characters', pass: hasLen8 }); if (hasLen8) score++
      checks.push({ label: 'At least 12 characters', pass: hasLen12 }); if (hasLen12) score++
      checks.push({ label: 'Contains lowercase', pass: hasLower }); if (hasLower) score++
      checks.push({ label: 'Contains uppercase', pass: hasUpper }); if (hasUpper) score++
      checks.push({ label: 'Contains numbers', pass: hasNum }); if (hasNum) score++
      checks.push({ label: 'Contains symbols', pass: hasSym }); if (hasSym) score++
      let charset = 0
      if (hasLower) charset += 26
      if (hasUpper) charset += 26
      if (hasNum) charset += 10
      if (hasSym) charset += 32
      const entropy = charset > 0 ? Math.log(Math.pow(charset, pw.length)) / Math.LN2 : 0
      checks.push({ label: `Entropy: ~${Math.round(entropy)} bits`, pass: entropy >= 60 }); if (entropy >= 60) score++
      const pct = Math.min(Math.round(score / checks.length * 100), 100)
      strengthBar.style.width = pct + '%'
      let color: string, label: string
      if (pct < 30) { color = 'bg-red-500'; label = 'Weak' }
      else if (pct < 60) { color = 'bg-yellow-500'; label = 'Fair' }
      else if (pct < 85) { color = 'bg-blue-500'; label = 'Strong' }
      else { color = 'bg-green-500'; label = 'Very Strong' }
      strengthBar.className = `h-full rounded-full transition-all duration-300 ${color}`
      strengthLabel.textContent = label
      strengthLabel.className = `text-center mt-2 font-bold text-${color.replace('bg-', '')}`
      pwAnalysis.innerHTML = checks.map(c =>
        `<div class="flex justify-between bg-gray-50 rounded-lg p-3 dark:bg-gray-800">
          <span class="text-gray-500 dark:text-gray-400">${c.label}</span>
          <span class="font-bold ${c.pass ? 'text-green-500' : 'text-red-400'}">${c.pass ? '✓' : '✗'}</span>
        </div>`
      ).join('')
    }
    pwInput.addEventListener('input', evaluate)
  </script>

    <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="space-y-3">
      <a href="/guides/password-hash-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Password Security Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">MD5 vs SHA-256, bcrypt, password best practices.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
      <a href="/tools/password-generator/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Password Generator</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Create strong, secure passwords.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    </div>
  </section>
</ToolLayout>