---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'color-palette')!
const steps = [
  { name: 'Pick a Base Color', text: 'Use the color picker to select your base color or type a HEX value.' },
  { name: 'Choose a Scheme', text: 'Select from complementary, analogous, triadic, or monochromatic schemes.' },
  { name: 'Copy Colors', text: 'Click any color swatch or Copy button to copy the HEX value to your clipboard.' },
]
const faq = [
  { question: 'What is a color palette?', answer: 'A color palette is a set of colors that work well together based on color theory rules: complementary (opposite), analogous (adjacent), triadic (evenly spaced), and monochromatic (variations of one hue).' },
  { question: 'Which scheme should I use?', answer: 'Complementary = high contrast for CTAs. Analogous = calming for backgrounds. Triadic = vibrant for data viz. Monochromatic = clean and professional for UI systems.' },
]
---
<ToolLayout tool={tool} description="Free color palette generator. Generate harmonious color palettes from a base color. Includes complementary, analogous, triadic, and monochromatic schemes." {steps} {faq}>
  <div class="flex flex-wrap gap-4 mb-6 items-end">
    <div><label class="block font-medium text-gray-700 dark:text-gray-300 mb-2">Base Color</label><input type="color" id="baseColor" value="#3b82f6" class="h-12 w-20 rounded-lg border-0 cursor-pointer" oninput="generate()"></div>
    <div><label class="block font-medium text-gray-700 dark:text-gray-300 mb-2">Scheme</label><select id="scheme" class="form-select bg-white border border-gray-200 text-gray-900 rounded-lg px-4 py-3 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100" onchange="generate()"><option value="complementary">Complementary</option><option value="analogous">Analogous</option><option value="triadic">Triadic</option><option value="mono">Monochromatic</option></select></div>
  </div>
  <div id="palette" class="grid grid-cols-5 gap-3 mb-6"></div>
  <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Color Values</span></div><div class="p-4 space-y-2" id="colorValues"></div></div>
  <script is:inline>
    async function copyText(text) { try { await navigator.clipboard.writeText(text) } catch {} }
    var baseColor = document.getElementById('baseColor');
    var scheme = document.getElementById('scheme');
    var palette = document.getElementById('palette');
    var colorValues = document.getElementById('colorValues');
    function hexToHsl(h) { var r = parseInt(h.slice(1,3),16)/255, g = parseInt(h.slice(3,5),16)/255, b = parseInt(h.slice(5,7),16)/255; var max = Math.max(r,g,b), min = Math.min(r,g,b); var hue = 0, sat = 0; var l = (max+min)/2; if (max!==min) { var d = max-min; sat = l>0.5?d/(2-max-min):d/(max+min); switch(max) { case r: hue = ((g-b)/d+(g<b?6:0))/6; break; case g: hue = ((b-r)/d+2)/6; break; case b: hue = ((r-g)/d+4)/6; break; } } return { h: Math.round(hue*360), s: Math.round(sat*100), l: Math.round(l*100) }; }
    function hslToHex(h, s, l) { s/=100; l/=100; var a = s*Math.min(l,1-l); function f(n) { var k = (n+h/30)%12; return Math.round((l-a*Math.max(Math.min(k-3,9-k,1),-1))*255).toString(16).padStart(2,'0'); } return '#'+f(0)+f(8)+f(4); }
    function generate() {
      var hsl = hexToHsl(baseColor.value); var h = hsl.h, s = hsl.s, l = hsl.l; var colors = [];
      switch (scheme.value) {
        case 'complementary': colors = [hslToHex(h,s,l), hslToHex((h+180)%360,s,l), hslToHex(h,s,Math.min(l+15,90)), hslToHex((h+180)%360,s,Math.min(l+15,90)), hslToHex(h,s,Math.max(l-15,10))]; break;
        case 'analogous': colors = [hslToHex((h-30+360)%360,s,l), hslToHex((h-15+360)%360,s,l), hslToHex(h,s,l), hslToHex((h+15)%360,s,l), hslToHex((h+30)%360,s,l)]; break;
        case 'triadic': colors = [hslToHex(h,s,l), hslToHex((h+120)%360,s,l), hslToHex((h+240)%360,s,l), hslToHex(h,s,Math.min(l+15,90)), hslToHex(h,s,Math.max(l-15,10))]; break;
        case 'mono': colors = [hslToHex(h,s,Math.min(l+30,95)), hslToHex(h,s,Math.min(l+15,90)), hslToHex(h,s,l), hslToHex(h,s,Math.max(l-15,10)), hslToHex(h,s,Math.max(l-30,5))]; break;
      }
      palette.innerHTML = colors.map(function(c) { return '<div class="h-24 rounded-xl cursor-pointer hover:scale-105 transition-transform" style="background:' + c + '" onclick="navigator.clipboard.writeText(\'' + c + '\')"></div>'; }).join('');
      colorValues.innerHTML = colors.map(function(c) { return '<div class="flex justify-between bg-gray-50 rounded-lg p-3 dark:bg-gray-800"><span class="text-gray-500 dark:text-gray-400">' + c + '</span><button class="btn btn-sm btn-secondary" data-clipboard="' + c + '">Copy</button></div>'; }).join('');
      document.querySelectorAll('[data-clipboard]').forEach(function(b) { b.addEventListener('click', async function() { await copyText(b.dataset.clipboard); }); });
    }
    generate();
  </script>
<section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="space-y-3">
      <a href="/guides/css-color-gradient-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">CSS Colors & Gradients Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">HEX, RGB, HSL explained. Build palettes and gradients.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
      <a href="/guides/css-color-gradient-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">CSS Colors & Gradients Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">HEX, RGB, HSL explained. Build palettes and gradients.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    </div>
  </section>
</ToolLayout>