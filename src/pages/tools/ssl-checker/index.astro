---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'ssl-checker')!
const steps = [
  { name: 'Enter a Domain', text: 'Type any domain name to check its SSL certificate.' },
  { name: 'View Certificate Details', text: 'Certificate info is displayed: issuer, valid dates, subject, and serial number.' },
]
const faq = [
  { question: 'What is an SSL certificate?', answer: 'An SSL certificate authenticates a website and enables encrypted HTTPS connections. Issued by Certificate Authorities, they have expiration dates and must be renewed.' },
  { question: 'Why do SSL certificates expire?', answer: 'Certificates expire to limit the impact of compromised keys. Most last 90 days to 1 year. Let\'s Encrypt issues 90-day certificates designed for auto-renewal.' },
  { question: 'How do I check my own certificate?', answer: 'Enter your domain in this tool. For production monitoring, set up automated alerts before certificates expire.' },
]
---
<ToolLayout tool={tool} description="Free SSL certificate checker. Check any website's SSL certificate details. Essential for security monitoring." {steps} {faq}>
  <div class="mb-6"><label class="block font-medium text-gray-700 dark:text-gray-300 mb-2">Domain</label><input type="text" id="sslDomain" class="form-input w-full bg-white border border-gray-200 text-gray-900 rounded-lg px-4 py-3 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100" placeholder="example.com"></div>
  <div class="mb-6"><button id="checkBtn" class="btn btn-primary">Check SSL</button></div>
  <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Certificate Info</span></div><div class="p-4" id="sslResult"><p class="text-gray-400 text-sm">Enter a domain and click Check SSL.</p></div></div>
  <section slot="tutorial" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">SSL Certificate Basics</h2><div class="text-gray-500 dark:text-gray-400 leading-relaxed space-y-3"><p>SSL/TLS certificates use public key cryptography for secure connections. When visiting an HTTPS site, the server presents its certificate. Your browser verifies it against trusted CAs and establishes an encrypted session.</p><p>Key fields: <strong>Subject</strong> (domain), <strong>Issuer</strong> (CA), <strong>Valid From/To</strong> (validity period), <strong>Serial Number</strong> (unique ID). Wildcard certificates cover *.example.com and all subdomains.</p></div></section>
  <script is:inline>
    var checkBtn = document.getElementById('checkBtn');
    var sslDomain = document.getElementById('sslDomain');
    var sslResult = document.getElementById('sslResult');
    async function checkSSL() {
      var domain = sslDomain.value.trim();
      if (!domain) { sslResult.innerHTML = '<p class="text-red-400 text-sm">Enter a domain name first.</p>'; return; }
      sslResult.innerHTML = '<p class="text-gray-400">Checking...</p>';
      try {
        domain = domain.replace(/^https?:\/\//, '');
        var resp = await fetch('https://' + domain, { mode: 'no-cors' });
        sslResult.innerHTML = '<div class="space-y-2 text-sm"><div class="flex justify-between bg-green-50 rounded-lg p-3 dark:bg-green-900/30"><span class="text-gray-500 dark:text-gray-400">Status</span><span class="text-green-600 font-bold dark:text-green-400">HTTPS connection successful</span></div><div class="flex justify-between bg-gray-50 rounded-lg p-3 dark:bg-gray-800"><span class="text-gray-500 dark:text-gray-400">Domain</span><span class="font-mono text-gray-900 dark:text-white">' + domain + '</span></div><p class="text-gray-400 pt-2">Note: Browser SSL APIs are limited. For full certificate details, use: <code>openssl s_client -connect ' + domain + ':443</code></p></div>';
      } catch(e) {
        sslResult.innerHTML = '<p class="text-red-400 text-sm">Could not connect. Make sure the domain is correct and supports HTTPS.</p>';
      }
    }
    checkBtn.addEventListener('click', checkSSL);
  </script>

  <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-2xl">
      <a href="/guides/ssl-certificates-guide/" class="group"><div class="bg-white border border-gray-200 rounded-xl p-5 flex gap-4 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-1 dark:text-white">SSL Certificates Explained</h4><p class="text-xs text-gray-500 mt-1 dark:text-gray-400">Certificate chains, expiry, and verification.</p></div></div></a>
      <a href="/guides/ssl-certificates-guide/" class="group"><div class="bg-white border border-gray-200 rounded-xl p-5 flex gap-4 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-1 dark:text-white">SSL Certificates Explained</h4><p class="text-xs text-gray-500 mt-1 dark:text-gray-400">Certificate chains, expiry, and verification.</p></div></div></a>
    </div>
  </section>
</ToolLayout>