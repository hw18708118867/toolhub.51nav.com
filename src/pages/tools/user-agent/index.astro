---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'user-agent')!
---
<ToolLayout tool={tool} description="Free User Agent parser. Parse any browser user agent string to see browser, OS, device, and engine details. All processing is local.">
  <div class="code-panel mb-6"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">User Agent String</span><button id="sampleBtn" class="btn btn-sm btn-secondary">Load Sample</button></div><textarea id="uaInput" class="code-input" placeholder="Paste a user agent string..." oninput="parseUA()"></textarea></div>
  <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Parsed Info</span></div><div class="p-4 space-y-2" id="uaResult"><p class="text-gray-400 text-sm">Enter a user agent string or click "Load Sample" to see your current browser info.</p></div></div>
  <section slot="examples" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Common User Agents</h2><div class="space-y-2 text-sm"><div class="bg-gray-50 border border-gray-200 rounded-lg p-3 dark:bg-gray-900 dark:border-gray-800"><p class="text-gray-500 dark:text-gray-400">Chrome on Windows:</p><code class="text-gray-700 dark:text-gray-300 text-xs break-all">Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36</code></div><div class="bg-gray-50 border border-gray-200 rounded-lg p-3 dark:bg-gray-900 dark:border-gray-800"><p class="text-gray-500 dark:text-gray-400">Safari on macOS:</p><code class="text-gray-700 dark:text-gray-300 text-xs break-all">Mozilla/5.0 (Macintosh; Intel Mac OS X 14_0) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.0 Safari/605.1.15</code></div></div></section>
  <section slot="tutorial" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Understanding User Agents</h2><div class="text-gray-500 dark:text-gray-400 leading-relaxed space-y-3"><p>A User Agent string is sent by your browser with every HTTP request. It identifies the browser, operating system, rendering engine, and device type. Websites use it for analytics, content negotiation, and device-specific optimizations.</p><p>User Agent strings follow a semi-standard format but can be complex. Most modern browsers include "Mozilla/5.0" for historical compatibility reasons. The actual browser is identified by keywords like "Chrome", "Safari", "Firefox", or "Edg".</p></div></section>
  <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-2xl">
      <a href="/guides/user-agent-guide/" class="group"><div class="bg-white border border-gray-200 rounded-xl p-5 flex gap-4 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-1 dark:text-white">User Agent Parsing</h4><p class="text-xs text-gray-500 mt-1 dark:text-gray-400">Decode browser, OS, and device from any UA string.</p></div></div></a>
      <a href="/guides/user-agent-guide/" class="group"><div class="bg-white border border-gray-200 rounded-xl p-5 flex gap-4 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-1 dark:text-white">User Agent Parsing</h4><p class="text-xs text-gray-500 mt-1 dark:text-gray-400">Decode browser, OS, and device from any UA string.</p></div></div></a>
    </div>
  </section>
  <script is:inline>
    var uaInput = document.getElementById('uaInput'); var uaResult = document.getElementById('uaResult'); var sampleBtn = document.getElementById('sampleBtn');
    function parseUA() { var ua = uaInput.value.trim(); if (!ua) { uaResult.innerHTML = '<p class="text-gray-400 text-sm">Enter a user agent string to parse it.</p>'; return; }
      var info = {};
      if (ua.indexOf('Edg/') >= 0) info['Browser'] = 'Edge'; else if (ua.indexOf('Chrome/') >= 0) info['Browser'] = 'Chrome'; else if (ua.indexOf('Firefox/') >= 0) info['Browser'] = 'Firefox'; else if (ua.indexOf('Safari/') >= 0 && ua.indexOf('Chrome') < 0) info['Browser'] = 'Safari'; else info['Browser'] = 'Unknown';
      if (ua.indexOf('Windows') >= 0) info['OS'] = 'Windows'; else if (ua.indexOf('Mac OS') >= 0) info['OS'] = 'macOS'; else if (ua.indexOf('Linux') >= 0 && ua.indexOf('Android') < 0) info['OS'] = 'Linux'; else if (ua.indexOf('Android') >= 0) info['OS'] = 'Android'; else if (ua.indexOf('iPhone') >= 0 || ua.indexOf('iPad') >= 0) info['OS'] = 'iOS'; else info['OS'] = 'Unknown';
      if (ua.indexOf('Mobile') >= 0) info['Device'] = 'Mobile'; else info['Device'] = 'Desktop';
      if (ua.indexOf('AppleWebKit') >= 0) info['Engine'] = 'WebKit/Blink'; else if (ua.indexOf('Gecko') >= 0) info['Engine'] = 'Gecko'; else info['Engine'] = 'Unknown';
      var keys = Object.keys(info); var html = '';
      for (var i = 0; i < keys.length; i++) { var k = keys[i]; html += '<div class="flex justify-between bg-gray-50 rounded-lg p-3 dark:bg-gray-800"><span class="text-gray-500 dark:text-gray-400">' + k + '</span><span class="font-mono text-gray-900 dark:text-white">' + info[k] + '</span></div>'; }
      uaResult.innerHTML = html;
    }
    sampleBtn.addEventListener('click', function() { uaInput.value = navigator.userAgent; parseUA(); });
  </script>
</ToolLayout>