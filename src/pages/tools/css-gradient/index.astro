---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'

const tool = tools.find(t => t.id === 'css-gradient')!

const steps = [
  { name: 'Choose Gradient Type', text: 'Select "Linear" for a directional gradient or "Radial" for a circular gradient. For linear gradients, you can adjust the angle from 0° to 360°.' },
  { name: 'Pick Colors', text: 'Use the color pickers to select your start and end colors. The preview updates in real-time as you adjust the colors.' },
  { name: 'Adjust Settings', text: 'For linear gradients, use the angle slider to control the direction. 0° goes bottom-to-top, 90° goes left-to-right, 180° goes top-to-bottom.' },
  { name: 'Copy CSS Code', text: 'Click "Copy CSS" to copy the generated CSS code to your clipboard. Paste it directly into your stylesheet or HTML.' },
]

const faq = [
  { question: 'What is a CSS gradient?', answer: 'A CSS gradient is a smooth transition between two or more colors. Unlike images, gradients are generated by the browser and can be used anywhere an image value is accepted in CSS. They are resolution-independent and can be animated.' },
  { question: 'Linear vs Radial gradients — which should I use?', answer: 'Linear gradients transition colors along a straight line and are ideal for backgrounds, headers, and banners. Radial gradients transition from a center point outward and work well for circular elements, spotlights, and buttons. Choose based on the visual effect you want.' },
  { question: 'Can I use more than two colors?', answer: 'Yes! CSS gradients support multiple color stops. While this tool generates two-color gradients for simplicity, you can easily add more colors to the generated CSS by adding additional color stops. For example: linear-gradient(135deg, #ff0000, #00ff00, #0000ff).' },
  { question: 'Are CSS gradients supported in all browsers?', answer: 'Yes, CSS gradients are supported in all modern browsers, including Chrome, Firefox, Safari, and Edge. For very old browsers, you may want to provide a solid color fallback using the background-color property.' },
]

---

<ToolLayout
  tool={tool}
  description="Free online CSS gradient generator. Create beautiful linear and radial gradients. Adjust colors and angles visually. Copy the generated CSS code instantly." {steps} {faq}
>
  <div id="gradPreview" class="h-40 rounded-xl mb-6"></div>
  <div class="mb-6"><label class="block font-medium text-gray-700 dark:text-gray-300 mb-3">Gradient Type</label><div class="flex gap-3"><button id="typeLinear" class="btn btn-primary">Linear</button><button id="typeRadial" class="btn btn-secondary">Radial</button></div></div>
  <div class="mb-6" id="angleGroup"><label class="block font-medium text-gray-700 dark:text-gray-300 mb-2">Angle: <span id="angleVal">135°</span></label><input type="range" id="gradAngle" min="0" max="360" value="135" class="w-full"></div>
  <div class="grid md:grid-cols-2 gap-6 mb-6">
    <div><label class="block font-medium text-gray-700 dark:text-gray-300 mb-2">Color 1</label><input type="color" id="gradColor1" value="#58a6ff" class="w-full h-12 rounded-lg border-0 cursor-pointer"></div>
    <div><label class="block font-medium text-gray-700 dark:text-gray-300 mb-2">Color 2</label><input type="color" id="gradColor2" value="#0d1117" class="w-full h-12 rounded-lg border-0 cursor-pointer"></div>
  </div>
  <div class="mb-6"><button id="copyBtn" class="btn btn-primary">Copy CSS</button></div>
  <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">CSS Code</span></div><pre id="gradCss" class="code-output"></pre></div>

  <section slot="examples" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Example Gradients</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      <div class="rounded-xl h-24" style="background: linear-gradient(135deg, #667eea, #764ba2)"></div>
      <div class="rounded-xl h-24" style="background: linear-gradient(135deg, #f093fb, #f5576c)"></div>
      <div class="rounded-xl h-24" style="background: radial-gradient(circle, #a8edea, #fed6e3)"></div>
      <div class="rounded-xl h-24" style="background: radial-gradient(circle, #ff9a9e, #fecfef)"></div>
    </div>
  </section>

  <section slot="tutorial" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">CSS Gradient Best Practices</h2>
    <div class="prose prose-gray max-w-none dark:prose-invert">
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">CSS gradients are a powerful tool for creating modern, visually appealing web designs without loading images. They're lightweight, responsive, and can be animated.</p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3 dark:text-white">Tips for Great Gradients</h3>
      <ul class="list-disc list-inside space-y-2 text-gray-500 dark:text-gray-400">
        <li>Use colors that are close on the color wheel for subtle effects</li>
        <li>Use contrasting colors for bold, dramatic backgrounds</li>
        <li>Add a solid background-color as a fallback for older browsers</li>
        <li>Combine gradients with other CSS properties like border-radius and box-shadow</li>
      </ul>
    </div>
  </section>

    <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="space-y-3">
      <a href="/guides/css-color-gradient-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">CSS Colors & Gradients Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">HEX, RGB, HSL explained. Build palettes and gradients.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
      <a href="/tools/color-picker/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Color Picker</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Pick and convert HEX, RGB, HSL colors.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    </div>
  </section>

  <script>
    import { copyToClipboard } from '../../../utils/copyToClipboard'
    let gradType = 'linear'
    const typeLinear = document.getElementById('typeLinear')!
    const typeRadial = document.getElementById('typeRadial')!
    const angleGroup = document.getElementById('angleGroup')!
    const gradAngle = document.getElementById('gradAngle')
    const angleVal = document.getElementById('angleVal')!
    const gradColor1 = document.getElementById('gradColor1')
    const gradColor2 = document.getElementById('gradColor2')
    const gradPreview = document.getElementById('gradPreview')!
    const gradCss = document.getElementById('gradCss')!
    const copyBtn = document.getElementById('copyBtn')!
    function setType(type: string) { gradType = type; typeLinear.className = 'btn ' + (type === 'linear' ? 'btn-primary' : 'btn-secondary'); typeRadial.className = 'btn ' + (type === 'radial' ? 'btn-primary' : 'btn-secondary'); angleGroup.style.display = type === 'linear' ? 'block' : 'none'; updateGradient() }
    function updateGradient() { const c1 = gradColor1.value; const c2 = gradColor2.value; const angle = gradAngle.value; let css: string; if (gradType === 'linear') { angleVal.textContent = angle + '°'; css = `background: linear-gradient(${angle}deg, ${c1}, ${c2});` } else { css = `background: radial-gradient(circle, ${c1}, ${c2});` }; gradPreview.style.cssText = css; gradCss.textContent = css }
    typeLinear.addEventListener('click', () => setType('linear')); typeRadial.addEventListener('click', () => setType('radial')); gradAngle.addEventListener('input', updateGradient); gradColor1.addEventListener('input', updateGradient); gradColor2.addEventListener('input', updateGradient)
    copyBtn.addEventListener('click', async () => { await copyToClipboard(gradCss.textContent || '') }); updateGradient()
  </script>
</ToolLayout>