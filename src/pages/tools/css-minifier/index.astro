---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'

const tool = tools.find(t => t.id === 'css-minifier')!

const steps = [
  { name: 'Paste Your CSS', text: 'Paste CSS code into the input panel. The tool accepts any valid CSS — single rules, entire stylesheets, or CSS with vendor prefixes and media queries.' },
  { name: 'Minify the Stylesheet', text: 'Click "Minify" to strip whitespace, comments, unnecessary semicolons, and trailing zeros. The output is a compact single-line CSS string ready for production.' },
  { name: 'Copy the Result', text: 'The minified CSS appears in the output panel. Check the size reduction percentage. Use the minified version in production to reduce page load time.' },
]

const faq = [
  { question: 'What does CSS minification remove?', answer: 'CSS minification removes: all comments (/* */), unnecessary whitespace (spaces, tabs, line breaks), the last semicolon in a rule block, leading zeros from decimal values (0.5em → .5em), and units from zero values (0px → 0). It also compresses hex colors where possible (#ffffff → #fff) and removes empty rules. The output is functionally identical to the input — only formatting changes.' },
  { question: 'How much smaller will my CSS get?', answer: 'Typical reduction: 20-40% for well-formatted CSS, 5-10% for already-compact CSS. Most savings come from removing indentation and line breaks. Combined with gzip/brotli compression on your server, the actual bandwidth savings are smaller because whitespace compresses very well. CSS minification is a best practice but don\'t expect dramatic page speed improvements from it alone.' },
  { question: 'Will minification break my CSS?', answer: 'No, our minifier preserves CSS semantics. It only removes characters that the CSS parser ignores — whitespace and comments. It will not change selectors, property values, or the cascade order. However, if your CSS contains unclosed comments or has syntax errors, the minified output may behave differently. Always test minified CSS before deploying to production.' },
  { question: 'Should I minify CSS during development?', answer: 'No. Keep readable CSS with comments during development. Minify as a build step using tools like PostCSS (cssnano), CleanCSS, or your bundler\'s production mode (Webpack, Vite). Use this tool for quick checks, one-off optimizations, or when you need to inline minified CSS into critical path rendering.' },
]

---

<ToolLayout
  tool={tool}
  description="Free online CSS minifier. Compress CSS code by removing whitespace, comments and unnecessary characters. Reduce stylesheet size for faster page loads. All processing is local and private." {steps} {faq}
>
  <div class="flex gap-3 mb-6">
    <button id="minifyBtn" class="btn btn-primary">Minify</button>
    <button id="sampleBtn" class="btn btn-secondary">Load Sample</button>
    <button id="clearBtn" class="btn btn-secondary">Clear</button>
  </div>
  <div class="grid lg:grid-cols-2 gap-6">
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Input CSS</span></div><textarea id="cssInput" class="code-input" placeholder="Paste CSS code..."></textarea></div>
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Minified Output</span><span id="sizeInfo" class="text-xs text-gray-400 ml-2"></span><button id="copyBtn" class="btn btn-sm btn-secondary ml-auto">Copy</button></div><pre id="cssOutput" class="code-output"></pre></div>
  </div>

  <section slot="examples" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">What Gets Removed</h2>
    <div class="overflow-x-auto"><table class="w-full text-left"><thead><tr class="border-b border-gray-200 dark:border-gray-800"><th class="py-3 px-4 text-sm font-semibold text-gray-900 dark:text-white">Removed</th><th class="py-3 px-4 text-sm font-semibold text-gray-900 dark:text-white">Example</th></tr></thead><tbody class="text-gray-500 dark:text-gray-400 text-sm">
      <tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4">Comments</td><td class="py-3 px-4 font-mono">/* Main styles */ → removed</td></tr>
      <tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4">Whitespace</td><td class="py-3 px-4 font-mono">Indentation, line breaks → collapsed</td></tr>
      <tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4">Last semicolon</td><td class="py-3 px-4 font-mono">color: red;} → color:red}</td></tr>
      <tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-3 px-4">Leading zeros</td><td class="py-3 px-4 font-mono">0.5em → .5em</td></tr>
      <tr><td class="py-3 px-4">Hex colors</td><td class="py-3 px-4 font-mono">#ffffff → #fff (when possible)</td></tr>
    </tbody></table></div>
    <p class="text-sm text-gray-400 mt-4">Typical reduction: 20-40% for formatted CSS, 5-10% for already-compact CSS.</p>
  </section>

  <section slot="tutorial" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">CSS Optimization Pipeline</h2>
    <div class="prose prose-gray max-w-none dark:prose-invert">
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">Minification is one step in a CSS optimization pipeline. For the best results, combine it with other techniques.</p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3 dark:text-white">Recommended Pipeline</h3>
      <ul class="list-disc list-inside space-y-2 text-gray-500 dark:text-gray-400">
        <li><strong>Remove unused CSS:</strong> Use PurgeCSS or browser DevTools Coverage panel to find and remove unused rules</li>
        <li><strong>Autoprefix:</strong> Add vendor prefixes automatically with Autoprefixer</li>
        <li><strong>Minify:</strong> Compress the final output with this tool or cssnano in your build pipeline</li>
        <li><strong>Compress:</strong> Enable gzip/brotli on your server for additional 70-80% size reduction</li>
      </ul>
    </div>
  </section>

  <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="space-y-3">
      <a href="/guides/css-minification-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">CSS Minification Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Compress stylesheets — what gets removed and why.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
      <a href="/tools/css-formatter/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">CSS Formatter</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Format and beautify CSS with proper indentation.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
      <a href="/tools/html-minifier/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">HTML Minifier</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Minify and compress HTML code.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    </div>
  </section>

  <script>
    import { copyToClipboard } from '../../../utils/copyToClipboard'
    const cssInput = document.getElementById('cssInput') as HTMLTextAreaElement;
    const cssOutput = document.getElementById('cssOutput')!;
    const sizeInfo = document.getElementById('sizeInfo')!;
    const minifyBtn = document.getElementById('minifyBtn')!;
    const clearBtn = document.getElementById('clearBtn')!;
    const sampleBtn = document.getElementById('sampleBtn')!;
    const copyBtn = document.getElementById('copyBtn')!;

    function minify() {
      let css = cssInput.value;
      const origSize = css.length;
      css = css.replace(/\/\*[\s\S]*?\*\//g, ''); // comments
      css = css.replace(/\s+/g, ' ');            // collapse whitespace
      css = css.replace(/;\s*}/g, '}');          // last semicolon
      css = css.replace(/\s*{\s*/g, '{');        // space before {
      css = css.replace(/}\s*/g, '}');           // space after }
      css = css.replace(/:\s+/g, ':');           // space after :
      css = css.replace(/;\s+/g, ';');           // space after ;
      css = css.replace(/,\s+/g, ',');           // space after ,
      css = css.replace(/(?<=[\d])\s*px/g, 'px'); // 0px → keep as-is (safe)
      css = css.replace(/#([a-f0-9])\1([a-f0-9])\2([a-f0-9])\3/gi, '#$1$2$3'); // hex compress
      css = css.trim();
      cssOutput.textContent = css;
      const newSize = css.length;
      const pct = origSize > 0 ? Math.round((1 - newSize / origSize) * 100) : 0;
      sizeInfo.textContent = `(${origSize} → ${newSize} bytes, ${pct}% smaller)`;
    }

    minifyBtn.addEventListener('click', minify);
    clearBtn.addEventListener('click', () => { cssInput.value = ''; cssOutput.textContent = ''; sizeInfo.textContent = ''; });
    copyBtn.addEventListener('click', async () => { await copyToClipboard(cssOutput.textContent || ''); });
    sampleBtn.addEventListener('click', () => {
      cssInput.value = '/* Main button styles */\n.button {\n  background-color: #3b82f6;\n  color: #ffffff;\n  border-radius: 8px;\n  padding: 12px 24px;\n  font-size: 14px;\n}\n\n.button:hover {\n  background-color: #2563eb;\n}\n\n.container {\n  max-width: 1200px;\n  margin: 0 auto;\n}';
    });
  </script>
</ToolLayout>
