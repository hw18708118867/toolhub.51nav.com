---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import StatusMessage from '../../../components/StatusMessage.astro'
import { tools } from '../../../data/tools'

const tool = tools.find(t => t.id === 'base64-image-viewer')!

const steps = [
  { name: 'Paste Your Base64 String', text: 'Paste a Base64-encoded image string into the input area. It can be a raw Base64 string or a full data URI (starting with data:image/...).' },
  { name: 'Click Decode', text: 'Click "View Image" to decode the Base64 string and display the image. The tool automatically detects the image format from the data URI or the Base64 header bytes.' },
  { name: 'View and Download', text: 'The decoded image appears in the preview area. You can see the image dimensions, file size, and MIME type. Right-click to save the image to your computer.' },
]

const faq = [
  { question: 'What format should the Base64 string be in?', answer: 'You can paste either a raw Base64 string or a full data URI (e.g., data:image/png;base64,iVBORw0KGgo...). The tool handles both formats. If pasting a raw Base64 string, the tool attempts to detect the image format automatically.' },
  { question: 'What image formats are supported?', answer: 'PNG, JPEG, GIF, WebP, SVG, BMP, and ICO are all supported. The browser handles the actual decoding, so any format your browser can display will work here.' },
  { question: 'Is my image data secure?', answer: 'Yes — all processing happens locally in your browser. The Base64 string is never uploaded to any server. The image is rendered directly in your browser using a data URI.' },
]
---

<ToolLayout
  tool={tool}
  description="Free online Base64 Image Viewer. Decode and view Base64-encoded images instantly. Paste a Base64 string to see the image. All processing is local and private." {steps} {faq}
>
  <div class="code-panel mb-4">
    <div class="code-panel-header">
      <span class="text-sm font-medium text-gray-500 dark:text-gray-400">Base64 String</span>
      <div class="flex gap-2">
        <button id="sampleBtn" class="btn btn-sm btn-secondary">Load Sample</button>
        <button id="clearBtn" class="btn btn-sm btn-secondary">Clear</button>
      </div>
    </div>
    <textarea id="inputEl" class="code-input" placeholder="Paste Base64 image string or data URI here..."></textarea>
  </div>

  <div class="flex flex-wrap gap-3 mb-6">
    <button id="viewBtn" class="btn btn-primary">View Image</button>
  </div>

  <StatusMessage id="statusEl" />

  <div id="resultArea" class="hidden">
    <div class="bg-gray-50 border border-gray-200 rounded-2xl p-6 dark:bg-gray-800 dark:border-gray-700">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Image Preview</h3>
        <div class="flex gap-2">
          <button id="downloadBtn" class="btn btn-sm btn-secondary">Download</button>
          <button id="copyDataUriBtn" class="btn btn-sm btn-secondary">Copy Data URI</button>
        </div>
      </div>
      <div class="flex justify-center mb-4 bg-white rounded-xl p-4 border border-gray-100 dark:bg-gray-900 dark:border-gray-700" style="background-image: linear-gradient(45deg, #f0f0f0 25%, transparent 25%, transparent 75%, #f0f0f0 75%, #f0f0f0), linear-gradient(45deg, #f0f0f0 25%, transparent 25%, transparent 75%, #f0f0f0 75%, #f0f0f0); background-size: 20px 20px; background-position: 0 0, 10px 10px;">
        <img id="imgPreview" class="max-w-full max-h-96 object-contain rounded-lg" alt="Decoded preview">
      </div>
      <div id="imgMeta" class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
        <div class="bg-white rounded-lg p-3 dark:bg-gray-900"><span class="text-gray-400 text-xs uppercase tracking-wider">Format</span><div id="metaFormat" class="font-semibold text-gray-900 dark:text-white mt-0.5">-</div></div>
        <div class="bg-white rounded-lg p-3 dark:bg-gray-900"><span class="text-gray-400 text-xs uppercase tracking-wider">Dimensions</span><div id="metaDimensions" class="font-semibold text-gray-900 dark:text-white mt-0.5">-</div></div>
        <div class="bg-white rounded-lg p-3 dark:bg-gray-900"><span class="text-gray-400 text-xs uppercase tracking-wider">Size</span><div id="metaSize" class="font-semibold text-gray-900 dark:text-white mt-0.5">-</div></div>
        <div class="bg-white rounded-lg p-3 dark:bg-gray-900"><span class="text-gray-400 text-xs uppercase tracking-wider">MIME Type</span><div id="metaMime" class="font-semibold text-gray-900 dark:text-white mt-0.5">-</div></div>
      </div>
    </div>
  </div>

  <section slot="tutorial" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Decoding Base64 Images in Practice</h2>
    <div class="prose prose-gray max-w-none dark:prose-invert">
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">
        Base64-encoded images show up in many places: API responses, database fields, HTML data URIs, and CSS inline images. Being able to quickly decode and view them saves time when debugging or inspecting data. Instead of writing a script or opening a dev tool, just paste the string here and see the image.
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3 dark:text-white">Where You'll Encounter Base64 Images</h3>
      <ul class="list-disc list-inside space-y-2 text-gray-500 dark:text-gray-400">
        <li>REST API responses that embed images as Base64 strings</li>
        <li>HTML <code>&lt;img src="data:image/png;base64,..."&gt;</code> tags</li>
        <li>CSS <code>background-image: url(data:...)</code> declarations</li>
        <li>Database BLOB fields exported as Base64 text</li>
        <li>Email attachments encoded in MIME format</li>
      </ul>
    </div>
  </section>

  <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-2xl">
      <a href="/guides/base64-image-guide/" class="group"><div class="bg-white border border-gray-200 rounded-xl p-5 flex gap-4 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-1 dark:text-white">Base64 Image Guide</h4><p class="text-xs text-gray-500 mt-1 dark:text-gray-400">When and how to use Base64 images, data URIs, and decoding.</p></div></div></a>
      <a href="/guides/web-encoding-guide/" class="group"><div class="bg-white border border-gray-200 rounded-xl p-5 flex gap-4 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-1 dark:text-white">Web Encoding Explained</h4><p class="text-xs text-gray-500 mt-1 dark:text-gray-400">Base64, URL encoding, HTML entities — when and how to use each.</p></div></div></a>
    </div>
  </section>

  <script>
    import { copyToClipboard } from '../../../utils/copyToClipboard'

    const inputEl = document.getElementById('inputEl') as HTMLTextAreaElement
    const resultArea = document.getElementById('resultArea')!
    const imgPreview = document.getElementById('imgPreview') as HTMLImageElement
    let currentDataUri = ''

    function showStatus(msg: string, type: 'success' | 'error') {
      const el = document.getElementById('statusEl')!
      el.textContent = msg; el.classList.remove('hidden')
      el.className = type === 'success' ? 'mt-4 px-4 py-3 rounded-lg bg-green-900/40 border border-green-800 text-green-400' : 'mt-4 px-4 py-3 rounded-lg bg-red-900/40 border border-red-800 text-red-400'
      setTimeout(() => el.classList.add('hidden'), 4000)
    }

    function formatBytes(bytes: number): string {
      if (bytes < 1024) return bytes + ' B'
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB'
      return (bytes / (1024 * 1024)).toFixed(1) + ' MB'
    }

    function getMimeFromDataUri(uri: string): string {
      const m = uri.match(/^data:([^;]+)/)
      return m ? m[1] : 'unknown'
    }

    function getExtFromMime(mime: string): string {
      const map: Record<string, string> = {
        'image/png': 'png', 'image/jpeg': 'jpg', 'image/gif': 'gif',
        'image/webp': 'webp', 'image/svg+xml': 'svg', 'image/bmp': 'bmp',
        'image/x-icon': 'ico', 'image/vnd.microsoft.icon': 'ico'
      }
      return map[mime] || 'png'
    }

    function viewImage() {
      const v = inputEl.value.trim()
      if (!v) { showStatus('Paste a Base64 string or data URI first', 'error'); return }

      try {
        let dataUri = v
        // If it's raw Base64 (no data: prefix), wrap it
        if (!v.startsWith('data:')) {
          // Clean the string: remove whitespace, newlines
          const cleaned = v.replace(/\s/g, '')
          // Try to detect format from Base64 magic bytes
          dataUri = 'data:image/png;base64,' + cleaned
        }

        imgPreview.onload = () => {
          const mime = getMimeFromDataUri(dataUri)
          const ext = getExtFromMime(mime)
          document.getElementById('metaFormat')!.textContent = ext.toUpperCase()
          document.getElementById('metaDimensions')!.textContent = imgPreview.naturalWidth + ' × ' + imgPreview.naturalHeight
          // Estimate Base64 size
          const b64Part = dataUri.includes('base64,') ? dataUri.split('base64,')[1] : v
          const byteSize = Math.round(b64Part.length * 0.75)
          document.getElementById('metaSize')!.textContent = formatBytes(byteSize)
          document.getElementById('metaMime')!.textContent = mime
          resultArea.classList.remove('hidden')
          currentDataUri = dataUri
          showStatus('Image decoded!', 'success')
        }
        imgPreview.onerror = () => {
          // Try with the original string as-is
          if (!v.startsWith('data:')) {
            // Try common image types
            const types = ['image/png', 'image/jpeg', 'image/gif', 'image/webp', 'image/svg+xml', 'image/bmp']
            let loaded = false
            const cleaned = v.replace(/\s/g, '')
            for (const t of types) {
              if (loaded) break
              const uri = 'data:' + t + ';base64,' + cleaned
              imgPreview.src = uri
            }
          }
          if (!imgPreview.complete || imgPreview.naturalWidth === 0) {
            showStatus('Could not decode the Base64 string as an image. Check that the string is valid.', 'error')
          }
        }
        imgPreview.src = dataUri
      } catch (e) {
        showStatus('Error: ' + (e as Error).message, 'error')
      }
    }

    document.getElementById('viewBtn')!.addEventListener('click', viewImage)

    document.getElementById('sampleBtn')!.addEventListener('click', () => {
      // Tiny 1x1 red pixel PNG in Base64
      inputEl.value = 'data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mP8/5+hHgAHggJ/PchI7wAAAABJRU5ErkJggg=='
    })

    document.getElementById('clearBtn')!.addEventListener('click', () => {
      inputEl.value = ''
      resultArea.classList.add('hidden')
      currentDataUri = ''
    })

    document.getElementById('downloadBtn')!.addEventListener('click', () => {
      if (!currentDataUri) return
      const mime = getMimeFromDataUri(currentDataUri)
      const ext = getExtFromMime(mime)
      const a = document.createElement('a')
      a.href = currentDataUri
      a.download = 'image.' + ext
      a.click()
    })

    document.getElementById('copyDataUriBtn')!.addEventListener('click', async () => {
      if (!currentDataUri) return
      const ok = await copyToClipboard(currentDataUri)
      showStatus(ok ? 'Data URI copied!' : 'Copy failed', ok ? 'success' : 'error')
    })
  </script>
</ToolLayout>
