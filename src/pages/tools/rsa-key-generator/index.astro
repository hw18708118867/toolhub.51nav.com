---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'rsa-key-generator')!
const steps = [
  { name: 'Choose Key Size', text: 'Select the RSA key size — 2048-bit (standard), 3072-bit (high security), or 4096-bit (maximum). Larger keys are more secure but slower to generate and use.' },
  { name: 'Generate the Key Pair', text: 'Click "Generate Keys" to create a new RSA public/private key pair. Generation uses the Web Crypto API and may take a few seconds for larger key sizes.' },
  { name: 'Copy the Keys', text: 'Copy the public key (safe to share) and private key (keep secret). Keys are in PEM format — compatible with OpenSSL, SSH, and most crypto libraries.' },
]
const faq = [
  { question: 'What is RSA?', answer: 'RSA (Rivest-Shamir-Adleman) is the most widely used public-key cryptosystem. It generates a key pair: a public key (used for encryption and signature verification) and a private key (used for decryption and signing). RSA security is based on the mathematical difficulty of factoring large prime numbers. RSA-2048 is considered secure through 2030; RSA-4096 offers longer-term protection.' },
  { question: 'What key size should I use?', answer: 'RSA-2048 is the minimum and most widely deployed. It meets NIST and FIPS security requirements. RSA-3072 provides additional security margin. RSA-4096 is maximum security but significantly slower — generation can take 20+ seconds. For most applications, RSA-2048 is sufficient. For long-term secrets or compliance requirements, use RSA-3072 or RSA-4096.' },
  { question: 'Where can I use these keys?', answer: 'PEM-format keys work with OpenSSL, nginx, Apache, Node.js (crypto module), Python (cryptography), SSH (rsa keys), TLS certificates, JWT signing, and virtually any system that supports RSA. The public key goes in certificates and server configs. The private key stays on your server, encrypted at rest, never shared.' },
]
---
<ToolLayout tool={tool} description="Free online RSA key generator. Generate RSA-2048, 3072 or 4096 key pairs in PEM format. Uses Web Crypto API. Public and private keys for encryption and signing. All processing is local and private." {steps} {faq}>
  <div class="mb-6 space-y-4"><div class="flex items-center gap-4"><label class="text-sm text-gray-600 dark:text-gray-400">Key Size:</label><select id="keySize" class="form-select bg-white border border-gray-200 rounded-lg px-3 py-2 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100"><option value="2048" selected>2048-bit</option><option value="3072">3072-bit</option><option value="4096">4096-bit</option></select><button id="generateBtn" class="btn btn-primary">Generate Keys</button></div></div>
  <div class="grid lg:grid-cols-2 gap-6"><div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-green-600 dark:text-green-400">Public Key</span><button id="copyPub" class="btn btn-sm btn-secondary ml-auto">Copy</button></div><pre id="pubKey" class="code-output text-xs">Click "Generate Keys" to create a key pair.</pre></div><div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-red-500 dark:text-red-400">Private Key</span><button id="copyPriv" class="btn btn-sm btn-secondary ml-auto">Copy</button></div><pre id="privKey" class="code-output text-xs">Keep this secret. Never share your private key.</pre></div></div>
  <section slot="relatedArticles" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2><div class="space-y-3">
      <a href="/guides/crypto-tools-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Crypto Tools Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Hashing, HMAC, encryption and password security.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/aes-encrypt/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">AES Encrypt/Decrypt</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Encrypt and decrypt text with AES-256.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/hmac-generator/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">HMAC Generator</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Generate HMAC with SHA-256 and SHA-512.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
  </div></section>
  <script>
    const keySize=document.getElementById('keySize') as HTMLSelectElement,generateBtn=document.getElementById('generateBtn')!,pubKey=document.getElementById('pubKey')!,privKey=document.getElementById('privKey')!,copyPub=document.getElementById('copyPub')!,copyPriv=document.getElementById('copyPriv')!;
    function spkiToPEM(b:ArrayBuffer):string{const d=btoa(String.fromCharCode(...new Uint8Array(b)));return'-----BEGIN PUBLIC KEY-----\n'+d.match(/.{1,64}/g)!.join('\n')+'\n-----END PUBLIC KEY-----'}
    function pkcs8ToPEM(b:ArrayBuffer):string{const d=btoa(String.fromCharCode(...new Uint8Array(b)));return'-----BEGIN PRIVATE KEY-----\n'+d.match(/.{1,64}/g)!.join('\n')+'\n-----END PRIVATE KEY-----'}
    generateBtn.addEventListener('click',async()=>{
      pubKey.textContent='Generating keys...';privKey.textContent='This may take a few seconds for larger key sizes.';
      try{
        const kp=await crypto.subtle.generateKey({name:'RSA-OAEP',modulusLength:parseInt(keySize.value),publicExponent:new Uint8Array([1,0,1]),hash:'SHA-256'},true,['encrypt','decrypt']);
        const pub=await crypto.subtle.exportKey('spki',kp.publicKey);const priv=await crypto.subtle.exportKey('pkcs8',kp.privateKey);
        pubKey.textContent=spkiToPEM(pub);privKey.textContent=pkcs8ToPEM(priv)
      }catch(e){pubKey.textContent='Generation failed. Try a smaller key size or reload the page.';privKey.textContent=''}
    })
    copyPub.addEventListener('click',()=>navigator.clipboard.writeText(pubKey.textContent||''))
    copyPriv.addEventListener('click',()=>navigator.clipboard.writeText(privKey.textContent||''))
  </script>
</ToolLayout>
