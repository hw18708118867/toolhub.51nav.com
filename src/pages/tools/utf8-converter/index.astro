---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import StatusMessage from '../../../components/StatusMessage.astro'
import { tools } from '../../../data/tools'

const tool = tools.find(t => t.id === 'utf8-converter')!

const steps = [
  { name: 'Enter Your Text', text: 'Type or paste text into the input panel. You can enter regular text to see its UTF-8 byte representation, or paste hex bytes to decode back to text.' },
  { name: 'Choose Direction', text: 'Click "Encode to UTF-8 Bytes" to see the raw byte sequence for your text, or "Decode from Bytes" to convert hex bytes back to readable text.' },
  { name: 'Inspect and Use', text: 'Each byte is shown in hex. For multi-byte characters (like Chinese or emoji), you can see exactly which bytes make up each character — useful for debugging encoding issues.' },
]

const faq = [
  { question: 'What is UTF-8?', answer: 'UTF-8 is a variable-length character encoding for Unicode. It uses 1 byte for ASCII characters (0-127), 2 bytes for most Latin-script extensions, 3 bytes for most CJK characters, and 4 bytes for emoji and rare characters. It\'s backward-compatible with ASCII and is the dominant encoding on the web (used by over 98% of websites).' },
  { question: 'How can I tell how many bytes a character uses in UTF-8?', answer: 'Look at the first byte: if it starts with 0 (0x00-0x7F), it\'s a 1-byte ASCII char. If it starts with 110 (0xC0-0xDF), it\'s the first of 2 bytes. If it starts with 1110 (0xE0-0xEF), 3 bytes. If it starts with 11110 (0xF0-0xF7), 4 bytes. Continuation bytes always start with 10 (0x80-0xBF).' },
  { question: 'When would I need to inspect UTF-8 bytes?', answer: 'UTF-8 byte inspection helps when: debugging character encoding bugs (garbled text, mojibake), validating that a system handles multi-byte characters correctly, working with binary file formats that store text as UTF-8, and understanding why a string\'s byte length differs from its character count.' },
]
---

<ToolLayout
  tool={tool}
  description="Free online UTF-8 encoder and decoder. See the raw byte representation of any text in UTF-8. Decode hex bytes back to readable characters. UTF-8 debugging made easy." {steps} {faq}
>
  <div class="flex flex-wrap gap-3 mb-6">
    <button id="encodeBtn" class="btn btn-primary">Encode to UTF-8 Bytes</button>
    <button id="decodeBtn" class="btn btn-secondary">Decode from Bytes</button>
    <button id="sampleBtn" class="btn btn-secondary">Load Sample</button>
    <button id="clearBtn" class="btn btn-secondary">Clear</button>
  </div>

  <div class="grid lg:grid-cols-2 gap-6">
    <div class="code-panel">
      <div class="code-panel-header">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400" id="inputLabel">Text</span>
        <button id="copyInputBtn" class="btn btn-sm btn-secondary">Copy</button>
      </div>
      <textarea id="inputEl" class="code-input" placeholder="Enter text or hex byte sequence..."></textarea>
    </div>
    <div class="code-panel">
      <div class="code-panel-header">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400" id="outputLabel">UTF-8 Bytes (Hex)</span>
        <button id="copyOutputBtn" class="btn btn-sm btn-secondary">Copy</button>
      </div>
      <pre id="outputEl" class="code-output"></pre>
    </div>
  </div>

  <!-- Byte Analysis -->
  <div id="analysisArea" class="hidden mt-6">
    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 dark:text-gray-400">Byte Breakdown</h3>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-4">
      <div class="bg-white border border-gray-200 rounded-xl p-4 dark:bg-gray-800 dark:border-gray-700">
        <div class="text-2xl font-bold text-blue-600 dark:text-blue-400" id="statChars">0</div>
        <div class="text-xs text-gray-400 mt-1">Characters</div>
      </div>
      <div class="bg-white border border-gray-200 rounded-xl p-4 dark:bg-gray-800 dark:border-gray-700">
        <div class="text-2xl font-bold text-green-600 dark:text-green-400" id="statBytes">0</div>
        <div class="text-xs text-gray-400 mt-1">Total Bytes</div>
      </div>
      <div class="bg-white border border-gray-200 rounded-xl p-4 dark:bg-gray-800 dark:border-gray-700">
        <div class="text-2xl font-bold text-purple-600 dark:text-purple-400" id="statAscii">0</div>
        <div class="text-xs text-gray-400 mt-1">ASCII (1-byte)</div>
      </div>
      <div class="bg-white border border-gray-200 rounded-xl p-4 dark:bg-gray-800 dark:border-gray-700">
        <div class="text-2xl font-bold text-orange-600 dark:text-orange-400" id="statMulti">0</div>
        <div class="text-xs text-gray-400 mt-1">Multi-byte chars</div>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200 dark:border-gray-700">
            <th class="text-left py-2 px-3 text-gray-500 font-medium dark:text-gray-400">Char</th>
            <th class="text-left py-2 px-3 text-gray-500 font-medium dark:text-gray-400">Code Point</th>
            <th class="text-left py-2 px-3 text-gray-500 font-medium dark:text-gray-400">UTF-8 Bytes</th>
            <th class="text-left py-2 px-3 text-gray-500 font-medium dark:text-gray-400">Byte Count</th>
          </tr>
        </thead>
        <tbody id="byteTable"></tbody>
      </table>
    </div>
  </div>

  <StatusMessage id="statusEl" />

  <section slot="examples" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Examples</h2>
    <div class="grid lg:grid-cols-2 gap-6">
      <div>
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 dark:text-gray-400">Text</h3>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>Hello 世界 🌍</code></pre>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-green-600 uppercase tracking-wider mb-3">UTF-8 Bytes</h3>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>48 65 6C 6C 6F 20 E4 B8 96 E7 95 8C 20 F0 9F 8C 8D</code></pre>
      </div>
    </div>
  </section>

  <section slot="tutorial" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Understanding UTF-8 Encoding</h2>
    <div class="prose prose-gray max-w-none dark:prose-invert">
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">
        UTF-8 is brilliantly designed. ASCII characters (the most common on the web) use exactly one byte — identical to their ASCII representation. This means every ASCII document is automatically valid UTF-8. For characters beyond ASCII, UTF-8 uses a leading byte that indicates how many bytes follow, with continuation bytes that can't be confused with the start of a new character.
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3 dark:text-white">Byte Patterns</h3>
      <ul class="list-disc list-inside space-y-2 text-gray-500 dark:text-gray-400">
        <li><strong>1 byte</strong>: 0xxxxxxx (U+0000 to U+007F) — ASCII</li>
        <li><strong>2 bytes</strong>: 110xxxxx 10xxxxxx (U+0080 to U+07FF) — Latin extensions, Greek, Arabic</li>
        <li><strong>3 bytes</strong>: 1110xxxx 10xxxxxx 10xxxxxx (U+0800 to U+FFFF) — CJK, Hindi, most common scripts</li>
        <li><strong>4 bytes</strong>: 11110xxx 10xxxxxx 10xxxxxx 10xxxxxx (U+10000+) — Emoji, rare characters</li>
      </ul>
    </div>
  </section>

  <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-2xl">
      <a href="/guides/character-encoding-guide/" class="group"><div class="bg-white border border-gray-200 rounded-xl p-5 flex gap-4 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-1 dark:text-white">Character Encoding Guide</h4><p class="text-xs text-gray-500 mt-1 dark:text-gray-400">Unicode, UTF-8, ASCII — master character encoding.</p></div></div></a>
      <a href="/guides/string-escaping-guide/" class="group"><div class="bg-white border border-gray-200 rounded-xl p-5 flex gap-4 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-1 dark:text-white">String Escaping Guide</h4><p class="text-xs text-gray-500 mt-1 dark:text-gray-400">Escape sequences in JSON, JS, and more.</p></div></div></a>
    </div>
  </section>

  <script>
    import { copyToClipboard } from '../../../utils/copyToClipboard'

    const inputEl = document.getElementById('inputEl') as HTMLTextAreaElement
    const outputEl = document.getElementById('outputEl')!
    const inputLabel = document.getElementById('inputLabel')!
    const outputLabel = document.getElementById('outputLabel')!
    const analysisArea = document.getElementById('analysisArea')!
    const byteTable = document.getElementById('byteTable')!

    function showStatus(msg: string, type: 'success' | 'error') {
      const el = document.getElementById('statusEl')!
      el.textContent = msg; el.classList.remove('hidden')
      el.className = type === 'success' ? 'mt-4 px-4 py-3 rounded-lg bg-green-900/40 border border-green-800 text-green-400' : 'mt-4 px-4 py-3 rounded-lg bg-red-900/40 border border-red-800 text-red-400'
      setTimeout(() => el.classList.add('hidden'), 3000)
    }

    function encodeUtf8(text: string): string {
      const bytes = new TextEncoder().encode(text)
      return Array.from(bytes).map(b => b.toString(16).toUpperCase().padStart(2, '0')).join(' ')
    }

    function decodeUtf8(hex: string): string {
      const cleaned = hex.replace(/\s/g, '').replace(/0x/gi, '').replace(/[^0-9a-fA-F]/g, '')
      if (cleaned.length % 2 !== 0) throw new Error('Hex string must have an even number of characters')
      const bytes: number[] = []
      for (let i = 0; i < cleaned.length; i += 2) {
        bytes.push(parseInt(cleaned.substring(i, i + 2), 16))
      }
      return new TextDecoder('utf-8', { fatal: true }).decode(new Uint8Array(bytes))
    }

    function showAnalysis(text: string) {
      const chars = Array.from(text)
      if (chars.length === 0 || chars.length > 100) {
        analysisArea.classList.add('hidden')
        return
      }

      const encoder = new TextEncoder()
      let asciiCount = 0, multiCount = 0

      byteTable.innerHTML = chars.map(ch => {
        const code = ch.codePointAt(0) ?? 0
        const bytes = encoder.encode(ch)
        const hexBytes = Array.from(bytes).map(b => b.toString(16).toUpperCase().padStart(2, '0')).join(' ')
        if (bytes.length === 1) asciiCount++
        else multiCount++
        return `<tr class="border-b border-gray-100 dark:border-gray-800">
          <td class="py-2 px-3 font-mono font-bold text-gray-900 dark:text-white">${ch === ' ' ? '␣' : ch}</td>
          <td class="py-2 px-3 font-mono text-blue-600 dark:text-blue-400">U+${code.toString(16).toUpperCase().padStart(4, '0')}</td>
          <td class="py-2 px-3 font-mono text-gray-500 dark:text-gray-400">${hexBytes}</td>
          <td class="py-2 px-3 font-mono ${bytes.length > 1 ? 'text-orange-500' : 'text-gray-400'}">${bytes.length}</td>
        </tr>`
      }).join('')

      const totalBytes = new TextEncoder().encode(text).length
      document.getElementById('statChars')!.textContent = String(chars.length)
      document.getElementById('statBytes')!.textContent = String(totalBytes)
      document.getElementById('statAscii')!.textContent = String(asciiCount)
      document.getElementById('statMulti')!.textContent = String(multiCount)

      analysisArea.classList.remove('hidden')
    }

    document.getElementById('encodeBtn')!.addEventListener('click', () => {
      const v = inputEl.value
      if (!v) { showStatus('Enter some text first', 'error'); return }
      inputLabel.textContent = 'Text'
      outputLabel.textContent = 'UTF-8 Bytes (Hex)'
      outputEl.textContent = encodeUtf8(v)
      showAnalysis(v)
      showStatus('Encoded to UTF-8 bytes!', 'success')
    })

    document.getElementById('decodeBtn')!.addEventListener('click', () => {
      const v = inputEl.value.trim()
      if (!v) { showStatus('Enter hex bytes first', 'error'); return }
      try {
        inputLabel.textContent = 'Hex Bytes'
        outputLabel.textContent = 'Text'
        const text = decodeUtf8(v)
        outputEl.textContent = text
        showAnalysis(text)
        showStatus('Decoded from UTF-8!', 'success')
      } catch (e) {
        showStatus('Invalid UTF-8 bytes: ' + (e as Error).message, 'error')
      }
    })

    document.getElementById('sampleBtn')!.addEventListener('click', () => {
      inputEl.value = 'Hello 世界 🌍'
      outputEl.textContent = ''
      analysisArea.classList.add('hidden')
      inputLabel.textContent = 'Text'
      outputLabel.textContent = 'UTF-8 Bytes (Hex)'
    })

    document.getElementById('clearBtn')!.addEventListener('click', () => { inputEl.value = ''; outputEl.textContent = ''; analysisArea.classList.add('hidden') })

    document.getElementById('copyInputBtn')!.addEventListener('click', async () => {
      const ok = await copyToClipboard(inputEl.value)
      showStatus(ok ? 'Copied!' : 'Copy failed', ok ? 'success' : 'error')
    })
    document.getElementById('copyOutputBtn')!.addEventListener('click', async () => {
      const ok = await copyToClipboard(outputEl.textContent || '')
      showStatus(ok ? 'Copied!' : 'Copy failed', ok ? 'success' : 'error')
    })
  </script>
</ToolLayout>
