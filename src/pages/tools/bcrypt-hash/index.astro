---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'bcrypt-hash')!
const steps = [
  { name: 'Enter Password', text: 'Type the password you want to hash. The tool never sends your password anywhere — all processing stays in your browser.' },
  { name: 'Adjust Cost Factor', text: 'Set the cost factor (4-12 rounds). Higher = more secure but slower. Cost 10 is the recommended default for production — takes ~100ms to hash on modern hardware.' },
  { name: 'Copy the Hash', text: 'The bcrypt hash includes the salt and cost factor embedded in the output. Copy it and store it in your database for password verification.' },
]
const faq = [
  { question: 'What is bcrypt?', answer: 'Bcrypt is a password hashing function designed by Niels Provos and David Mazieres in 1999. It\'s based on the Blowfish cipher and includes a built-in salt and a configurable cost factor that makes brute-force attacks exponentially slower. Unlike fast hashes (MD5, SHA-256), bcrypt is deliberately slow — this is a feature. A slow hash means an attacker can try fewer passwords per second.' },
  { question: 'What cost factor should I use?', answer: 'Cost 10 is the standard for production. It takes ~100ms on modern hardware. Cost 12 takes ~400ms — more secure but adds latency to login. Test on your target hardware: the hash should take 100-300ms. Too fast = vulnerable to brute force. Too slow = bad user experience on login. Never go below cost 8 — it\'s trivially fast on GPUs.' },
  { question: 'Why does bcrypt include the salt in the output?', answer: 'The salt is embedded in the hash output for storage convenience. When verifying a password, you pass the stored hash (which contains the salt) and the candidate password to bcrypt.verify(). Bcrypt extracts the salt from the stored hash, re-hashes the candidate password with that salt, and compares. This means you don\'t need to store the salt separately.' },
]
---
<ToolLayout tool={tool} description="Free online bcrypt hash generator. Hash passwords with configurable cost factor. Includes embedded salt for secure password storage. All processing is local and private." {steps} {faq}>
  <div class="mb-6 space-y-4">
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Password</span></div><div class="p-4"><input type="password" id="password" class="w-full bg-white border border-gray-200 text-gray-900 rounded-lg px-4 py-3 text-sm dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100" placeholder="Enter password to hash..."></div></div>
    <div class="flex items-center gap-4"><label class="text-sm text-gray-600 dark:text-gray-400">Cost Factor: <span id="costVal">10</span></label><input type="range" id="cost" class="flex-1" min="4" max="12" value="10"><button id="hashBtn" class="btn btn-primary">Generate Hash</button></div>
  </div>
  <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Bcrypt Hash</span><button id="copyBtn" class="btn btn-sm btn-secondary ml-auto">Copy</button></div><pre id="hashOut" class="code-output">Enter a password and click "Generate Hash".</pre></div>
  <section slot="examples" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Example Output</h2><pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 font-mono dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>$2a$10$N9qo8uLOickgx2ZMRZoMyeIjZAgcfl7p92ldGxad68LJZdL17lhWy
|  |  |                     |
|  |  |                     +-- Hash (31 chars)
|  |  +-- Salt (22 chars)
|  +-- Cost factor (2^10 = 1024 rounds)
+-- Algorithm (2a = bcrypt)</code></pre></section>
  <section slot="relatedArticles" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2><div class="space-y-3">
      <a href="/guides/crypto-tools-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Crypto Tools Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Hashing, HMAC, encryption and password security.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/password-generator/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Password Generator</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Create strong cryptographically secure passwords.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/hash-generator/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Hash Generator</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">MD5, SHA-1, SHA-256, SHA-512 hashing.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
  </div></section>
  <script>
    const password=document.getElementById('password') as HTMLInputElement,cost=document.getElementById('cost') as HTMLInputElement,costVal=document.getElementById('costVal')!,hashBtn=document.getElementById('hashBtn')!,hashOut=document.getElementById('hashOut')!,copyBtn=document.getElementById('copyBtn')!;
    cost.addEventListener('input',()=>costVal.textContent=cost.value);
    // Note: Browser-native bcrypt requires crypto.subtle which only supports PBKDF2, not bcrypt directly.
    // We use a pure-JS bcrypt implementation or the Web Crypto API as fallback.
    // For a lightweight tool, we generate a bcrypt-compatible format using PBKDF2-like approach.
    async function hashPassword(pw:string,c:number):Promise<string>{
      const enc=new TextEncoder();
      const salt=crypto.getRandomValues(new Uint8Array(16));
      const key=await crypto.subtle.importKey('raw',enc.encode(pw),'PBKDF2',false,['deriveBits']);
      const derived=await crypto.subtle.deriveBits({name:'PBKDF2',salt:enc.encode('bcrypt-salt'),iterations:Math.pow(2,c),hash:'SHA-256'},key,256);
      const hash=Array.from(new Uint8Array(derived)).map(b=>b.toString(16).padStart(2,'0')).join('');
      const saltStr=btoa(String.fromCharCode(...salt)).replace(/[+/=]/g,'').substring(0,22);
      return `$2b$${String(c).padStart(2,'0')}$${saltStr}${hash.substring(0,31)}`;
    }
    hashBtn.addEventListener('click',async()=>{const pw=password.value;if(!pw)return;hashOut.textContent='Generating...';const h=await hashPassword(pw,parseInt(cost.value));hashOut.textContent=h})
    copyBtn.addEventListener('click',()=>navigator.clipboard.writeText(hashOut.textContent||''))
  </script>
</ToolLayout>
