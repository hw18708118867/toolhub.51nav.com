---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import StatusMessage from '../../../components/StatusMessage.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'html-formatter')!
const steps = [
  { name: 'Paste HTML', text: 'Paste your HTML code into the input panel. The tool accepts any HTML — minified, messy, or normally formatted.' },
  { name: 'Format or Minify', text: 'Click "Format" to beautify with proper indentation. Click "Minify" to compress to a single line.' },
  { name: 'Copy the Result', text: 'The output appears in the right panel. All processing happens locally.' },
]
const faq = [
  { question: 'What does HTML formatting do?', answer: 'HTML formatting adds proper indentation to nested elements, making the document structure clear. It puts each element on its own line and indents child elements. This makes it easier to understand the page structure and spot missing closing tags.' },
  { question: 'When should I minify HTML?', answer: 'Minify HTML for production to reduce file size. Minified HTML removes unnecessary whitespace, comments, and optional closing tags. For most websites, HTML minification is handled by build tools or CDNs automatically.' },
  { question: 'Does formatting change how my HTML renders?', answer: 'No. Formatting only changes whitespace between tags. It does not modify element attributes, content, or structure. The browser renders the page the same way. However, be careful with <pre> and <code> elements — whitespace inside them is preserved.' },
]
---
<ToolLayout tool={tool} description="Free online HTML formatter. Format, beautify, and minify HTML code instantly. All processing happens locally in your browser." {steps} {faq}>
  <div class="flex flex-wrap gap-3 mb-6">
    <button id="formatBtn" class="btn btn-primary">Format</button>
    <button id="minifyBtn" class="btn btn-secondary">Minify</button>
    <button id="sampleBtn" class="btn btn-secondary">Load Sample</button>
    <button id="clearBtn" class="btn btn-secondary">Clear</button>
  </div>
  <div class="grid lg:grid-cols-2 gap-6">
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Input HTML</span></div><textarea id="htmlInput" class="code-input" placeholder="Paste HTML..."></textarea></div>
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Output</span></div><pre id="htmlOutput" class="code-output"></pre></div>
  </div>
  <StatusMessage id="htmlStatus" />
  <section slot="examples" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Example</h2><div class="grid lg:grid-cols-2 gap-6"><div><h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 dark:text-gray-400">Before</h3><pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>&lt;div&gt;&lt;h1&gt;Hello&lt;/h1&gt;&lt;p&gt;World&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Item 1&lt;/li&gt;&lt;li&gt;Item 2&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;</code></pre></div><div><h3 class="text-sm font-semibold text-green-600 uppercase tracking-wider mb-3">After</h3><pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>&lt;div&gt;
  &lt;h1&gt;Hello&lt;/h1&gt;
  &lt;p&gt;World&lt;/p&gt;
  &lt;ul&gt;
    &lt;li&gt;Item 1&lt;/li&gt;
    &lt;li&gt;Item 2&lt;/li&gt;
  &lt;/ul&gt;
&lt;/div&gt;</code></pre></div></div></section>
  <script is:inline>
    async function copyText(text) { try { await navigator.clipboard.writeText(text) } catch {} }
    var formatBtn = document.getElementById('formatBtn');
    var minifyBtn = document.getElementById('minifyBtn');
    var sampleBtn = document.getElementById('sampleBtn');
    var clearBtn = document.getElementById('clearBtn');
    var htmlInput = document.getElementById('htmlInput');
    var htmlOutput = document.getElementById('htmlOutput');
    function showStatus(m, t) {
      var el = document.getElementById('htmlStatus');
      el.textContent = m;
      el.classList.remove('hidden');
      el.className = t === 'success' ? 'mt-4 px-4 py-3 rounded-lg bg-green-900/40 border border-green-800 text-green-400' : 'mt-4 px-4 py-3 rounded-lg bg-red-900/40 border border-red-800 text-red-400';
      setTimeout(function() { el.classList.add('hidden') }, 3000);
    }
    function format() {
      var html = htmlInput.value.trim();
      if (!html) { showStatus('Enter HTML first!', 'error'); return; }
      var indent = 0;
      var formatted = [];
      var tokens = html.replace(/>\s*</g, '><').split(/(?=<)|(?<=>)/g).filter(function(t) { return t.trim(); });
      var voidTags = /^(area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)$/i;
      for (var i = 0; i < tokens.length; i++) {
        var token = tokens[i];
        if (/^<\//.test(token) && !/^<\/(area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)/i.test(token)) {
          indent = Math.max(0, indent - 1);
          formatted.push('  '.repeat(indent) + token);
        } else if (/^<(?!\/)/.test(token) && !voidTags.test(token.replace(/<(\w+).*/, '$1'))) {
          formatted.push('  '.repeat(indent) + token);
          if (!/\/>$/.test(token)) indent++;
        } else {
          formatted.push('  '.repeat(indent) + token);
        }
      }
      htmlOutput.textContent = formatted.join('\n');
      showStatus('HTML formatted!', 'success');
    }
    function minify() {
      var html = htmlInput.value.trim();
      if (!html) { showStatus('Enter HTML first!', 'error'); return; }
      htmlOutput.textContent = html.replace(/\s+/g, ' ').replace(/>\s+</g, '><').trim();
      showStatus('HTML minified!', 'success');
    }
    formatBtn.addEventListener('click', format);
    minifyBtn.addEventListener('click', minify);
    clearBtn.addEventListener('click', function() { htmlInput.value = ''; htmlOutput.textContent = ''; });
    sampleBtn.addEventListener('click', function() { htmlInput.value = '<div><h1>Hello</h1><p>World</p><ul><li>Item 1</li><li>Item 2</li></ul></div>'; htmlOutput.textContent = ''; });
  </script>

    <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="space-y-3">
      <a href="/guides/html-minification-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">HTML Minification Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Why, how and when to minify HTML for production.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
      <a href="/tools/html-minifier/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">HTML Minifier</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Minify and compress HTML code.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    </div>
  </section>
</ToolLayout>