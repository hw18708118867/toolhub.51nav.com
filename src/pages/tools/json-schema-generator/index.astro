---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'json-schema-generator')!
const steps = [
  { name: 'Paste JSON Data', text: 'Paste any JSON object or array into the input panel. The tool analyzes the structure and generates a JSON Schema that describes the data types, required fields, and constraints.' },
  { name: 'Review the Schema', text: 'The generated JSON Schema appears in the output panel. It includes type definitions, required field lists, and example values. Adjust the draft version (Draft-07 or 2020-12) as needed.' },
  { name: 'Copy and Use', text: 'Copy the schema for API documentation, validation, or OpenAPI specs. Use it to validate incoming JSON, generate TypeScript types, or document your API responses.' },
]
const faq = [
  { question: 'What is JSON Schema?', answer: 'JSON Schema is a vocabulary that lets you describe and validate JSON documents. It defines what fields are required, what types they should be, and what constraints apply (min/max values, string patterns, array sizes). JSON Schema is used by OpenAPI, Postman, and most API frameworks for request/response validation.' },
  { question: 'Can I edit the generated schema?', answer: 'Yes. The generated schema is a starting point. Copy it and customize: add descriptions for each field, set format constraints (email, uri, date-time), add enum values for fields with limited options, and adjust the draft version for your validator. The generator infers types from your data but doesn\'t know your business logic — you add that.' },
]
---
<ToolLayout tool={tool} description="Free online JSON Schema generator. Generate JSON Schema from JSON data instantly. Supports Draft-07 and 2020-12. Perfect for API validation and OpenAPI specs." {steps} {faq}>
  <div class="flex gap-3 mb-6"><select id="draft" class="form-select bg-white border border-gray-200 rounded-lg px-3 py-2 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100"><option value="7">Draft-07</option><option value="2020-12">Draft 2020-12</option></select><button id="generateBtn" class="btn btn-primary">Generate Schema</button><button id="sampleBtn" class="btn btn-secondary">Load Sample</button></div>
  <div class="grid lg:grid-cols-2 gap-6"><div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Input JSON</span></div><textarea id="jsonInput" class="code-input" placeholder="Paste JSON..."></textarea></div><div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Generated Schema</span><button id="copyBtn" class="btn btn-sm btn-secondary ml-auto">Copy</button></div><pre id="output" class="code-output text-sm"></pre></div></div>
  <section slot="relatedArticles" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2><div class="space-y-3">
      <a href="/guides/dev-tools-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Dev Tools Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">JSON Schema, LLM tokens, prompts and mock data.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/json-formatter/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">JSON Formatter</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Format, validate and minify JSON.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/json-to-code/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">JSON to Code</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Convert JSON to TypeScript, Go, Rust types.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
  </div></section>
  <script>
    const jsonInput=document.getElementById('jsonInput') as HTMLTextAreaElement,draft=document.getElementById('draft') as HTMLSelectElement,output=document.getElementById('output')!,generateBtn=document.getElementById('generateBtn')!,sampleBtn=document.getElementById('sampleBtn')!,copyBtn=document.getElementById('copyBtn')!;
    function inferType(v:any):any{if(v===null)return{type:'null'};if(Array.isArray(v)){const items=v.length>0?inferType(v[0]):{};return{type:'array',items}}if(typeof v==='object'){const props:any={},required:string[]=[];for(const[k,val]of Object.entries(v)){props[k]=inferType(val);required.push(k)}return{type:'object',properties:props,required}}if(typeof v==='string')return{type:'string'};if(typeof v==='number')return Number.isInteger(v)?{type:'integer'}:{type:'number'};if(typeof v==='boolean')return{type:'boolean'};return{type:'string'}}
    function generate(){try{const data=JSON.parse(jsonInput.value);const schema:any={$schema:`http://json-schema.org/draft-0${draft.value==='7'?'7':'2020-12'}/schema#`,...inferType(data)};output.textContent=JSON.stringify(schema,null,2)}catch(e){output.textContent='Invalid JSON. Check syntax and try again.'}}
    generateBtn.addEventListener('click',generate);copyBtn.addEventListener('click',()=>navigator.clipboard.writeText(output.textContent||''));sampleBtn.addEventListener('click',()=>{jsonInput.value='{"name":"Alice","age":30,"email":"alice@example.com","tags":["dev","design"],"address":{"city":"Tokyo","zip":"100-0001"}}';generate()})
  </script>
</ToolLayout>
