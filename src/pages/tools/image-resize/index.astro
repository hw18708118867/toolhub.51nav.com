---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'image-resize')!
const steps = [
  { name: 'Upload an Image', text: 'Click or drag an image file. The tool displays the current dimensions and loads a preview. Supported formats: JPEG, PNG, WebP, SVG.' },
  { name: 'Set New Dimensions', text: 'Enter the desired width and height in pixels. Toggle "Maintain aspect ratio" to keep proportions — change one dimension and the other adjusts automatically.' },
  { name: 'Download the Resized Image', text: 'Click "Resize & Download" to save the image at the new dimensions. The output is PNG format. For other formats, use the Image Format Converter after resizing.' },
]
const faq = [
  { question: 'Will resizing affect image quality?', answer: 'Downscaling (making smaller) maintains good quality. Upscaling (making larger) will look blurry or pixelated because the browser is inventing pixels that don\'t exist in the original. For upscaling, use AI-based tools. For web use, always start with the largest version of your image and downscale to the needed sizes.' },
  { question: 'What dimensions should I use?', answer: 'Common web image sizes: Hero/banner: 1200-1920px wide, Blog post featured image: 1200×630px (social share ratio), Thumbnail: 300-400px, Product image: 800-1200px, Avatar: 128-256px. Always resize to the display size — serving a 4000px image when displaying at 400px wastes bandwidth.' },
]
---
<ToolLayout tool={tool} description="Free online image resize tool. Resize images to exact pixel dimensions. Maintain aspect ratio or set custom width and height. All processing is local and private." {steps} {faq}>
  <div class="mb-6"><div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Upload Image</span></div><div class="p-6 text-center"><input type="file" id="fileInput" accept="image/*" class="hidden"><button id="uploadBtn" class="btn btn-primary" onclick="document.getElementById('fileInput').click()">Choose Image</button><p class="text-xs text-gray-400 mt-2">or drag and drop • JPEG, PNG, WebP, SVG</p></div></div></div>
  <div class="hidden" id="controls"><div class="grid md:grid-cols-2 gap-6">
    <div class="space-y-4"><div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Dimensions</span></div><div class="p-4 space-y-3">
      <div class="flex items-center gap-3"><label class="text-sm text-gray-600 dark:text-gray-400 w-16">Width</label><input type="number" id="width" class="w-28 bg-white border border-gray-200 rounded-lg px-3 py-2 text-sm dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100" min="1" max="10000"><span class="text-sm text-gray-400">px</span></div>
      <div class="flex items-center gap-3"><label class="text-sm text-gray-600 dark:text-gray-400 w-16">Height</label><input type="number" id="height" class="w-28 bg-white border border-gray-200 rounded-lg px-3 py-2 text-sm dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100" min="1" max="10000"><span class="text-sm text-gray-400">px</span></div>
      <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" id="aspectRatio" checked class="w-4 h-4 rounded"><span class="text-sm text-gray-600 dark:text-gray-400">Maintain aspect ratio</span></label>
      <button id="resizeBtn" class="btn btn-primary w-full">Resize & Download</button></div></div></div>
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Preview</span><span id="origDims" class="text-xs text-gray-400 ml-2"></span></div><div class="p-4 flex items-center justify-center"><img id="preview" class="max-h-64 max-w-full object-contain"></div></div>
  </div></div>
  <section slot="relatedArticles" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2><div class="space-y-3">
      <a href="/guides/image-tools-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Image Tools Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Compress, resize, convert and optimize images for the web.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/image-compressor/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Image Compressor</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Compress JPEG, PNG and WebP images.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/image-crop/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Image Crop</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Crop and trim images in the browser.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
  </div></section>
  <script>
    const fileInput=document.getElementById('fileInput') as HTMLInputElement,controls=document.getElementById('controls')!,width=document.getElementById('width') as HTMLInputElement,height=document.getElementById('height') as HTMLInputElement,aspectRatio=document.getElementById('aspectRatio') as HTMLInputElement,preview=document.getElementById('preview') as HTMLImageElement,origDims=document.getElementById('origDims')!,resizeBtn=document.getElementById('resizeBtn')!;
    let img:HTMLImageElement|null=null,origW=0,origH=0;
    fileInput.addEventListener('change',(e:any)=>{const f=e.target.files?.[0];if(f)loadImage(f)});
    document.addEventListener('dragover',e=>e.preventDefault());document.addEventListener('drop',e=>{e.preventDefault();const f=e.dataTransfer?.files?.[0];if(f)loadImage(f)});
    function loadImage(f:File){const r=new FileReader();r.onload=()=>{img=new Image();img.onload=()=>{origW=img!.width;origH=img!.height;width.value=origW.toString();height.value=origH.toString();origDims.textContent=`${origW} × ${origH} (original)`;preview.src=r.result as string;controls.classList.remove('hidden')};img.src=r.result as string};r.readAsDataURL(f)}
    width.addEventListener('input',()=>{if(aspectRatio.checked&&img)height.value=Math.round(parseInt(width.value)*(origH/origW)).toString()});
    height.addEventListener('input',()=>{if(aspectRatio.checked&&img)width.value=Math.round(parseInt(height.value)*(origW/origH)).toString()});
    resizeBtn.addEventListener('click',()=>{if(!img)return;const w=parseInt(width.value),h=parseInt(height.value);if(w<1||h<1)return;const c=document.createElement('canvas');c.width=w;c.height=h;c.getContext('2d')!.drawImage(img,0,0,w,h);const a=document.createElement('a');a.href=c.toDataURL();a.download='resized.png';a.click()});
  </script>
</ToolLayout>
