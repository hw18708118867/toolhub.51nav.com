---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'hmac-generator')!
const steps = [
  { name: 'Enter Message & Secret Key', text: 'Type the message to authenticate and a secret key. The key should be known only to parties that need to verify the HMAC — it\'s the shared secret that proves authenticity.' },
  { name: 'Select Hash Algorithm', text: 'Choose SHA-256 (recommended) or SHA-512. SHA-256 is faster and sufficient for most use cases. SHA-512 provides higher security margin.' },
  { name: 'Copy the HMAC', text: 'The HMAC is a hex-encoded authentication code. Send it alongside your message. The receiver can recompute the HMAC with the same key to verify the message hasn\'t been tampered with.' },
]
const faq = [
  { question: 'What is HMAC?', answer: 'HMAC (Hash-based Message Authentication Code) combines a cryptographic hash function (SHA-256 or SHA-512) with a secret key to produce a message authentication code. Unlike a plain hash, HMAC proves both data integrity (the message hasn\'t changed) and authenticity (it came from someone who knows the secret key). HMAC is used in JWT signing, API authentication, OAuth 1.0, and AWS Signature V4.' },
  { question: 'HMAC vs plain hash — when to use which?', answer: 'Use a plain hash (SHA-256) when you only need to verify data hasn\'t been corrupted — file checksums, deduplication, commit hashes. Use HMAC when you need to verify both integrity AND authenticity — API request signing, webhook payloads, session tokens. Anyone can compute a plain hash. Only someone with the secret key can compute a valid HMAC.' },
  { question: 'What should I use as the secret key?', answer: 'Use a cryptographically random string at least 32 bytes (64 hex chars) long. Never use a password directly — run it through a KDF first. Generate keys with our Password Generator or Random String Generator. Store the key securely — if an attacker obtains your HMAC key, they can forge valid HMACs for any message.' },
]
---
<ToolLayout tool={tool} description="Free online HMAC generator. Generate HMAC-SHA256 and HMAC-SHA512 authentication codes. Used for API signing, JWT and webhook verification. All processing is local and private." {steps} {faq}>
  <div class="mb-6 space-y-4">
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Message</span></div><textarea id="message" class="code-input" placeholder="Enter message to authenticate..."></textarea></div>
    <div class="flex gap-4 flex-wrap items-end"><div class="flex-1 min-w-[200px]"><label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Secret Key</label><input type="password" id="key" class="w-full bg-white border border-gray-200 text-gray-900 rounded-lg px-4 py-3 text-sm dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100" placeholder="Enter secret key..."></div><div><label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Algorithm</label><select id="algo" class="form-select bg-white border border-gray-200 rounded-lg px-3 py-2 dark:bg-gray-900 dark:border-gray-800 dark:text-gray-100"><option value="SHA-256" selected>SHA-256</option><option value="SHA-512">SHA-512</option></select></div></div>
  </div>
  <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">HMAC (Hex)</span><button id="copyBtn" class="btn btn-sm btn-secondary ml-auto">Copy</button></div><pre id="output" class="code-output text-sm font-mono">Enter a message and key. The HMAC updates as you type.</pre></div>
  <section slot="relatedArticles" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2><div class="space-y-3">
      <a href="/guides/crypto-tools-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Crypto Tools Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Hashing, HMAC, encryption and password security.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/hash-generator/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Hash Generator</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">MD5, SHA-1, SHA-256, SHA-512 hashing.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/aes-encrypt/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">AES Encrypt/Decrypt</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Encrypt and decrypt text with AES-256.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
  </div></section>
  <script>
    const message=document.getElementById('message') as HTMLTextAreaElement,key=document.getElementById('key') as HTMLInputElement,algo=document.getElementById('algo') as HTMLSelectElement,output=document.getElementById('output')!,copyBtn=document.getElementById('copyBtn')!;
    async function update(){if(!message.value||!key.value){output.textContent='Enter a message and key. The HMAC updates as you type.';return}const enc=new TextEncoder();const k=await crypto.subtle.importKey('raw',enc.encode(key.value),{name:'HMAC',hash:algo.value},false,['sign']);const sig=await crypto.subtle.sign('HMAC',k,enc.encode(message.value));output.textContent=Array.from(new Uint8Array(sig)).map(b=>b.toString(16).padStart(2,'0')).join('')}
    message.addEventListener('input',update);key.addEventListener('input',update);algo.addEventListener('change',update)
    copyBtn.addEventListener('click',()=>navigator.clipboard.writeText(output.textContent||''))
  </script>
</ToolLayout>
