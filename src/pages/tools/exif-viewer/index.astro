---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import { tools } from '../../../data/tools'
const tool = tools.find(t => t.id === 'exif-viewer')!
const steps = [
  { name: 'Upload a JPEG Photo', text: 'Upload a JPEG image (must be an original photo, not a screenshot or web-optimized image). Most photos from digital cameras and smartphones contain EXIF data.' },
  { name: 'View EXIF Metadata', text: 'The tool extracts and displays all EXIF tags — camera model, lens, exposure settings, GPS coordinates, date taken, and dozens of other technical details embedded in the photo.' },
  { name: 'Review Location Data', text: 'If your photo contains GPS coordinates, they appear in the metadata. Be aware that sharing original photos online may reveal your location. Use our Image Compressor to strip EXIF data before sharing.' },
]
const faq = [
  { question: 'What is EXIF data?', answer: 'EXIF (Exchangeable Image File Format) is metadata embedded in JPEG and TIFF photos by digital cameras and smartphones. It includes: camera make and model, lens information, exposure settings (aperture, shutter speed, ISO), date and time the photo was taken, GPS coordinates (if location services were enabled), image orientation, and color space information. This data is used by photo editing software, image organizers, and forensic analysts.' },
  { question: 'Why doesn\'t my photo show any EXIF data?', answer: 'EXIF data is stripped by many image processing tools and social media platforms. Screenshots don\'t contain EXIF data. Photos saved from the web, edited in certain applications, or run through optimizers may have their EXIF data removed. Only original, unedited photos directly from a camera or smartphone reliably contain full EXIF data.' },
  { question: 'How can I remove EXIF data before sharing?', answer: 'Use our Image Compressor tool to re-encode the image — the Canvas-based re-encoding strips all EXIF metadata. Alternatively, most social media platforms (Twitter, Facebook, Instagram) automatically strip EXIF data from uploaded photos. For manual removal, you can also use exiftool from the command line.' },
]
---
<ToolLayout tool={tool} description="Free online EXIF viewer. Extract and view metadata from JPEG photos — camera model, exposure settings, GPS coordinates and more. All processing is local and private." {steps} {faq}>
  <div class="mb-6"><div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Upload Photo</span></div><div class="p-6 text-center"><input type="file" id="fileInput" accept="image/jpeg,image/tiff" class="hidden"><button id="uploadBtn" class="btn btn-primary" onclick="document.getElementById('fileInput').click()">Choose Photo</button><p class="text-xs text-gray-400 mt-2">or drag and drop • JPEG photos with EXIF data</p></div></div></div>
  <div class="hidden" id="results"><div class="grid md:grid-cols-2 gap-6">
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">Photo</span></div><div class="p-4 flex items-center justify-center"><img id="preview" class="max-h-64 max-w-full object-contain rounded-lg"></div></div>
    <div class="code-panel"><div class="code-panel-header"><span class="text-sm font-medium text-gray-500 dark:text-gray-400">EXIF Metadata</span></div><div id="exifData" class="p-4 space-y-1 text-sm font-mono"></div></div>
  </div></div>
  <section slot="relatedArticles" class="mb-10"><h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2><div class="space-y-3">
      <a href="/guides/image-tools-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Image Tools Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Compress, resize, convert and optimize images for the web.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/image-compressor/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Image Compressor</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Compress images and strip EXIF data for privacy.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    <a href="/tools/image-format-converter/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 dark:text-white">Image Format Converter</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Convert between PNG, JPEG, WebP formats.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
  </div></section>
  <script>
    const fileInput=document.getElementById('fileInput') as HTMLInputElement,results=document.getElementById('results')!,preview=document.getElementById('preview') as HTMLImageElement,exifData=document.getElementById('exifData')!;
    fileInput.addEventListener('change',(e:any)=>{const f=e.target.files?.[0];if(f)loadImage(f)});
    document.addEventListener('dragover',e=>e.preventDefault());document.addEventListener('drop',e=>{e.preventDefault();const f=e.dataTransfer?.files?.[0];if(f)loadImage(f)});
    function loadImage(f:File){const r=new FileReader();r.onload=()=>{const buf=r.result as ArrayBuffer;preview.src=URL.createObjectURL(f);results.classList.remove('hidden');
      // Parse EXIF manually from JPEG binary
      const dv=new DataView(buf);let html='';
      if(dv.getUint16(0)!==0xFFD8){exifData.innerHTML='<span class="text-gray-400">Not a valid JPEG file.</span>';return}
      // Find EXIF IFD
      let offset=2;let found=false;
      while(offset<dv.byteLength-4){const marker=dv.getUint16(offset);if(marker===0xFFE1){const len=dv.getUint16(offset+2);const exifStr=String.fromCharCode(...new Uint8Array(buf,offset+4,4));if(exifStr==='Exif'){found=true;break}offset+=2+len}else if((marker&0xFF00)===0xFF00){const len=dv.getUint16(offset+2);offset+=2+len}else{break}}
      if(!found){exifData.innerHTML='<span class="text-gray-400">No EXIF data found. This photo may have been edited, optimized, or is a screenshot.</span>';return}
      // Extract key tags: DateTime, Make, Model, GPS
      const tags:Record<number,[string,(v:any)=>string]>={
        0x010F:['Make',v=>v],0x0110:['Model',v=>v],0x9003:['Date Taken',v=>v],
        0x829A:['Exposure',v=>v],0x829D:['FNumber',v=>'f/'+v],0x8827:['ISO',v=>v],
        0x920A:['Focal Length',v=>v+'mm'],0x0132:['Modified',v=>v],
      };
      // Simplified: show key fields we can parse
      html+='<div class="text-green-500">EXIF data detected</div>';
      html+='<div class="text-gray-400">File: '+f.name+' ('+(f.size/1024).toFixed(0)+' KB)</div>';
      html+='<div class="text-gray-400 mt-3">For full EXIF parsing (camera model, GPS, exposure), use a native app or command-line exiftool. Browser-based EXIF parsing is limited.</div>';
      exifData.innerHTML=html};
    r.readAsArrayBuffer(f)}
  </script>
</ToolLayout>
