---
import ToolLayout from '../../../layouts/ToolLayout.astro'
import StatusMessage from '../../../components/StatusMessage.astro'
import { tools } from '../../../data/tools'

const tool = tools.find(t => t.id === 'base64-converter')!

const steps = [
  { name: 'Enter Your Data', text: 'Type or paste your text into the input panel. You can enter plain text to encode, or Base64-encoded text to decode.' },
  { name: 'Choose Direction', text: 'Click "Encode" to convert text to Base64, or "Decode" to convert Base64 back to readable text.' },
  { name: 'Get the Result', text: 'The converted output appears instantly in the right panel. All processing is done locally in your browser.' },
  { name: 'Copy and Use', text: 'Click the Copy button to copy the result to your clipboard. Paste it wherever you need it.' },
]

const faq = [
  { question: 'What is Base64 encoding?', answer: 'Base64 is a binary-to-text encoding scheme that represents binary data as ASCII text. It uses 64 characters (A-Z, a-z, 0-9, +, /) to encode any data. It\'s commonly used for transmitting data over text-based protocols like email (MIME), embedding images in HTML/CSS, and storing binary data in JSON.' },
  { question: 'Is Base64 encoding the same as encryption?', answer: 'No! Base64 is encoding, not encryption. It provides no security — anyone can decode Base64 data back to its original form. Think of it like translating text to a different alphabet, not locking it with a key. If you need to protect data, use proper encryption like AES.' },
  { question: 'When should I use Base64 encoding?', answer: 'Base64 is useful when you need to transmit binary data through text-only channels. Common use cases include embedding images as data URIs in HTML/CSS, sending file attachments via email, storing binary data in JSON payloads, and encoding API credentials for Basic Authentication.' },
  { question: 'Can I encode files like images or PDFs to Base64?', answer: 'Yes, any binary data can be Base64 encoded. However, Base64 encoding increases the data size by about 33%. For very large files, this overhead can be significant. Our tool is optimized for text conversion — for large files, consider using a dedicated file-to-Base64 tool.' },
]

const before = 'Hello, World! 👋'
const after = 'SGVsbG8sIFdvcmxkISDwn5GL'
---

<ToolLayout
  tool={tool}
  description="Free online Base64 encoder and decoder. Instantly encode text to Base64 or decode Base64 back to plain text. All processing happens locally in your browser." {steps} {faq}
>
  <div class="flex flex-wrap gap-3 mb-6">
    <button id="encodeBtn" class="btn btn-primary">Encode</button>
    <button id="decodeBtn" class="btn btn-secondary">Decode</button>
    <button id="sampleBtn" class="btn btn-secondary">Load Sample</button>
    <button id="clearBtn" class="btn btn-secondary">Clear</button>
  </div>
  <div class="grid lg:grid-cols-2 gap-6">
    <div class="code-panel">
      <div class="code-panel-header">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400" id="inputLabel">Text</span>
        <button id="copyInputBtn" class="btn btn-sm btn-secondary">Copy</button>
      </div>
      <textarea id="b64Input" class="code-input" placeholder="Enter text or Base64..."></textarea>
    </div>
    <div class="code-panel">
      <div class="code-panel-header">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400" id="outputLabel">Base64</span>
        <button id="copyOutputBtn" class="btn btn-sm btn-secondary">Copy</button>
      </div>
      <pre id="b64Output" class="code-output"></pre>
    </div>
  </div>
  <StatusMessage id="b64Status" />

  <section slot="examples" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Examples</h2>
    <div class="grid lg:grid-cols-2 gap-6">
      <div>
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 dark:text-gray-400">Before (Plain Text)</h3>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>{before}</code></pre>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-green-600 uppercase tracking-wider mb-3">After (Base64 Encoded)</h3>
        <pre class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-gray-700 overflow-x-auto break-all dark:bg-gray-900 dark:border-gray-800 dark:text-gray-300"><code>{after}</code></pre>
      </div>
    </div>
  </section>

  <section slot="tutorial" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Understanding Base64 Encoding</h2>
    <div class="prose prose-gray max-w-none dark:prose-invert">
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">Base64 encoding converts binary data into a set of 64 printable ASCII characters. Every 3 bytes (24 bits) of input are split into 4 groups of 6 bits, each mapped to one of 64 characters: uppercase letters A-Z, lowercase letters a-z, digits 0-9, and symbols + and /. The = character is used for padding when the input length is not a multiple of 3.</p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3 dark:text-white">Common Use Cases</h3>
      <ul class="list-disc list-inside space-y-2 text-gray-500 dark:text-gray-400">
        <li>Data URIs: embedding images directly in HTML/CSS</li>
        <li>Email attachments (MIME encoding)</li>
        <li>HTTP Basic Authentication headers</li>
        <li>Storing binary data in JSON or XML</li>
        <li>Encoding API keys and tokens for transmission</li>
      </ul>
    </div>
  </section>

    <section slot="relatedArticles" class="mb-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-white">Related Articles</h2>
    <div class="space-y-3">
      <a href="/guides/web-encoding-guide/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-blue-500 font-medium">Guide</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">Web Encoding Guide</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">Base64, URL encoding, and HTML entities explained.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
      <a href="/tools/url-encode/" class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all group dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600"><div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div><div class="flex-1 min-w-0"><span class="text-xs text-green-500 font-medium">Tool</span><h4 class="text-sm font-semibold text-gray-900 mt-0.5 group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400 transition-colors">URL Encode/Decode</h4><p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400 truncate">URL encode and decode text.</p></div><svg class="w-5 h-5 text-gray-300 group-hover:text-blue-500 flex-shrink-0 transition-colors dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></a>
    </div>
  </section>

  <script>
    import { copyToClipboard } from '../../../utils/copyToClipboard'
    const encodeBtn = document.getElementById('encodeBtn')!
    const decodeBtn = document.getElementById('decodeBtn')!
    const clearBtn = document.getElementById('clearBtn')!
    const sampleBtn = document.getElementById('sampleBtn')!
    const copyInputBtn = document.getElementById('copyInputBtn')!
    const copyOutputBtn = document.getElementById('copyOutputBtn')!
    const b64Input = document.getElementById('b64Input')
    const b64Output = document.getElementById('b64Output')!
    const inputLabel = document.getElementById('inputLabel')!
    const outputLabel = document.getElementById('outputLabel')!
    function showStatus(message: string, type: 'success' | 'error') {
      const statusEl = document.getElementById('b64Status')!
      statusEl.textContent = message
      statusEl.classList.remove('hidden')
      statusEl.className = type === 'success' ? 'mt-4 px-4 py-3 rounded-lg bg-green-900/40 border border-green-800 text-green-400' : 'mt-4 px-4 py-3 rounded-lg bg-red-900/40 border border-red-800 text-red-400'
      setTimeout(() => statusEl.classList.add('hidden'), 3000)
    }
    encodeBtn.addEventListener('click', () => {
      try { inputLabel.textContent = 'Text'; outputLabel.textContent = 'Base64'; b64Output.textContent = btoa(unescape(encodeURIComponent(b64Input.value))); showStatus('Encoded successfully!', 'success') } catch { showStatus('Encoding error', 'error') }
    })
    decodeBtn.addEventListener('click', () => {
      try { inputLabel.textContent = 'Base64'; outputLabel.textContent = 'Text'; b64Output.textContent = decodeURIComponent(escape(atob(b64Input.value))); showStatus('Decoded successfully!', 'success') } catch { showStatus('Invalid Base64', 'error') }
    })
    clearBtn.addEventListener('click', () => { b64Input.value = ''; b64Output.textContent = '' })
    sampleBtn.addEventListener('click', () => { b64Input.value = 'Hello, World! 👋'; b64Output.textContent = ''; inputLabel.textContent = 'Text'; outputLabel.textContent = 'Base64' })
    copyInputBtn.addEventListener('click', async () => { const success = await copyToClipboard(b64Input.value); showStatus(success ? 'Copied!' : 'Failed to copy', success ? 'success' : 'error') })
    copyOutputBtn.addEventListener('click', async () => { const success = await copyToClipboard(b64Output.textContent || ''); showStatus(success ? 'Copied!' : 'Failed to copy', success ? 'success' : 'error') })
  </script>
</ToolLayout>