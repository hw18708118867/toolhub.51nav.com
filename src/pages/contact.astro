---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
---

<BaseLayout title="Contact Us | DevTools Hub" description="Get in touch with the DevTools Hub team. Send feedback, report bugs, or suggest new tools.">
  <Header />
  <main class="flex-1 py-16">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4 dark:text-white">Contact</h1>
      <p class="text-lg text-gray-500 mb-12 dark:text-gray-400">Questions, feedback, or suggestions for a new tool? Send an email — we read every message.</p>

      <div class="space-y-8">
        <!-- Email -->
        <div class="bg-white border border-gray-200 rounded-2xl p-6 sm:p-8 dark:bg-gray-900 dark:border-gray-800">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-4 text-blue-600 dark:bg-blue-600/20 dark:text-blue-400">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <h2 class="text-xl font-bold text-gray-900 mb-2 dark:text-white">Email</h2>
          <a href="mailto:miraclehuang611@gmail.com" class="text-blue-600 hover:text-blue-500 text-lg dark:text-blue-400 dark:hover:text-blue-300">miraclehuang611@gmail.com</a>
          <p class="text-gray-500 mt-3 dark:text-gray-400">For bug reports, include your browser and OS. For tool suggestions, describe what the tool would do and how you'd use it.</p>
        </div>

        <!-- What to include -->
        <div class="bg-white border border-gray-200 rounded-2xl p-6 sm:p-8 dark:bg-gray-900 dark:border-gray-800">
          <h2 class="text-xl font-bold text-gray-900 mb-4 dark:text-white">What to Send Us</h2>
          <ul class="space-y-3 text-gray-500 dark:text-gray-400">
            <li class="flex gap-3">
              <span class="text-blue-500 font-bold flex-shrink-0">1.</span>
              <span><strong class="text-gray-700 dark:text-gray-300">Bug reports</strong> — which tool, what you did, what happened, what you expected. Screenshots help.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-blue-500 font-bold flex-shrink-0">2.</span>
              <span><strong class="text-gray-700 dark:text-gray-300">Tool suggestions</strong> — what the tool does, who would use it, why it belongs on DevTools Hub.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-blue-500 font-bold flex-shrink-0">3.</span>
              <span><strong class="text-gray-700 dark:text-gray-300">Feature requests</strong> — which existing tool, what you want it to do, how it helps your workflow.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-blue-500 font-bold flex-shrink-0">4.</span>
              <span><strong class="text-gray-700 dark:text-gray-300">Content feedback</strong> — found an error in a guide? Have a topic you want covered? Let us know.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>