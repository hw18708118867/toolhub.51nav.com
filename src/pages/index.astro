---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import ToolCard from '../components/ToolCard.astro'
import AnimatedIcon from '../components/AnimatedIcon.astro'
import { popularTools, tools, categories } from '../data/tools'

// Group tools by category
const toolsByCategory = Object.entries(categories).map(([key, cat]) => ({
  key,
  name: cat.name,
  tools: tools.filter(t => t.category === key)
}))
---

<BaseLayout title={`DevTools Hub — ${tools.length}+ Free Online Developer Tools`}>
  <Header />
  <main class="flex-1">
    <!-- Hero Section (with integrated stats) -->
    <section class="bg-gradient-to-br from-blue-50 via-gray-50 to-white dark:from-blue-900 dark:via-gray-900 dark:to-gray-950 py-16 sm:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-100 border border-blue-200 rounded-full mb-6 dark:bg-blue-600/20 dark:border-blue-500/30">
            <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M13 2 L3 14 H12 L11 22 L21 10 H12 L13 2Z"/>
            </svg>
            <span class="text-blue-700 text-sm font-medium dark:text-blue-300">{tools.length}+ Free Developer Tools</span>
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 mb-6 leading-tight dark:text-white">
            Make your work
            <span class="text-blue-600 dark:text-blue-400">easier</span>
          </h1>
          <p class="text-xl text-gray-500 max-w-2xl mx-auto mb-10 dark:text-gray-400">
            Fast, private, and easy-to-use tools for developers. All tools run locally in your browser. No data is sent anywhere.
          </p>
          <div class="flex flex-wrap justify-center gap-4 mb-14">
            <a href="/tools/" class="inline-flex items-center gap-2 px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all duration-200 shadow-lg hover:shadow-blue-500/30">
              Browse Tools
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
            <a href="#tool-categories" class="inline-flex items-center gap-2 px-8 py-4 bg-white hover:bg-gray-50 text-gray-700 font-semibold rounded-xl border border-gray-200 transition-all duration-200 dark:bg-gray-800 dark:hover:bg-gray-700 dark:text-white dark:border-gray-700">
              Explore Categories
            </a>
          </div>

          <!-- Stats Row -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto">
            <div class="bg-white border border-gray-200 rounded-xl p-4 dark:bg-gray-900/50 dark:border-gray-800">
              <div class="text-3xl font-bold text-blue-600 mb-1 dark:text-blue-400">{tools.length}</div>
              <div class="text-sm text-gray-400 dark:text-gray-500">Free Tools</div>
            </div>
            <div class="bg-white border border-gray-200 rounded-xl p-4 dark:bg-gray-900/50 dark:border-gray-800">
              <div class="text-3xl font-bold text-green-600 mb-1 dark:text-green-400">100%</div>
              <div class="text-sm text-gray-400 dark:text-gray-500">Private</div>
            </div>
            <div class="bg-white border border-gray-200 rounded-xl p-4 dark:bg-gray-900/50 dark:border-gray-800">
              <div class="text-3xl font-bold text-yellow-600 mb-1 dark:text-yellow-400">0</div>
              <div class="text-sm text-gray-400 dark:text-gray-500">Sign Ups</div>
            </div>
            <div class="bg-white border border-gray-200 rounded-xl p-4 dark:bg-gray-900/50 dark:border-gray-800">
              <div class="text-3xl font-bold text-purple-600 mb-1 dark:text-purple-400">∞</div>
              <div class="text-sm text-gray-400 dark:text-gray-500">No Limits</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Popular Tools Section -->
    <section id="popular-tools" class="py-16 sm:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4 dark:text-white">Popular Tools</h2>
          <p class="text-lg text-gray-500 max-w-2xl mx-auto dark:text-gray-400">Our most-used developer tools, all in one place</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {popularTools.map(tool => (
            <a href={`/tools/${tool.id}/`} class="group">
              <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:border-blue-500 hover:shadow-xl hover:shadow-blue-500/10 transition-all duration-300 hover:-translate-y-1 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600 dark:hover:shadow-blue-500/10">
                <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center mb-5 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all duration-200 overflow-visible dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white">
                  <AnimatedIcon type={tool.icon} />
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2 dark:text-white">{tool.name}</h3>
                <p class="text-gray-400 dark:text-gray-500">{tool.description}</p>
                <div class="flex items-center gap-2 mt-4 text-blue-600 font-medium dark:text-blue-400">
                  <span>Use Now</span>
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Tool Categories Section -->
    <section id="tool-categories" class="bg-gray-50 border-y border-gray-200 py-16 sm:py-20 dark:bg-gray-900 dark:border-gray-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4 dark:text-white">Tool Categories</h2>
          <p class="text-lg text-gray-500 max-w-2xl mx-auto dark:text-gray-400">Browse tools by category — find exactly what you need</p>
        </div>

        <div class="space-y-10">
          {toolsByCategory.map(({ key, name, tools }) => (
            <div>
              <!-- Category Header -->
              <div class="flex items-center gap-4 mb-5">
                <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center text-blue-600 dark:bg-blue-600/20 dark:text-blue-400">
                  {key === 'encoding' && (
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M10 4H4v6h6V4zM20 4h-6v6h6V4zM10 14H4v6h6v-6zM20 14h-6v6h6v-6z"/>
                    </svg>
                  )}
                  {key === 'generator' && (
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M13 2 L3 14 H12 L11 22 L21 10 H12 L13 2Z"/>
                    </svg>
                  )}
                  {key === 'color' && (
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/>
                    </svg>
                  )}
                  {key === 'data' && (
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
                    </svg>
                  )}
                  {key === 'dev' && (
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M16 18l6-6-6-6M8 6l-6 6 6 6"/>
                    </svg>
                  )}
                  {key === 'text' && (
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M4 7V4h16v3M9 20h6M12 4v16"/>
                    </svg>
                  )}
                  {key === 'network' && (
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="9"/><path d="M12 3v18M3 12h18"/><path d="M5.5 5.5l13 13M18.5 5.5l-13 13"/>
                    </svg>
                  )}
                  {key === 'image' && (
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
                    </svg>
                  )}
                  {key === 'security' && (
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                  )}
                  {key === 'formatters' && (
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="12" y1="2" x2="12" y2="22"/>
                    </svg>
                  )}
                  {key === 'calculators' && (
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="12" y2="14"/>
                    </svg>
                  )}
                  {key === 'seo' && (
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><path d="M8 11h6"/>
                    </svg>
                  )}
                </div>
                <div>
                  <h3 class="text-xl font-semibold text-gray-900 dark:text-white">{name}</h3>
                  <span class="text-sm text-gray-400 dark:text-gray-500">{tools.length} tools</span>
                </div>
              </div>

              <!-- Category Tools Grid -->
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                {tools.map(tool => (
                  <a href={`/tools/${tool.id}/`} class="group">
                    <div class="bg-white border border-gray-200 rounded-xl p-4 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 hover:-translate-y-0.5 dark:bg-gray-950 dark:border-gray-800 dark:hover:border-blue-600 dark:hover:shadow-blue-500/10">
                      <div class="flex items-center gap-3">
                        <div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center text-blue-600 flex-shrink-0 group-hover:bg-blue-600 group-hover:text-white transition-all duration-200 overflow-visible dark:bg-blue-600/20 dark:text-blue-400 dark:group-hover:bg-blue-600 dark:group-hover:text-white">
                          <AnimatedIcon type={tool.icon} />
                        </div>
                        <div class="min-w-0">
                          <h4 class="text-sm font-semibold text-gray-900 truncate dark:text-white">{tool.name}</h4>
                          <p class="text-xs text-gray-400 truncate dark:text-gray-500">{tool.description}</p>
                        </div>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why Choose Us Section -->
    <section class="py-16 sm:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4 dark:text-white">Why Choose Us?</h2>
          <p class="text-lg text-gray-500 max-w-2xl mx-auto dark:text-gray-400">The tools you need, designed the way you want them</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:border-gray-300 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-gray-700">
            <div class="w-14 h-14 bg-green-50 rounded-xl flex items-center justify-center mb-6 text-green-600 dark:bg-green-600/20 dark:text-green-400">
              <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3 dark:text-white">100% Private</h3>
            <p class="text-gray-400 dark:text-gray-500">All processing happens locally in your browser. Your data never leaves your computer.</p>
          </div>
          <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:border-gray-300 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-gray-700">
            <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center mb-6 text-blue-600 dark:bg-blue-600/20 dark:text-blue-400">
              <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M13 2 L3 14 H12 L11 22 L21 10 H12 L13 2Z"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3 dark:text-white">Lightning Fast</h3>
            <p class="text-gray-400 dark:text-gray-500">No server roundtrips. No loading spinners. Just instant results every time.</p>
          </div>
          <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:border-gray-300 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-gray-700">
            <div class="w-14 h-14 bg-purple-50 rounded-xl flex items-center justify-center mb-6 text-purple-600 dark:bg-purple-600/20 dark:text-purple-400">
              <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3 dark:text-white">Always Free</h3>
            <p class="text-gray-400 dark:text-gray-500">No sign ups. No paywalls. No limits. Just tools that work for developers.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Developer Guides Section -->
    <section class="bg-gray-50 border-y border-gray-200 py-16 sm:py-20 dark:bg-gray-900 dark:border-gray-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4 dark:text-white">Developer Guides</h2>
          <p class="text-lg text-gray-500 max-w-2xl mx-auto dark:text-gray-400">In-depth tutorials to help you get the most out of our tools</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <a href="/guides/json-debugging-guide/" class="group">
            <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 h-full dark:bg-gray-950 dark:border-gray-800 dark:hover:border-blue-600">
              <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center mb-5 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all dark:bg-blue-600/20 dark:text-blue-400">
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              </div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2 dark:text-white">JSON Data Debugging Guide</h3>
              <p class="text-gray-500 text-sm dark:text-gray-400">A systematic approach to finding and fixing JSON errors. Covers validation, formatting, JWT debugging, and real-world API workflows.</p>
            </div>
          </a>
          <a href="/guides/web-encoding-guide/" class="group">
            <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 h-full dark:bg-gray-950 dark:border-gray-800 dark:hover:border-blue-600">
              <div class="w-14 h-14 bg-green-50 rounded-xl flex items-center justify-center mb-5 text-green-600 group-hover:bg-green-600 group-hover:text-white transition-all dark:bg-green-600/20 dark:text-green-400">
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              </div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2 dark:text-white">Web Encoding Explained</h3>
              <p class="text-gray-500 text-sm dark:text-gray-400">Base64, URL encoding, and HTML entities — when to use each, common mistakes, and practical code examples.</p>
            </div>
          </a>
          <a href="/guides/text-processing-guide/" class="group">
            <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 h-full dark:bg-gray-950 dark:border-gray-800 dark:hover:border-blue-600">
              <div class="w-14 h-14 bg-purple-50 rounded-xl flex items-center justify-center mb-5 text-purple-600 group-hover:bg-purple-600 group-hover:text-white transition-all dark:bg-purple-600/20 dark:text-purple-400">
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              </div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2 dark:text-white">Text Processing for Developers</h3>
              <p class="text-gray-500 text-sm dark:text-gray-400">Regex patterns, case conversion, deduplication, and word counting — practical workflows for everyday text tasks.</p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Latest Articles Section -->
    <section class="py-16 sm:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4 dark:text-white">Latest Articles</h2>
          <p class="text-lg text-gray-500 max-w-2xl mx-auto dark:text-gray-400">In-depth guides and tutorials for developers</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          <a href="/guides/password-hash-guide/" class="group">
            <div class="bg-white border border-gray-200 rounded-2xl p-8 flex gap-5 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600">
              <div class="w-16 h-16 bg-orange-50 rounded-xl flex items-center justify-center flex-shrink-0 text-orange-600 group-hover:bg-orange-600 group-hover:text-white transition-all dark:bg-orange-600/20 dark:text-orange-400">
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <span class="text-xs text-blue-500 font-medium">Security</span>
                <h3 class="text-lg font-semibold text-gray-900 mt-1 mb-2 dark:text-white">Password Security &amp; Hash Algorithms</h3>
                <p class="text-gray-500 text-sm dark:text-gray-400">MD5 vs SHA-256, password hashing best practices, UUIDs, and how to avoid common security mistakes.</p>
              </div>
            </div>
          </a>
          <a href="/guides/css-color-gradient-guide/" class="group">
            <div class="bg-white border border-gray-200 rounded-2xl p-8 flex gap-5 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200 dark:bg-gray-900 dark:border-gray-800 dark:hover:border-blue-600">
              <div class="w-16 h-16 bg-pink-50 rounded-xl flex items-center justify-center flex-shrink-0 text-pink-600 group-hover:bg-pink-600 group-hover:text-white transition-all dark:bg-pink-600/20 dark:text-pink-400">
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/></svg>
              </div>
              <div>
                <span class="text-xs text-blue-500 font-medium">Frontend</span>
                <h3 class="text-lg font-semibold text-gray-900 mt-1 mb-2 dark:text-white">CSS Colors &amp; Gradients Guide</h3>
                <p class="text-gray-500 text-sm dark:text-gray-400">HEX, RGB, HSL explained. Building color palettes and creating beautiful CSS gradients with practical examples.</p>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section id="faq" class="bg-gray-50 border-y border-gray-200 py-16 sm:py-20 dark:bg-gray-900 dark:border-gray-800">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4 dark:text-white">Frequently Asked Questions</h2>
          <p class="text-lg text-gray-500 dark:text-gray-400">Got questions? We've got answers.</p>
        </div>

        <div class="space-y-4">
          <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden dark:bg-gray-950 dark:border-gray-800">
            <summary class="flex items-center justify-between px-6 py-5 cursor-pointer hover:bg-gray-50 transition-colors list-none dark:hover:bg-gray-900">
              <span class="text-gray-900 font-medium pr-4 dark:text-white">Are these tools really free?</span>
              <svg class="w-5 h-5 text-gray-400 flex-shrink-0 group-open:rotate-180 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </summary>
            <div class="px-6 pb-5 text-gray-500 dark:text-gray-400">
              <p>Yes! All tools are 100% free to use, with no hidden fees, no paywalls, and no sign-up required. We believe essential developer tools should be accessible to everyone.</p>
            </div>
          </details>

          <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden dark:bg-gray-950 dark:border-gray-800">
